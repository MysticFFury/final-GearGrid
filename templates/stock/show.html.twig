{% extends 'base.html.twig' %}

{% block title %}Stock movement #{{ movement.id }} | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<style>
    :root {
        --primary: #6C63FF;
        --secondary: #ff6584;
        --bg-base: #0B1120;
        --text-muted: #94a3b8;
    }
    .dashboard main {
        margin-left: 16rem;
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-base);
    }
    .detail-table { width: 100%; border-collapse: collapse; margin-bottom: 2rem; }
    .detail-table tr { border-bottom: 1px solid rgba(255,255,255,0.05); }
    .detail-table th {
        text-align: left; padding: 1.5rem 0; color: var(--text-muted);
        font-weight: 500; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1.5px; width: 35%;
    }
    .detail-table td { padding: 1.5rem 0; color: #fff; font-size: 1.05rem; }
    .badge-secondary { color: var(--secondary); font-family: monospace; background: rgba(255,101,132,0.1); padding: 6px 12px; border-radius: 6px; font-weight: 600; }
    .badge-success { background: rgba(74,222,128,0.2); color: #4ade80; padding: 6px 12px; border-radius: 6px; font-weight: 600; }
    @media (max-width: 768px) {
        .dashboard main { margin-left: 0; padding: 1rem; }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 pb-6 border-b border-gray-800">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">Stock movement</h1>
                <nav class="flex items-center gap-2 text-sm text-gray-400 flex-wrap">
                    <a href="{{ path('app_dashboard') }}" class="hover:text-purple-400 transition-colors">Dashboard</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <a href="{{ path('app_stock_index') }}" class="hover:text-purple-400 transition-colors">Stock</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <span class="text-pink-400 font-semibold">#{{ movement.id }}</span>
                </nav>
            </div>
            <div class="mt-4 md:mt-0">
                {% include 'partials/_user_dropdown.html.twig' %}
            </div>
        </div>

        {% set actor = movement.createdBy %}
        {% set is_admin_actor = actor and 'ROLE_ADMIN' in actor.roles %}

        <div class="max-w-3xl mx-auto">
            <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-8 border-t-4 border-t-purple-500">
                <h2 class="text-xl font-semibold text-white mb-8 flex items-center gap-3"><i class="fas fa-warehouse text-purple-500"></i> Movement details</h2>

                <table class="detail-table">
                    <tbody>
                        <tr>
                            <th>ID</th>
                            <td><span class="badge-secondary">#{{ movement.id }}</span></td>
                        </tr>
                        <tr>
                            <th>Product</th>
                            <td class="font-medium">{{ movement.product ? movement.product.name : '—' }}</td>
                        </tr>
                        <tr>
                            <th>Quantity added</th>
                            <td><span class="badge-success">+{{ movement.amount }}</span></td>
                        </tr>
                        <tr>
                            <th>Recorded by</th>
                            <td>{{ actor ? (actor.name|default(actor.userIdentifier)) : '—' }}</td>
                        </tr>
                        <tr>
                            <th>Role at time</th>
                            <td class="text-gray-400">{{ is_admin_actor ? 'Admin' : 'Staff' }}</td>
                        </tr>
                        <tr>
                            <th>Product stock after (current)</th>
                            <td class="text-gray-400">{{ movement.product ? (movement.product.quantity ?? 0) : '—' }} <span class="text-gray-500 text-sm">(live total — may change after later sales or stock adds)</span></td>
                        </tr>
                        <tr>
                            <th>Created at</th>
                            <td class="text-gray-400">{{ movement.createdAt ? movement.createdAt|date('F d, Y g:i A') : '—' }}</td>
                        </tr>
                    </tbody>
                </table>

                <p class="text-gray-500 text-sm mb-6">Like Activity Logs, movements are <strong class="text-gray-400">read-only</strong> after they are saved.</p>

                <div class="flex flex-wrap gap-3 pt-6 border-t border-gray-700">
                    <a href="{{ path('app_stock_index') }}" class="bg-gray-700/50 hover:bg-gray-600/50 text-gray-300 border border-gray-600 px-4 py-2 rounded-lg font-medium flex items-center gap-2">
                        <i class="fas fa-arrow-left"></i> Back to list
                    </a>
                    <a href="{{ path('app_stock_new') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium flex items-center gap-2">
                        <i class="fas fa-plus"></i> Add stock
                    </a>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}
