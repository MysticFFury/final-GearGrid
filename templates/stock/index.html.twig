{% extends 'base.html.twig' %}

{% block title %}Stock Activity | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<style>
    :root {
        --primary: #6C63FF;
        --secondary: #ff6584;
        --bg-base: #0B1120;
        --text-muted: #94a3b8;
        --glass-border: rgba(255,255,255,0.06);
    }
    .dashboard main {
        margin-left: 16rem;
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-base);
    }
    .styled-table { width: 100%; border-collapse: collapse; }
    .styled-table thead { background: rgba(255,255,255,0.03); }
    .styled-table th {
        padding: 1rem 1.2rem; text-align: left; color: var(--text-muted);
        font-weight: 600; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1.5px;
        border-bottom: 2px solid var(--glass-border);
    }
    .styled-table td {
        padding: 1.2rem; color: #fff; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.9rem;
    }
    .styled-table tbody tr:hover { background: rgba(255,255,255,0.03); }
    .badge-id { color: var(--secondary); font-family: monospace; background: rgba(255,101,132,0.1); padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: 600; }
    .badge-qty { background: rgba(74,222,128,0.2); color: #4ade80; padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: 600; }
    .badge-role-admin { background: rgba(108,99,255,0.2); color: var(--primary); padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: 600; }
    .badge-role-staff { background: rgba(148,163,184,0.15); color: #94a3b8; padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: 600; }
    select option { background: #1f2937; color: #fff; }
    @media (max-width: 768px) {
        .dashboard main { margin-left: 0; padding: 1rem; }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 pb-6 border-b border-gray-800">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">Stock Activity</h1>
                <nav class="flex items-center gap-2 text-sm text-gray-400">
                    <a href="{{ path('app_dashboard') }}" class="hover:text-purple-400 transition-colors">Dashboard</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <span class="text-pink-400 font-semibold">Stock</span>
                </nav>
                <p class="text-gray-400 text-sm mt-2 max-w-2xl">Inventory additions (same style as Activity Logs). Use <strong class="text-gray-300">Add stock</strong> to record new quantities.</p>
            </div>
            <div class="mt-4 md:mt-0 flex flex-wrap items-center gap-3">
                <a href="{{ path('app_stock_new') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-lg shadow-purple-500/20">
                    <i class="fas fa-plus"></i> Add stock
                </a>
                {% include 'partials/_user_dropdown.html.twig' %}
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="bg-green-500/20 border border-green-500/30 text-green-400 px-4 py-3 rounded-lg mb-4 flex justify-between items-center gap-3">
                <span><i class="fas fa-check-circle"></i> {{ message }}</span>
                <button type="button" onclick="this.parentElement.remove()" class="text-green-400 text-xl leading-none">&times;</button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="bg-red-500/20 border border-red-500/30 text-red-400 px-4 py-3 rounded-lg mb-4 flex justify-between items-center gap-3">
                <span><i class="fas fa-exclamation-circle"></i> {{ message }}</span>
                <button type="button" onclick="this.parentElement.remove()" class="text-red-400 text-xl leading-none">&times;</button>
            </div>
        {% endfor %}

        <form method="get" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 mb-6 p-6 bg-gray-800/30 border border-gray-700 rounded-xl">
            <input type="text" name="user" value="{{ filters.user }}" placeholder="🔍 Filter by staff name or email" class="px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500">
            <select name="product" class="px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500">
                <option value="">All products</option>
                {% for p in products %}
                    <option value="{{ p.id }}" {% if filters.product != '' and filters.product == (p.id ~ '') %}selected{% endif %}>{{ p.name }}</option>
                {% endfor %}
            </select>
            <input type="date" name="from" value="{{ filters.from }}" class="px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500">
            <input type="date" name="to" value="{{ filters.to }}" class="px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500">
            <div class="flex gap-3 md:col-span-2 lg:col-span-4 justify-end">
                <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                    <i class="fas fa-filter"></i> Filter
                </button>
                <a href="{{ path('app_stock_index') }}" class="bg-gray-700/50 hover:bg-gray-600/50 text-gray-300 border border-gray-600 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                    <i class="fas fa-undo"></i> Reset
                </a>
            </div>
        </form>

        <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-6 border-t-4 border-t-purple-500">
            <h2 class="text-xl font-semibold text-white flex items-center gap-3 mb-4"><i class="fas fa-warehouse text-purple-500"></i> Stock movement list</h2>
            <table id="stockTable" class="display styled-table" style="width:100%;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Product</th>
                        <th>Qty added</th>
                        <th>User</th>
                        <th>Role</th>
                        <th>Created at</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for m in movements %}
                        {% set actor = m.createdBy %}
                        {% set is_admin_actor = actor and 'ROLE_ADMIN' in actor.roles %}
                        <tr>
                            <td><span class="badge-id">#{{ m.id }}</span></td>
                            <td>{{ m.product ? m.product.name : '—' }}</td>
                            <td><span class="badge-qty">+{{ m.amount }}</span></td>
                            <td>{{ actor ? (actor.name|default(actor.userIdentifier)) : '—' }}</td>
                            <td>
                                {% if is_admin_actor %}
                                    <span class="badge-role-admin">Admin</span>
                                {% else %}
                                    <span class="badge-role-staff">Staff</span>
                                {% endif %}
                            </td>
                            <td class="text-gray-400">{{ m.createdAt ? m.createdAt|date('M d, Y H:i') : '—' }}</td>
                            <td>
                                <a href="{{ path('app_stock_show', { id: m.id }) }}" class="bg-purple-600/20 hover:bg-purple-600/30 text-purple-400 border border-purple-600/30 px-3 py-1.5 rounded-lg text-sm font-medium inline-flex items-center gap-1">
                                    <i class="fas fa-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-8 text-gray-400">
                                <i class="fas fa-warehouse text-4xl mb-3 opacity-50 block"></i>
                                No stock movements found.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script>
$(document).ready(function() {
    $('#stockTable').DataTable({
        pageLength: 10,
        lengthMenu: [5, 10, 25, 50],
        order: [[0, 'desc']],
        columnDefs: [{ orderable: false, targets: 6 }],
        autoWidth: false,
        dom: 'lrtip',
        language: {
            search: '',
            searchPlaceholder: 'Search...',
            lengthMenu: 'Show _MENU_ entries',
            info: 'Showing _START_ to _END_ of _TOTAL_ movements',
            infoEmpty: 'No movements',
            infoFiltered: '(filtered from _MAX_ total)'
        }
    });
});
</script>
{% endblock %}
