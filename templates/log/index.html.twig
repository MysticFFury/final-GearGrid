{% extends 'base.html.twig' %}

{% block title %}Logs | GearGrid Admin{% endblock %}

{% block stylesheets %}
<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<!-- DataTables CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">

<style>
.dashboard main { padding: 2rem; }

.top-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
.top-header h1 { font-family: 'Oswald', sans-serif; color: #fff; }

.profile img { width: 40px; height: 40px; border-radius: 50%; margin-right: 0.5rem; }

.table-card {
    background: #1e1e2f;
    padding: 1.5rem;
    border-radius: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    margin-top: 1rem;
}

table.dataTable thead th {
    color: #fff;
    font-weight: bold;
    border-bottom: 1px solid #444;
}

table.dataTable tbody td {
    color: #e0e0e0;
    border-bottom: 1px solid #333;
}

.btn-show, .btn-edit, .btn-add {
    padding: 0.3rem 0.6rem;
    border-radius: 8px;
    color: #fff;
    text-decoration: none;
    margin-right: 0.3rem;
    font-weight: bold;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 4px;
}

.btn-show { background: #6C63FF; }
.btn-edit { background: #ff6584; }
.btn-add { background: #00c6ff; margin-left: 1rem; }

.btn-show:hover, .btn-edit:hover, .btn-add:hover { opacity: 0.85; }

.content-actions {
    display: flex;
    align-items: center;
    margin-bottom: 1rem;
    justify-content: space-between;
}

.search-input {
    padding: 0.5rem 0.8rem;
    border-radius: 8px;
    border: 1px solid #444;
    background: #2a2a3f;
    color: #fff;
    width: 250px;
}

.search-input::placeholder { color: #aaa; }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}
    <main class="main-content">
        <div class="top-header">
            <h1>Logs</h1>
            <div class="profile">
                <img src="https://ui-avatars.com/api/?name=John+Ralf&background=17a2b8&color=fff" alt="User">
                <span>John Ralf</span>
            </div>
        </div>

        <div class="content-area">
            <div class="content-header">
                <h1>Activity Logs</h1>
                <div class="content-actions">
                    <input type="text" id="logSearch" class="search-input" placeholder="🔍 Search logs...">
                    <a href="{{ path('app_log_new') }}" class="btn-add">
                        <i class="fas fa-plus"></i> Create Log
                    </a>
                </div>
            </div>

            <div class="table-card">
                <table id="logTable" class="display styled-table" style="width:100%;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Action</th>
                            <th>Message</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in logs %}
                            <tr>
                                <td>{{ log.id }}</td>
                                <td>{{ log.action }}</td>
                                <td>{{ log.message }}</td>
                                <td>{{ log.createdAt ? log.createdAt|date('Y-m-d H:i:s') : '-' }}</td>
                                <td>
                                    <a href="{{ path('app_log_show', {'id': log.id}) }}" class="btn-show">
                                        <i class="fas fa-eye"></i> Show
                                    </a>
                                    <a href="{{ path('app_log_edit', {'id': log.id}) }}" class="btn-edit">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" style="text-align:center;">No logs found.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script>
$(document).ready(function() {
    const table = $('#logTable').DataTable({
        pageLength: 10,
        lengthMenu: [5, 10, 25, 50],
        order: [[0, 'desc']],
        columnDefs: [{ orderable: false, targets: 4 }],
        autoWidth: false
    });

    $('#logSearch').on('keyup', function () {
        table.search(this.value).draw();
    });
});
</script>
{% endblock %}
