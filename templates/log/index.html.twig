{% extends 'base.html.twig' %}

{% block title %}Logs | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    :root {
        --primary: #6C63FF;
        --secondary: #ff6584;
        --danger: #dc3545;
        --bg-dark: #12121e;
        --card-bg: #1e1e2f;
        --text-muted: #88889b;
        --glass-border: rgba(255, 255, 255, 0.08);
    }

    .dashboard main {
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-dark);
        font-family: 'Inter', sans-serif;
    }

    /* --- TOP BAR STYLING --- */
    .top-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--glass-border);
    }

    .header-left h1 {
        font-family: 'Oswald', sans-serif;
        color: #fff;
        font-size: 2rem;
        letter-spacing: 1px;
        margin: 0;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-top: 8px;
    }

    .breadcrumb a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s;
    }

    .breadcrumb a:hover { color: var(--primary); }

    .breadcrumb i { font-size: 0.7rem; opacity: 0.5; }

    .breadcrumb span { color: var(--secondary); font-weight: 600; }

    .header-right .profile {
        display: flex;
        align-items: center;
        gap: 15px;
        background: rgba(255, 255, 255, 0.03);
        padding: 8px 20px;
        border-radius: 50px;
        border: 1px solid var(--glass-border);
        transition: all 0.3s ease;
    }

    .header-right .profile:hover {
        background: rgba(255, 255, 255, 0.08);
        transform: translateY(-2px);
    }

    .text-info {
        display: flex;
        flex-direction: column;
        text-align: right;
    }

    .text-info .name { color: #fff; font-weight: 600; font-size: 0.9rem; }
    .text-info .role { color: var(--text-muted); font-size: 0.75rem; }

    .avatar-wrapper { position: relative; width: 42px; height: 42px; }
    .avatar-wrapper img { width: 100%; height: 100%; border-radius: 50%; border: 2px solid var(--primary); }
    .status-indicator {
        position: absolute; bottom: 2px; right: 2px; width: 10px; height: 10px;
        background: #4ade80; border: 2px solid var(--bg-dark); border-radius: 50%;
    }

    /* --- CONTENT AREA --- */
    .content-area {
        width: 100%;
    }

    /* --- CONTENT HEADER --- */
    .content-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1.5rem;
    }

    .content-header h2 {
        font-family: 'Oswald', sans-serif;
        color: #fff;
        font-size: 1.5rem;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .content-header h2 i {
        color: var(--primary);
    }

    /* --- FILTER BAR --- */
    .filter-bar {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 12px;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background: var(--card-bg);
        border-radius: 16px;
        border: 1px solid var(--glass-border);
    }

    .filter-bar input,
    .filter-bar select {
        padding: 0.75rem 1rem;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

    .filter-bar input:focus,
    .filter-bar select:focus {
        outline: none;
        border-color: var(--primary);
        background: rgba(255, 255, 255, 0.08);
        box-shadow: 0 0 20px rgba(108, 99, 255, 0.2);
    }

    .filter-bar input::placeholder {
        color: var(--text-muted);
    }

    .filter-bar select option {
        background: var(--card-bg);
        color: #fff;
    }

    .filter-actions {
        display: flex;
        gap: 10px;
        align-items: center;
        grid-column: 1 / -1;
        justify-content: flex-end;
    }

    .btn-filter,
    .btn-reset {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0.75rem 1.5rem;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        color: #fff;
    }

    .btn-filter {
        background: var(--primary);
        box-shadow: 0 4px 20px rgba(108, 99, 255, 0.25);
    }

    .btn-filter:hover {
        transform: translateY(-2px);
        filter: brightness(1.2);
    }

    .btn-reset {
        background: rgba(255, 255, 255, 0.05);
        color: #ccc;
        border: 1px solid var(--glass-border);
    }

    .btn-reset:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
    }

    /* --- TABLE CARD --- */
    .table-card {
        background: var(--card-bg);
        padding: 2rem;
        border-radius: 24px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        border: 1px solid var(--glass-border);
        position: relative;
        overflow: hidden;
    }

    .table-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, var(--primary), var(--secondary));
    }

    /* --- DATA TABLE STYLING --- */
    .styled-table {
        width: 100%;
        border-collapse: collapse;
    }

    .styled-table thead {
        background: rgba(255, 255, 255, 0.03);
    }

    .styled-table th {
        padding: 1rem 1.2rem;
        text-align: left;
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1.5px;
        border-bottom: 2px solid var(--glass-border);
    }

    .styled-table td {
        padding: 1.2rem 1.2rem;
        color: #fff;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        font-size: 0.9rem;
    }

    .styled-table tbody tr {
        transition: all 0.2s ease;
    }

    .styled-table tbody tr:hover {
        background: rgba(255, 255, 255, 0.03);
    }

    .styled-table tbody tr:last-child td {
        border-bottom: none;
    }

    /* --- ACTION BUTTONS --- */
    .btn-view {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        font-size: 0.85rem;
        transition: all 0.3s ease;
        background: rgba(108, 99, 255, 0.2);
        color: var(--primary);
        border: 1px solid rgba(108, 99, 255, 0.3);
    }

    .btn-view:hover {
        background: rgba(108, 99, 255, 0.3);
        transform: translateY(-2px);
    }

    /* --- BADGES --- */
    .badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .badge-id {
        color: var(--secondary);
        font-family: monospace;
        background: rgba(255,101,132,0.1);
    }

    .badge-action {
        background: rgba(108, 99, 255, 0.2);
        color: var(--primary);
    }

    .badge-status-active {
        background: rgba(74, 222, 128, 0.2);
        color: #4ade80;
    }

    .badge-status-inactive {
        background: rgba(220, 53, 69, 0.2);
        color: #ff6b6b;
    }

    /* --- RESPONSIVE --- */
    @media screen and (max-width: 768px) {
        .dashboard main {
            padding: 1.5rem 1rem;
        }

        .top-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }

        .header-right {
            width: 100%;
        }

        .header-right .profile {
            justify-content: space-between;
        }

        .content-header {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-bar {
            grid-template-columns: 1fr;
        }

        .filter-actions {
            grid-column: 1;
            flex-direction: column;
        }

        .btn-filter,
        .btn-reset {
            width: 100%;
            justify-content: center;
        }

        .table-card {
            padding: 1rem;
            overflow-x: auto;
        }

        .styled-table {
            font-size: 0.85rem;
        }

        .styled-table th,
        .styled-table td {
            padding: 0.75rem 0.5rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <div class="top-header">
            <div class="header-left">
                <h1>Activity Logs</h1>
                <nav class="breadcrumb">
                    <a href="{{ path('app_dashboard') }}">Dashboard</a> 
                    <i class="fas fa-chevron-right"></i> 
                    <span>Logs</span>
                </nav>
            </div>

            <div class="header-right">
                <div class="user-info">
                    <div class="profile">
                        <div class="text-info">
                            <span class="name">{{ app.user.name|default('User') }}</span>
                            <span class="role">{% if is_granted('ROLE_ADMIN') %}Administrator{% else %}Staff{% endif %}</span>
                        </div>
                        <div class="avatar-wrapper">
                            <img src="https://ui-avatars.com/api/?name={{ app.user.name|default('User')|url_encode }}&background=6C63FF&color=fff" alt="User">
                            <span class="status-indicator"></span>
                        </div>
                        <i class="fas fa-chevron-down" style="color: var(--text-muted); font-size: 0.8rem;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="content-area">
            <div class="content-header">
                <h2><i class="fas fa-file-alt"></i> Log List</h2>
            </div>

            <form method="get" class="filter-bar">
                <input type="text" name="user" value="{{ filters.user }}" placeholder="🔍 Filter by user">
                <select name="action">
                    <option value="">All Actions</option>
                    {% for action in actions %}
                        <option value="{{ action }}" {% if filters.action == action %}selected{% endif %}>
                            {{ action }}
                        </option>
                    {% endfor %}
                </select>
                <input type="date" name="from" value="{{ filters.from }}" placeholder="From date">
                <input type="date" name="to" value="{{ filters.to }}" placeholder="To date">
                <div class="filter-actions">
                    <button type="submit" class="btn-filter">
                        <i class="fas fa-filter"></i> Filter
                    </button>
                    <a href="{{ path('app_log_index') }}" class="btn-reset">
                        <i class="fas fa-undo"></i> Reset
                    </a>
                </div>
            </form>

            <div class="table-card">
                <table id="logTable" class="display styled-table" style="width:100%;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Action</th>
                            <th>Message</th>
                            <th>Status</th>
                            <th>User</th>
                            <th>Role</th>
                            <th>Entity</th>
                            <th>Created At</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in logs %}
                            <tr>
                                <td><span class="badge badge-id">#{{ log.id }}</span></td>
                                <td><span class="badge badge-action">{{ log.action }}</span></td>
                                <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{ log.message }}</td>
                                <td>
                                    <span class="badge {% if log.status == 'active' %}badge-status-active{% else %}badge-status-inactive{% endif %}">
                                        {{ log.status|capitalize }}
                                    </span>
                                </td>
                                <td>{{ log.userName ?: 'Anonymous' }}</td>
                                <td style="color: var(--text-muted);">{{ log.userRole ?: '-' }}</td>
                                <td style="color: var(--text-muted);">{{ log.entity ?: '-' }}</td>
                                <td style="color: var(--text-muted);">{{ log.createdAt ? log.createdAt|date('M d, Y H:i') : '-' }}</td>
                                <td>
                                    <a href="{{ path('app_log_show', {'id': log.id}) }}" class="btn-view">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" style="text-align:center; padding: 2rem; color: var(--text-muted);">
                                    <i class="fas fa-file-alt" style="font-size: 2rem; margin-bottom: 1rem; display: block; opacity: 0.5;"></i>
                                    No logs found.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script>
$(document).ready(function() {
    const table = $('#logTable').DataTable({
        pageLength: 10,
        lengthMenu: [5, 10, 25, 50],
        order: [[0, 'desc']],
        columnDefs: [{ orderable: false, targets: 8 }],
        autoWidth: false,
        dom: 'lrtip',
        language: {
            search: "",
            searchPlaceholder: "Search...",
            lengthMenu: "Show _MENU_ entries",
            info: "Showing _START_ to _END_ of _TOTAL_ logs",
            infoEmpty: "No logs available",
            infoFiltered: "(filtered from _MAX_ total logs)"
        }
    });
});
</script>
{% endblock %}
