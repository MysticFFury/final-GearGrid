{% extends 'base.html.twig' %}

{% block title %}Edit Log{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --primary: #6C63FF;
        --primary-hover: #5b54d6;
        --secondary: #ff6584;
        --success: #4ade80;
        --bg-base: #0B1120;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --glass-bg: rgba(255, 255, 255, 0.02);
        --glass-bg-hover: rgba(255, 255, 255, 0.04);
        --glass-border: rgba(255, 255, 255, 0.06);
        --glass-border-hover: rgba(255, 255, 255, 0.12);
        --danger: #dc3545;
        --card-bg: rgba(255, 255, 255, 0.02);
    }

    .dashboard main {
        margin-left: 16rem;
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-base);
    }

    @media (max-width: 768px) {
        .dashboard main {
            margin-left: 0;
            padding: 1rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}
    <main class="main-content">
        <div class="form-card">
            <h2>Edit Log #{{ log.id }}</h2>

            {{ form_start(form) }}
                {{ form_widget(form) }}
                <div style="margin-top: 1rem;">
                    <button class="btn-save"><i class="fas fa-save"></i> Update</button>
                    <a href="{{ path('app_log_index') }}" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
                </div>
            {{ form_end(form) }}

            <div style="margin-top: 1rem;">
                <form method="post" action="{{ path('app_log_delete', {'id': log.id}) }}" 
                      onsubmit="return confirm('Are you sure you want to delete this log?');" style="display:inline-block;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ log.id) }}">
                    <button class="btn-delete"><i class="fas fa-trash"></i> Delete</button>
                </form>
                <form method="post" action="{{ path('app_log_toggle', {'id': log.id}) }}" style="display:inline-block;">
                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ log.id) }}">
                    <button class="btn-toggle">{{ log.status == 'active' ? 'Deactivate' : 'Activate' }}</button>
                </form>
            </div>
        </div>
    </main>
</div>
{% endblock %}
