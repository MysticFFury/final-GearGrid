{% extends 'base.html.twig' %}

{% block title %}Edit Log{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    .form-card {
        background: #1e1e2f;
        padding: 2rem;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        max-width: 700px;
        margin: 2rem auto;
        color: #e0e0e0;
    }

    .form-card h2 {
        color: #fff;
        margin-bottom: 1.5rem;
    }

    .form-card label {
        display: block;
        margin-bottom: 0.3rem;
        font-weight: bold;
    }

    .form-card input, 
    .form-card textarea, 
    .form-card select {
        width: 100%;
        padding: 0.5rem;
        margin-bottom: 1rem;
        border-radius: 8px;
        border: 1px solid #444;
        background: #2a2a3f;
        color: #fff;
    }

    .btn-back, .btn-save, .btn-delete, .btn-toggle {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        color: #fff;
        text-decoration: none;
        font-weight: bold;
        margin-right: 0.5rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s;
    }

    .btn-back { background: #6C63FF; }
    .btn-save { background: #00c6ff; }
    .btn-delete { background: #ff4d4f; }
    .btn-toggle { background: #ff6584; }

    .btn-back:hover, .btn-save:hover, .btn-delete:hover, .btn-toggle:hover { opacity: 0.85; }

</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}
    <main class="main-content">
        <div class="form-card">
            <h2>Edit Log #{{ log.id }}</h2>

            {{ form_start(form) }}
                {{ form_widget(form) }}
                <div style="margin-top: 1rem;">
                    <button class="btn-save"><i class="fas fa-save"></i> Update</button>
                    <a href="{{ path('app_log_index') }}" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
                </div>
            {{ form_end(form) }}

            <div style="margin-top: 1rem;">
                <form method="post" action="{{ path('app_log_delete', {'id': log.id}) }}" 
                      onsubmit="return confirm('Are you sure you want to delete this log?');" style="display:inline-block;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ log.id) }}">
                    <button class="btn-delete"><i class="fas fa-trash"></i> Delete</button>
                </form>
                <form method="post" action="{{ path('app_log_toggle', {'id': log.id}) }}" style="display:inline-block;">
                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ log.id) }}">
                    <button class="btn-toggle">{{ log.status == 'active' ? 'Deactivate' : 'Activate' }}</button>
                </form>
            </div>
        </div>
    </main>
</div>
{% endblock %}
