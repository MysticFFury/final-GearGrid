{% extends 'base.html.twig' %}

{% block title %}Create New Log{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    .form-card {
        background: #1e1e2f;
        padding: 2rem;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        max-width: 700px;
        margin: 2rem auto;
        color: #e0e0e0;
    }

    .form-card h2 {
        color: #fff;
        margin-bottom: 1.5rem;
    }

    .form-card label {
        display: block;
        margin-bottom: 0.3rem;
        font-weight: bold;
    }

    .form-card input, 
    .form-card textarea, 
    .form-card select {
        width: 100%;
        padding: 0.5rem;
        margin-bottom: 1rem;
        border-radius: 8px;
        border: 1px solid #444;
        background: #2a2a3f;
        color: #fff;
    }

    .btn-back, .btn-save {
        padding: 0.5rem 1rem;
        border-radius: 8px;
        color: #fff;
        text-decoration: none;
        font-weight: bold;
        margin-right: 0.5rem;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s;
    }

    .btn-back { background: #6C63FF; }
    .btn-save { background: #00c6ff; }

    .btn-back:hover, .btn-save:hover { opacity: 0.85; }

</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}
    <main class="main-content">
        <div class="form-card">
            <h2>Create New Log</h2>

            {{ form_start(form) }}
                {{ form_widget(form) }}
                <div style="margin-top: 1rem;">
                    <button class="btn-save"><i class="fas fa-plus"></i> Create</button>
                    <a href="{{ path('app_log_index') }}" class="btn-back"><i class="fas fa-arrow-left"></i> Back</a>
                </div>
            {{ form_end(form) }}
        </div>
    </main>
</div>
{% endblock %}
