{% extends 'base.html.twig' %}

{% block title %}Create New Log{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --primary: #6C63FF;
        --primary-hover: #5b54d6;
        --secondary: #ff6584;
        --success: #4ade80;
        --bg-base: #0B1120;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --glass-bg: rgba(255, 255, 255, 0.02);
        --glass-bg-hover: rgba(255, 255, 255, 0.04);
        --glass-border: rgba(255, 255, 255, 0.06);
        --glass-border-hover: rgba(255, 255, 255, 0.12);
        --danger: #dc3545;
        --card-bg: rgba(255, 255, 255, 0.02);
    }

    .dashboard main {
        margin-left: 16rem;
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-base);
    }

    @media (max-width: 768px) {
        .dashboard main {
            margin-left: 0;
            padding: 1rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}
    <main class="main-content">
        <div class="max-w-3xl mx-auto">
            <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-8 border-t-4 border-t-purple-500">
                <h2 class="text-xl font-semibold text-white mb-8 flex items-center gap-3"><i class="fas fa-plus text-purple-500"></i> Create New Log</h2>

                {{ form_start(form, { 'attr': { 'class': 'space-y-4' } }) }}
                    {{ form_widget(form) }}
                    <div class="flex flex-wrap gap-3 pt-6 border-t border-gray-700">
                        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-lg shadow-purple-500/20">
                            <i class="fas fa-plus"></i> Create
                        </button>
                        <a href="{{ path('app_log_index') }}" class="bg-gray-700/50 hover:bg-gray-600/50 text-gray-300 hover:text-white border border-gray-600 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                            <i class="fas fa-arrow-left"></i> Back
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </main>
</div>
{% endblock %}
