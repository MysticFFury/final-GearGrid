{% extends 'base.html.twig' %}

{% block title %}Add New User | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --primary: #6C63FF;
        --primary-hover: #5b54d6;
        --secondary: #ff6584;
        --success: #4ade80;
        --bg-base: #0B1120;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --glass-bg: rgba(255, 255, 255, 0.02);
        --glass-bg-hover: rgba(255, 255, 255, 0.04);
        --glass-border: rgba(255, 255, 255, 0.06);
        --glass-border-hover: rgba(255, 255, 255, 0.12);
        --danger: #dc3545;
        --card-bg: rgba(255, 255, 255, 0.02);
    }

    .dashboard main {
        margin-left: 16rem;
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-base);
    }

    @media (max-width: 768px) {
        .dashboard main {
            margin-left: 0;
            padding: 1rem;
        }
    }
</style>
{% endblock %}
        border-bottom: 1px solid var(--border-color);
    }

    .card-title {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text-main);
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .card-title i {
        color: var(--primary);
        font-size: 1.25rem;
    }

    /* Form Styling */
    .gg-form {
        width: 100%;
    }

    .gg-form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .gg-form-grid .gg-full {
        grid-column: 1 / -1;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .gg-form label {
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
    }

    .gg-form input,
    .gg-form select {
        width: 100%;
        padding: 0.875rem 1rem;
        border-radius: 10px;
        border: 1px solid var(--border-color);
        background: var(--bg-elevated);
        color: var(--text-main);
        font-size: 0.95rem;
        font-family: 'Inter', sans-serif;
        transition: all 0.3s ease;
    }

    .gg-form input:focus,
    .gg-form select:focus {
        outline: none;
        border-color: var(--primary);
        background: var(--bg-base);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
    }

    .gg-form select option {
        background: var(--bg-card);
        color: var(--text-main);
    }

    /* Role checkboxes styling */
    .gg-form input[type="checkbox"] {
        width: auto;
        margin-right: 8px;
        accent-color: var(--primary);
    }

    .checkbox-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .checkbox-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: var(--glass-bg);
        border: 1px solid var(--border-color);
        border-radius: 10px;
        transition: all 0.2s ease;
    }

    .checkbox-item:hover {
        background: var(--bg-elevated);
        border-color: var(--primary);
    }

    .checkbox-item label {
        margin: 0;
        text-transform: none;
        letter-spacing: normal;
        font-weight: 500;
        cursor: pointer;
        color: var(--text-main);
    }

    .gg-form .form-error {
        color: var(--danger);
        font-size: 0.8rem;
        margin-top: 0.4rem;
    }

    /* Action Buttons */
    .actions {
        display: flex;
        gap: 1rem;
        justify-content: flex-start;
        align-items: center;
        border-top: 1px solid var(--border-color);
        padding-top: 2rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        cursor: pointer;
        border: none;
        transition: all 0.3s ease;
        font-family: 'Inter', sans-serif;
    }

    .btn-primary {
        background: var(--primary);
        color: #fff;
        box-shadow: 0 4px 14px rgba(99, 102, 241, 0.4);
    }

    .btn-primary:hover {
        background: var(--primary-dark);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.5);
    }

    .btn-secondary {
        background: var(--glass-bg);
        color: var(--text-main);
        border: 1px solid var(--border-color);
    }

    .btn-secondary:hover {
        background: var(--bg-elevated);
        border-color: var(--primary);
    }

    /* Flash Messages */
    .flash-message {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.5rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        box-shadow: var(--shadow-md);
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
    }

    .flash-message.success {
        background: rgba(16, 185, 129, 0.15);
        border: 1px solid rgba(16, 185, 129, 0.3);
        color: var(--success);
    }

    .flash-message.error {
        background: rgba(239, 68, 68, 0.15);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: var(--danger);
    }

    .flash-message span {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .flash-message button {
        background: transparent;
        border: none;
        color: inherit;
        cursor: pointer;
        font-size: 1.25rem;
        opacity: 0.7;
        padding: 0;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .flash-message button:hover {
        opacity: 1;
    }

    /* Responsive */
    @media (max-width: 1200px) {
        .profile-grid {
            grid-template-columns: 1fr;
        }
    }

    @media screen and (max-width: 768px) {
        .dashboard main {
            padding: 1.5rem;
        }

        .card {
            padding: 2rem 1.5rem;
        }

        .gg-form-grid {
            grid-template-columns: 1fr;
        }

        .actions {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <!-- Page Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-white mb-2">Add New User</h1>
            <p class="text-gray-400">Create a new user account with appropriate roles</p>
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="bg-green-500/20 border border-green-500/30 text-green-400 px-4 py-3 rounded-lg mb-4 flex items-center justify-between">
                <span class="flex items-center gap-2">
                    <i class="fas fa-check-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" class="text-green-400 hover:text-green-300 text-xl opacity-80 hover:opacity-100 transition-opacity">&times;</button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="bg-red-500/20 border border-red-500/30 text-red-400 px-4 py-3 rounded-lg mb-4 flex items-center justify-between">
                <span class="flex items-center gap-2">
                    <i class="fas fa-exclamation-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-300 text-xl opacity-80 hover:opacity-100 transition-opacity">&times;</button>
            </div>
        {% endfor %}

        <div class="max-w-3xl mx-auto">
            <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-6 border-t-4 border-t-purple-500">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-semibold text-white flex items-center gap-3"><i class="fas fa-user-plus text-purple-500"></i> User Information</h2>
                    <a href="{{ path('app_user_index') }}" class="bg-gray-700/50 hover:bg-gray-600/50 text-gray-300 hover:text-white border border-gray-600 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                        <i class="fas fa-arrow-left"></i> Back
                    </a>
                </div>

                {{ form_start(form, { 'attr': { 'class': 'space-y-4' } }) }}
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            {{ form_label(form.name, 'Full Name', {'label_attr': {'class': 'block text-sm font-medium text-gray-400 mb-2'}}) }}
                            {{ form_widget(form.name, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500', 'placeholder': 'Enter full name', 'autofocus': true}}) }}
                            {{ form_errors(form.name) }}
                        </div>

                        <div>
                            {{ form_label(form.email, 'Email Address', {'label_attr': {'class': 'block text-sm font-medium text-gray-400 mb-2'}}) }}
                            {{ form_widget(form.email, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500', 'placeholder': 'Enter email address'}}) }}
                            {{ form_errors(form.email) }}
                        </div>

                        <div class="md:col-span-2">
                            {{ form_label(form.roles, 'User Roles', {'label_attr': {'class': 'block text-sm font-medium text-gray-400 mb-2'}}) }}
                            {{ form_widget(form.roles, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500'}}) }}
                            {{ form_errors(form.roles) }}
                        </div>

                        <div>
                            {{ form_label(form.plainPassword.first, 'Password', {'label_attr': {'class': 'block text-sm font-medium text-gray-400 mb-2'}}) }}
                            {{ form_widget(form.plainPassword.first, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500', 'placeholder': 'Enter password'}}) }}
                            {{ form_errors(form.plainPassword.first) }}
                        </div>

                        <div>
                            {{ form_label(form.plainPassword.second, 'Confirm Password', {'label_attr': {'class': 'block text-sm font-medium text-gray-400 mb-2'}}) }}
                            {{ form_widget(form.plainPassword.second, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500', 'placeholder': 'Confirm password'}}) }}
                            {{ form_errors(form.plainPassword.second) }}
                        </div>

                        <div>
                            {{ form_label(form.isActive, 'Account Status', {'label_attr': {'class': 'block text-sm font-medium text-gray-400 mb-2'}}) }}
                            {{ form_widget(form.isActive, {'attr': {'class': 'w-4 h-4 text-purple-600 bg-gray-800 border-gray-600 rounded focus:ring-purple-500'}}) }}
                            {{ form_errors(form.isActive) }}
                        </div>
                    </div>

                    <div class="flex flex-wrap gap-3 pt-6 border-t border-gray-700">
                        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-lg shadow-purple-500/20">
                            <i class="fas fa-save"></i> Create User
                        </button>
                        <a href="{{ path('app_user_index') }}" class="bg-gray-700/50 hover:bg-gray-600/50 text-gray-300 hover:text-white border border-gray-600 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </main>
</div>
{% endblock %}
                    <div class="checkbox-group">
                        {{ form_widget(form.roles) }}
                    </div>
                    {{ form_errors(form.roles) }}
                </div>

                <div class="form-group gg-full">
                    {{ form_label(form.plainPassword) }}
                    {{ form_widget(form.plainPassword, {'attr': {'placeholder': 'Enter password (min 6 characters)'}}) }}
                    {{ form_errors(form.plainPassword) }}
                </div>
            </div>

            <div class="actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Create User
                </button>
                
                <a href="{{ path('app_user_index') }}" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Cancel
                </a>
            </div>

            {{ form_end(form) }}
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Auto-dismiss flash messages after 5 seconds
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
            message.style.transition = 'opacity 0.5s';
            message.style.opacity = '0';
            setTimeout(function() {
                message.remove();
            }, 500);
        });
    }, 5000);
});
</script>
{% endblock %}
