{% extends 'base.html.twig' %}

{% block title %}User Details | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --primary: #6C63FF;
        --primary-hover: #5b54d6;
        --secondary: #ff6584;
        --success: #4ade80;
        --bg-base: #0B1120;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --glass-bg: rgba(255, 255, 255, 0.02);
        --glass-bg-hover: rgba(255, 255, 255, 0.04);
        --glass-border: rgba(255, 255, 255, 0.06);
        --glass-border-hover: rgba(255, 255, 255, 0.12);
        --danger: #dc3545;
        --card-bg: rgba(255, 255, 255, 0.02);
    }

    .dashboard main {
        margin-left: 16rem;
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-base);
    }

    .detail-table { width: 100%; border-collapse: collapse; margin-bottom: 3rem; }
    .detail-table tr { border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
    .detail-table tr:last-child { border: none; }
    .detail-table th {
        text-align: left; padding: 1.5rem 0; color: var(--text-muted);
        font-weight: 500; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1.5px; width: 35%;
    }
    .detail-table td { padding: 1.5rem 0; color: #fff; font-size: 1.1rem; }

    .badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .badge-primary {
        background: rgba(108, 99, 255, 0.2);
        color: var(--primary);
    }

    .badge-success {
        background: rgba(74, 222, 128, 0.2);
        color: #4ade80;
    }

    .badge-danger {
        background: rgba(220, 53, 69, 0.2);
        color: #ff6b6b;
    }

    .badge-secondary {
        color: var(--secondary);
        font-family: monospace;
        background: rgba(255,101,132,0.1);
    }

    @media (max-width: 768px) {
        .dashboard main {
            margin-left: 0;
            padding: 1rem;
        }
    }

        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-main);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .card-title i {
        color: var(--primary);
        font-size: 1.1rem;
    }

    /* Profile Card */
    .profile-card {
        text-align: center;
    }

    .profile-avatar-container {
        position: relative;
        width: 140px;
        height: 140px;
        margin: 0 auto 1.5rem;
    }

    .profile-avatar {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        border: 4px solid var(--primary);
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
        object-fit: cover;
    }

    .status-badge {
        position: absolute;
        bottom: 8px;
        right: 8px;
        width: 24px;
        height: 24px;
        background: var(--success);
        border: 3px solid var(--bg-card);
        border-radius: 50%;
        box-shadow: var(--shadow-md);
    }

    .status-badge.inactive {
        background: var(--danger);
    }

    .profile-name {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 0.5rem;
    }

    .profile-email {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
    }

    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: rgba(99, 102, 241, 0.15);
        color: var(--primary-light);
        border: 1px solid rgba(99, 102, 241, 0.3);
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .profile-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
    }

    .stat-item {
        text-align: center;
    }

    .stat-value {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-main);
    }

    .stat-label {
        color: var(--text-muted);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-top: 0.25rem;
    }

    /* Info Grid */
    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .info-item {
        background: var(--glass-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.25rem;
        transition: all 0.2s ease;
    }

    .info-item:hover {
        background: var(--bg-elevated);
        border-color: var(--primary);
    }

    .info-label {
        color: var(--text-muted);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .info-value {
        color: var(--text-main);
        font-size: 1rem;
        font-weight: 500;
    }

    .info-value i {
        color: var(--primary);
        margin-right: 0.5rem;
    }

    /* Action Buttons */
    .action-buttons {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        cursor: pointer;
        border: none;
        transition: all 0.3s ease;
        font-family: 'Inter', sans-serif;
    }

    .btn-primary {
        background: var(--primary);
        color: #fff;
        box-shadow: 0 4px 14px rgba(99, 102, 241, 0.4);
    }

    .btn-primary:hover {
        background: var(--primary-dark);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.5);
    }

    .btn-secondary {
        background: var(--glass-bg);
        color: var(--text-main);
        border: 1px solid var(--border-color);
    }

    .btn-secondary:hover {
        background: var(--bg-elevated);
        border-color: var(--primary);
    }

    .btn-danger {
        background: rgba(239, 68, 68, 0.15);
        color: var(--danger);
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .btn-danger:hover {
        background: rgba(239, 68, 68, 0.25);
        border-color: var(--danger);
    }

    /* Flash Messages */
    .flash-message {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.5rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        box-shadow: var(--shadow-md);
    }

    .flash-message.success {
        background: rgba(16, 185, 129, 0.15);
        border: 1px solid rgba(16, 185, 129, 0.3);
        color: var(--success);
    }

    .flash-message.error {
        background: rgba(239, 68, 68, 0.15);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: var(--danger);
    }

    .flash-message span {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .flash-message button {
        background: transparent;
        border: none;
        color: inherit;
        cursor: pointer;
        font-size: 1.25rem;
        opacity: 0.7;
        padding: 0;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .flash-message button:hover {
        opacity: 1;
    }

    /* Responsive */
    @media (max-width: 1200px) {
        .profile-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 768px) {
        .dashboard main {
            padding: 1.5rem;
        }

        .profile-stats {
            grid-template-columns: 1fr;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <!-- Page Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-white mb-2">User Details</h1>
            <p class="text-gray-400">View and manage user information</p>
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="bg-green-500/20 border border-green-500/30 text-green-400 px-4 py-3 rounded-lg mb-4 flex items-center justify-between">
                <span class="flex items-center gap-2">
                    <i class="fas fa-check-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" class="text-green-400 hover:text-green-300 text-xl opacity-80 hover:opacity-100 transition-opacity">&times;</button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="bg-red-500/20 border border-red-500/30 text-red-400 px-4 py-3 rounded-lg mb-4 flex items-center justify-between">
                <span class="flex items-center gap-2">
                    <i class="fas fa-exclamation-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-300 text-xl opacity-80 hover:opacity-100 transition-opacity">&times;</button>
            </div>
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Profile Card -->
            <div class="lg:col-span-1">
                <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-6 border-t-4 border-t-purple-500">
                    <div class="text-center">
                        <div class="relative inline-block">
                            <img src="https://ui-avatars.com/api/?name={{ user.name|url_encode }}&background=6366f1&color=fff&size=280" 
                                 alt="{{ user.name }}" class="w-32 h-32 rounded-full mx-auto border-4 border-purple-500/20">
                            <span class="absolute bottom-2 right-2 w-6 h-6 {{ user.isActive ? 'bg-green-500' : 'bg-red-500' }} border-2 border-gray-900 rounded-full"></span>
                        </div>
                        
                        <h2 class="text-2xl font-bold text-white mt-4 mb-2">{{ user.name }}</h2>
                        <p class="text-gray-400 mb-4">{{ user.email }}</p>
                        
                        <div class="flex flex-wrap gap-2 justify-center mb-6">
                            {% for role in user.roles %}
                                {% if role != 'ROLE_USER' %}
                                    <span class="badge badge-primary">
                                        <i class="fas fa-shield-alt text-xs"></i>
                                        {{ role|replace({'ROLE_':''})|capitalize }}
                                    </span>
                                {% endif %}
                            {% else %}
                                <span class="badge badge-primary">
                                    <i class="fas fa-shield-alt text-xs"></i>
                                    User
                                </span>
                            {% endfor %}
                        </div>

                        <div class="grid grid-cols-3 gap-4">
                            <div class="text-center">
                                <div class="text-2xl font-bold text-purple-400">#{{ user.id }}</div>
                                <div class="text-xs text-gray-400 uppercase tracking-wider">ID</div>
                            </div>
                            <div class="text-center">
                                <div class="text-2xl font-bold text-purple-400">{{ user.roles|length }}</div>
                                <div class="text-xs text-gray-400 uppercase tracking-wider">Roles</div>
                            </div>
                            <div class="text-center">
                                <div class="text-2xl font-bold {{ user.isActive ? 'text-green-400' : 'text-red-400' }}">{{ user.isActive ? 'Active' : 'Inactive' }}</div>
                                <div class="text-xs text-gray-400 uppercase tracking-wider">Status</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Info Card -->
            <div class="lg:col-span-2">
                <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-6 border-t-4 border-t-purple-500">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-xl font-semibold text-white flex items-center gap-3"><i class="fas fa-user-circle text-purple-500"></i> Account Information</h2>
                        <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <div class="text-sm text-gray-400 uppercase tracking-wider mb-2">User ID</div>
                            <div class="text-white font-medium">#{{ user.id }}</div>
                        </div>

                        <div>
                            <div class="text-sm text-gray-400 uppercase tracking-wider mb-2">Full Name</div>
                            <div class="text-white font-medium">{{ user.name }}</div>
                        </div>

                        <div>
                            <div class="text-sm text-gray-400 uppercase tracking-wider mb-2">Email Address</div>
                            <div class="text-white font-medium flex items-center gap-2">
                                <i class="fas fa-envelope text-purple-500"></i> {{ user.email }}
                            </div>
                        </div>
                        <div>
                            <div class="text-sm text-gray-400 uppercase tracking-wider mb-2">User Roles</div>
                            <div class="flex flex-wrap gap-2">
                                {% for role in user.roles %}
                                    {% if role != 'ROLE_USER' %}
                                        <span class="badge badge-primary">{{ role|replace({'ROLE_':''})|capitalize }}</span>
                                    {% endif %}
                                {% else %}
                                    <span class="badge badge-primary">User</span>
                                {% endfor %}
                            </div>
                        </div>

                        <div>
                            <div class="text-sm text-gray-400 uppercase tracking-wider mb-2">Account Status</div>
                            <div class="flex items-center gap-2">
                                {% if user.isActive %}
                                    <span class="text-green-400"><i class="fas fa-check-circle"></i> Active</span>
                                {% else %}
                                    <span class="text-red-400"><i class="fas fa-times-circle"></i> Inactive</span>
                                {% endif %}
                            </div>
                        </div>

                        <div>
                            <div class="text-sm text-gray-400 uppercase tracking-wider mb-2">Created Date</div>
                            <div class="text-white font-medium flex items-center gap-2">
                                <i class="fas fa-calendar text-purple-500"></i> {{ user.createdAt ? user.createdAt|date('F d, Y \a\t g:i A') : 'N/A' }}
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-wrap gap-3 pt-6 border-t border-gray-700 mt-6">
                        <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                            <i class="fas fa-edit"></i> Edit User
                        </a>
                        <a href="{{ path('app_user_index') }}" class="bg-gray-700/50 hover:bg-gray-600/50 text-gray-300 hover:text-white border border-gray-600 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                        {{ include('user/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Auto-dismiss flash messages after 5 seconds
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
            message.style.transition = 'opacity 0.5s';
            message.style.opacity = '0';
            setTimeout(function() {
                message.remove();
            }, 500);
        });
    }, 5000);
});
</script>
{% endblock %}
