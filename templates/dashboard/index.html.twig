                        </div>
                        <p class="text-gray-400 font-medium">Welcome back, <span class="text-white">{{ app.user.name|default(app.user.username|default('User')) }}</span>. Here's what's happening today.</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-4">
                        <a href="{{ path('app_order_index') }}" class="btn-glow-primary px-5 py-2.5 rounded-xl text-white text-sm font-semibold flex items-center gap-2">
                            <i class="fas fa-bolt text-xs"></i> View Orders
                        </a>
                        <div class="ml-2 relative z-50">
                            {% include 'partials/_user_dropdown.html.twig' %}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Metrics Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                <div class="panel metric-card card-purple p-6 animate-up delay-100">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <p class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-1">Products</p>
                            <p class="text-4xl text-white font-bold tracking-tight">{{ totalProducts ?? 0 }}</p>
                        </div>
                        <div class="icon-wrapper">
                            <i class="fas fa-box-open"></i>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 mt-2">
                        <span class="text-xs font-medium text-emerald-400 bg-emerald-400/10 px-2 py-1 rounded-md"><i class="fas fa-arrow-up mr-1"></i> Active Inventory</span>
                    </div>
                </div>
                
                <div class="panel metric-card card-pink p-6 animate-up delay-200">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <p class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-1">Categories</p>
                            <p class="text-4xl text-white font-bold tracking-tight">{{ totalCategories ?? 0 }}</p>
                        </div>
                        <div class="icon-wrapper">
                            <i class="fas fa-layer-group"></i>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 mt-2">
                        <span class="text-xs font-medium text-gray-400"><i class="fas fa-tags mr-1"></i> Organized Groups</span>
                    </div>
                </div>
                
                <div class="panel metric-card card-green p-6 animate-up delay-300">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <p class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-1">Orders</p>
                            <p class="text-4xl text-white font-bold tracking-tight">{{ totalOrders ?? 0 }}</p>
                        </div>
                        <div class="icon-wrapper">
                            <i class="fas fa-shopping-bag"></i>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 mt-2">
                        <span class="text-xs font-medium text-emerald-400 bg-emerald-400/10 px-2 py-1 rounded-md"><i class="fas fa-check-circle mr-1"></i> {{ isAdmin ? 'Global' : 'Your' }} Orders</span>
                    </div>
                </div>
                
                <div class="panel metric-card card-blue p-6 animate-up delay-400">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <p class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-1">{{ isAdmin ? 'Users' : 'Revenue' }}</p>
                            <p class="text-4xl text-white font-bold tracking-tight">{% if isAdmin %}{{ totalUsers ?? 0 }}{% else %}₱{{ recentSales|default(0)|number_format(0, '.', ',') }}{% endif %}</p>
                        </div>
                        <div class="icon-wrapper">
                            <i class="fas {{ isAdmin ? 'fa-users' : 'fa-wallet' }}"></i>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 mt-2">
                        <span class="text-xs font-medium text-blue-400 bg-blue-400/10 px-2 py-1 rounded-md"><i class="fas {{ isAdmin ? 'fa-user-plus' : 'fa-chart-line' }} mr-1"></i> {{ isAdmin ? 'Registered' : 'Recent Sales' }}</span>
                    </div>
                </div>
            </div>

            <!-- Charts First Row -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-up delay-200">
                <div class="lg:col-span-2 panel p-6">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h3 class="text-lg text-white font-bold tracking-tight">Order Activity</h3>
                            <p class="text-sm text-gray-400">Monthly breakdown of created vs completed orders</p>
                        </div>
                        <button class="p-2 text-gray-400 hover:text-white transition-colors rounded-lg hover:bg-white/5"><i class="fas fa-ellipsis-h"></i></button>
                    </div>
                    <div class="h-[280px] w-full">
                        <canvas id="ordersLineChart"></canvas>
                    </div>
                </div>
                <div class="panel p-6">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-lg text-white font-bold tracking-tight">Status Overview</h3>
                        <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center"><i class="fas fa-chart-pie text-gray-400"></i></div>
                    </div>
                    <div class="h-[220px] relative flex justify-center items-center">
                        <canvas id="statusDonutChart"></canvas>
                        <!-- Center text for Donut Chart -->
                        <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
                            <span class="text-2xl font-bold text-white">{{ (deliveredCount + pendingCount + processingCount + shippedCount + cancelledCount) ?: 0 }}</span>
                            <span class="text-xs text-gray-400 uppercase tracking-wider">Total</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bottom Row -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-up delay-300">
                
                <div class="lg:col-span-2 panel p-6">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-lg text-white font-bold tracking-tight">Recent Transactions</h3>
                        <a href="{{ path('app_order_index') }}" class="text-sm font-medium text-indigo-400 hover:text-indigo-300 transition-colors flex items-center gap-1">View All <i class="fas fa-arrow-right text-xs"></i></a>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="premium-table text-left">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th class="text-right">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for order in recentOrders|default([])|slice(0, 5) %}
                                    <tr>
                                        <td class="font-semibold text-white">#{{ order.id }}</td>
                                        <td>
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-xs font-bold text-white">
                                                    {{ order.customerName|default('U')|first|upper }}
                                                </div>
                                                <span class="text-gray-300">{{ order.customerName|default('Unknown Customer') }}</span>
                                            </div>
                                        </td>
                                        <td><span class="status-chip status-{{ order.status|lower }}">{{ order.status|default('Unknown') }}</span></td>
                                        <td class="text-gray-400 text-sm">{{ order.createdAt ? order.createdAt|date('M d, Y') : 'N/A' }}</td>
                                        <td class="text-right font-bold text-white">₱{{ order.totalPrice|default(0)|number_format(2, '.', ',') }}</td>
                                    </tr>
                                {% else %}
                                    <tr><td colspan="5" class="py-12 text-center text-gray-500">
                                        <div class="flex flex-col items-center justify-center">
                                            <i class="fas fa-inbox text-4xl mb-3 text-gray-600"></i>
                                            <p>No recent orders found.</p>
                                        </div>
                                    </td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="panel p-6 flex flex-col">
                    <h3 class="text-lg text-white font-bold tracking-tight mb-6">Quick Actions</h3>
                    <div class="flex-1 flex flex-col gap-3 justify-center">
                        <a href="{{ path('app_order_new') }}" class="group relative overflow-hidden rounded-xl p-4 bg-gradient-to-br from-violet-500/10 to-violet-600/5 border border-violet-500/20 hover:border-violet-500/40 transition-all duration-300">
                            <div class="absolute inset-0 bg-violet-500/10 translate-y-[100%] group-hover:translate-y-[0%] transition-transform duration-300 ease-out"></div>
                            <div class="relative flex items-center gap-4">
                                <div class="w-10 h-10 rounded-lg bg-violet-500/20 text-violet-400 flex items-center justify-center"><i class="fas fa-plus"></i></div>
                                <div>
                                    <h4 class="text-white font-semibold text-sm">New Order</h4>
                                    <p class="text-xs text-gray-400 mt-0.5">Process a manual transaction</p>
                                </div>
                            </div>
                        </a>
                        
                        <a href="{{ path('app_product_new') }}" class="group relative overflow-hidden rounded-xl p-4 bg-gradient-to-br from-pink-500/10 to-pink-600/5 border border-pink-500/20 hover:border-pink-500/40 transition-all duration-300">
                            <div class="absolute inset-0 bg-pink-500/10 translate-y-[100%] group-hover:translate-y-[0%] transition-transform duration-300 ease-out"></div>
                            <div class="relative flex items-center gap-4">
                                <div class="w-10 h-10 rounded-lg bg-pink-500/20 text-pink-400 flex items-center justify-center"><i class="fas fa-box-open"></i></div>
                                <div>
                                    <h4 class="text-white font-semibold text-sm">Add Product</h4>
                                    <p class="text-xs text-gray-400 mt-0.5">Expand your inventory</p>
                                </div>
                            </div>
                        </a>

                        <a href="{{ path('app_log_index') }}" class="group relative overflow-hidden rounded-xl p-4 bg-gradient-to-br from-slate-500/10 to-slate-600/5 border border-slate-500/20 hover:border-slate-500/40 transition-all duration-300">
                            <div class="absolute inset-0 bg-slate-500/10 translate-y-[100%] group-hover:translate-y-[0%] transition-transform duration-300 ease-out"></div>
                            <div class="relative flex items-center gap-4">
                                <div class="w-10 h-10 rounded-lg bg-slate-500/20 text-slate-400 flex items-center justify-center"><i class="fas fa-history"></i></div>
                                <div>
                                    <h4 class="text-white font-semibold text-sm">System Logs</h4>
                                    <p class="text-xs text-gray-400 mt-0.5">View recent activity</p>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
{% set deliveredCount = 0 %}
{% set pendingCount = 0 %}
{% set processingCount = 0 %}
{% set shippedCount = 0 %}
{% set cancelledCount = 0 %}
{% for order in recentOrders|default([]) %}
    {% set s = order.status|lower %}
    {% if s in ['delivered', 'completed'] %}
        {% set deliveredCount = deliveredCount + 1 %}
    {% elseif s == 'pending' %}
        {% set pendingCount = pendingCount + 1 %}
    {% elseif s == 'processing' %}
        {% set processingCount = processingCount + 1 %}
    {% elseif s == 'shipped' %}
        {% set shippedCount = shippedCount + 1 %}
    {% elseif s == 'cancelled' %}
        {% set cancelledCount = cancelledCount + 1 %}
    {% endif %}
{% endfor %}

document.addEventListener('DOMContentLoaded', function() {
    Chart.defaults.color = '#94a3b8';
    Chart.defaults.font.family = "'Inter', sans-serif";

    const commonOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { 
            legend: { 
                labels: { usePointStyle: true, padding: 20, font: { weight: '500' } } 
            },
            tooltip: {
                backgroundColor: 'rgba(17, 24, 39, 0.9)',
                titleColor: '#fff',
                bodyColor: '#cbd5e1',
                borderColor: 'rgba(255,255,255,0.1)',
                borderWidth: 1,
                padding: 12,
                boxPadding: 6,
                usePointStyle: true
            }
        },
        scales: {
            x: { 
                grid: { display: false, drawBorder: false },
                ticks: { padding: 10 }
            },
            y: { 
                grid: { color: 'rgba(255,255,255,0.05)', drawBorder: false, borderDash: [5, 5] },
                ticks: { padding: 10 }
            }
        },
        interaction: { mode: 'index', intersect: false }
    };

    // Orders Line Chart
    const lineEl = document.getElementById('ordersLineChart');
    if (lineEl) {
        const ctx = lineEl.getContext('2d');
        const gradientPurple = ctx.createLinearGradient(0, 0, 0, 300);
        gradientPurple.addColorStop(0, 'rgba(139, 92, 246, 0.4)');
        gradientPurple.addColorStop(1, 'rgba(139, 92, 246, 0.0)');

        const gradientPink = ctx.createLinearGradient(0, 0, 0, 300);
        gradientPink.addColorStop(0, 'rgba(236, 72, 153, 0.4)');
        gradientPink.addColorStop(1, 'rgba(236, 72, 153, 0.0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'],
                datasets: [
                    { 
                        label: 'Created Orders', 
                        data: [28, 42, 35, 51, 48, 62, 57], 
                        borderColor: '#8b5cf6', 
                        backgroundColor: gradientPurple, 
                        fill: true, 
                        tension: 0.4, 
                        borderWidth: 3,
                        pointBackgroundColor: '#030712',
                        pointBorderColor: '#8b5cf6',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    },
                    { 
                        label: 'Completed Orders', 
                        data: [18, 30, 22, 40, 37, 48, 45], 
                        borderColor: '#ec4899',
                        backgroundColor: gradientPink,
                        fill: true,
                        tension: 0.4, 
                        borderWidth: 3,
                        pointBackgroundColor: '#030712',
                        pointBorderColor: '#ec4899',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }
                ]
            },
            options: commonOptions
        });
    }

    // Status Donut Chart
    const donutEl = document.getElementById('statusDonutChart');
    if (donutEl) {
        new Chart(donutEl.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['Delivered', 'Pending', 'Processing', 'Shipped', 'Cancelled'],
                datasets: [{
                    data: [{{ deliveredCount }}, {{ pendingCount }}, {{ processingCount }}, {{ shippedCount }}, {{ cancelledCount }}],
                    backgroundColor: ['#10b981', '#f59e0b', '#0ea5e9', '#8b5cf6', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: { 
                responsive: true, 
                maintainAspectRatio: false, 
                cutout: '75%', 
                plugins: { 
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(17, 24, 39, 0.9)',
                        padding: 12,
                        callbacks: {
                            label: function(context) {
                                return ' ' + context.label + ': ' + context.parsed;
                            }
                        }
                    }
                } 
            }
        });
    }
});
</script>
{% endblock %}

