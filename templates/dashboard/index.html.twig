{# templates/dashboard/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Dashboard | GearGrid{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('CSS/admin_layout.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* --- ONLY CHANGING THE BACKGROUND FOR VISIBILITY --- */
        body {
            /* Solid deep background so all text is 100% visible */
            background-color: #0d1117 !important; 
            background-image: none !important;
            color: #f8fafc;
        }

        /* Ensuring cards have a solid, slightly lighter background to stand out from the body */
        .modern-stat-card, .chart-card, .product-rank-card, .table-card {
            background-color: #161b22 !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
        }

        /* --- REST OF YOUR DESIGN UNCHANGED --- */
        .content-area { max-width: 1200px; margin: 0 auto; width: 100%; gap: 2rem; }
        
        .section-label {
            font-size: 0.75rem; font-weight: 700; color: #64748b; letter-spacing: 1.5px;
            text-transform: uppercase; margin-bottom: 1rem; display: flex; align-items: center; gap: 8px;
        }
        .section-label i { color: var(--warning); font-size: 0.9rem; }

        .quick-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
        .action-btn {
            background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.08);
            padding: 0.7rem 1.2rem; border-radius: 10px; color: #e2e8f0; font-weight: 500; font-size: 0.9rem;
            text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: all 0.2s;
        }
        .action-btn:hover { background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 255, 255, 0.2); transform: translateY(-2px); }
        .action-btn i { opacity: 0.7; }

        .modern-stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; }
        .modern-stat-card {
            border-radius: 16px; padding: 1.5rem; position: relative; overflow: hidden;
            display: flex; flex-direction: column; transition: transform 0.3s ease, border-color 0.3s ease;
        }
        .modern-stat-card:hover { transform: translateY(-5px); border-color: rgba(255, 255, 255, 0.15); }
        
        .modern-stat-card.blue { border-top: 3px solid var(--primary); }
        .modern-stat-card.green { border-top: 3px solid var(--success); }
        .modern-stat-card.red { border-top: 3px solid var(--secondary); }
        .modern-stat-card.yellow { border-top: 3px solid var(--warning); }

        .m-stat-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; }
        .m-icon-box { width: 42px; height: 42px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
        .m-icon-box.blue { background: rgba(108, 99, 255, 0.15); color: var(--primary); }
        .m-icon-box.green { background: rgba(74, 222, 128, 0.15); color: var(--success); }
        .m-icon-box.red { background: rgba(255, 101, 132, 0.15); color: var(--secondary); }
        .m-icon-box.yellow { background: rgba(251, 191, 36, 0.15); color: var(--warning); }

        .m-trend { padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; display: inline-flex; align-items: center; gap: 4px; }
        .m-trend.up { background: rgba(74, 222, 128, 0.1); color: var(--success); border: 1px solid rgba(74, 222, 128, 0.2); }
        .m-trend.down { background: rgba(255, 101, 132, 0.1); color: var(--secondary); border: 1px solid rgba(255, 101, 132, 0.2); }

        .m-stat-val { font-size: 2rem; font-weight: 700; color: #fff; line-height: 1; margin-bottom: 0.4rem; }
        .m-stat-label { font-size: 0.75rem; color: #64748b; text-transform: uppercase; font-weight: 600; letter-spacing: 1px; margin-bottom: 1.5rem; }

        .sparkline-container { width: 100%; height: 40px; margin-top: auto; position: absolute; bottom: 0; left: 0; right: 0;}
        .sparkline-container svg { width: 100%; height: 100%; preserveAspectRatio: none; }

        .chart-card { border-radius: 16px; padding: 1.5rem; border-top: 3px solid #8b5cf6; }
        .chart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
        .chart-title { font-size: 1.1rem; font-weight: 600; color: #fff; }
        .chart-filters { display: flex; gap: 8px; }
        .chart-filter-btn {
            background: transparent; border: 1px solid rgba(255,255,255,0.1); color: var(--text-muted);
            padding: 4px 12px; border-radius: 6px; font-size: 0.8rem; cursor: pointer; transition: 0.2s;
        }
        .chart-filter-btn:hover, .chart-filter-btn.active { background: rgba(255,255,255,0.1); color: #fff; }
        .chart-wrapper { width: 100%; height: 250px; position: relative; }

        .top-products-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1rem; }
        .product-rank-card {
            border-radius: 12px; padding: 1.2rem; display: flex; align-items: center; gap: 1rem; transition: transform 0.2s;
        }
        .product-rank-card:hover { background: rgba(255,255,255,0.03); transform: translateX(5px); }
        .p-rank { font-size: 1.2rem; font-weight: 800; color: var(--warning); min-width: 25px; }
        .p-details { flex: 1; }
        .p-name { font-weight: 600; color: #f8fafc; font-size: 0.95rem; margin-bottom: 2px; }
        .p-orders { font-size: 0.75rem; color: var(--text-muted); }
        .p-price { font-weight: 700; color: var(--success); font-size: 1.1rem; }

        .status-dots-container { display: flex; gap: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); width: fit-content; }
        .status-pill { display: flex; align-items: center; gap: 10px; font-size: 0.9rem; color: #cbd5e1; font-weight: 500; }
        .glow-dot { width: 8px; height: 8px; border-radius: 50%; }
        .glow-dot.warning { background: var(--warning); box-shadow: 0 0 10px var(--warning); }
        .glow-dot.success { background: var(--success); box-shadow: 0 0 10px var(--success); }
    </style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <div class="top-header animate-up">
            <div class="header-left">
                <h1>{% if isAdmin|default(false) %}Admin Console{% else %}Staff Portal{% endif %}</h1>
            </div>
            <div class="header-right">
                <div class="user-info">
                    <div class="profile">
                        <div class="text-info">
                            <span class="name">{{ app.user.name|default(app.user.username|default('Admin')) }}</span>
                            <span class="role">{% if is_granted('ROLE_ADMIN') %}Administrator{% else %}Staff{% endif %}</span>
                        </div>
                        <img src="https://ui-avatars.com/api/?name={{ app.user.name|default(app.user.username|default('Admin'))|url_encode }}&background=6C63FF&color=fff" alt="User">
                    </div>
                </div>
            </div>
        </div>

        <div class="content-area">
            
            <div class="animate-up delay-1">
                <div class="section-label"><i class="fas fa-lightbulb"></i> Quick Actions Bar</div>
                <div class="quick-actions">
                    <a href="{{ path('app_product_new') }}" class="action-btn"><i class="fas fa-plus"></i> Add Product</a>
                    <a href="{{ path('app_order_index') }}" class="action-btn"><i class="fas fa-box"></i> View Orders</a>
                    {% if isAdmin|default(false) %}
                        <a href="{{ path('app_user_index') }}" class="action-btn" style="color: #c084fc;"><i class="fas fa-user-shield"></i> Manage Users</a>
                    {% endif %}
                    <a href="#" class="action-btn" style="color: #94a3b8;"><i class="fas fa-download"></i> Export Report</a>
                </div>
            </div>

            <div class="animate-up delay-2">
                <div class="section-label"><i class="fas fa-chart-pie"></i> Stat Cards — With Trend Badges & Sparklines</div>
                <div class="modern-stats-grid">
                    
                    <div class="modern-stat-card blue">
                        <div class="m-stat-header">
                            <div class="m-icon-box blue"><i class="fas fa-box-open"></i></div>
                            <div class="m-trend up"><i class="fas fa-arrow-up"></i> 12%</div>
                        </div>
                        <div class="m-stat-val">{{ totalProducts|default(0) }}</div>
                        <div class="m-stat-label">Total Products</div>
                        <div class="sparkline-container">
                            <svg viewBox="0 0 100 30" preserveAspectRatio="none">
                                <defs>
                                    <linearGradient id="grad-blue" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#6C63FF" stop-opacity="0.4"/><stop offset="100%" stop-color="#6C63FF" stop-opacity="0"/></linearGradient>
                                </defs>
                                <path d="M0,30 L0,20 L20,15 L40,22 L60,10 L80,18 L100,5 L100,30 Z" fill="url(#grad-blue)"/>
                                <polyline points="0,20 20,15 40,22 60,10 80,18 100,5" fill="none" stroke="#6C63FF" stroke-width="2"/>
                            </svg>
                        </div>
                    </div>

                    <div class="modern-stat-card green">
                        <div class="m-stat-header">
                            <div class="m-icon-box green">{% if isAdmin|default(false) %}<i class="fas fa-users"></i>{% else %}<i class="fas fa-tags"></i>{% endif %}</div>
                            <div class="m-trend up"><i class="fas fa-arrow-up"></i> 8%</div>
                        </div>
                        <div class="m-stat-val">{% if isAdmin|default(false) %}{{ totalUsers|default(0) }}{% else %}{{ totalCategories|default(0) }}{% endif %}</div>
                        <div class="m-stat-label">{% if isAdmin|default(false) %}Registered Users{% else %}Categories{% endif %}</div>
                        <div class="sparkline-container">
                            <svg viewBox="0 0 100 30" preserveAspectRatio="none">
                                <defs>
                                    <linearGradient id="grad-green" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#4ade80" stop-opacity="0.4"/><stop offset="100%" stop-color="#4ade80" stop-opacity="0"/></linearGradient>
                                </defs>
                                <path d="M0,30 L0,25 L30,20 L60,15 L100,5 L100,30 Z" fill="url(#grad-green)"/>
                                <polyline points="0,25 30,20 60,15 100,5" fill="none" stroke="#4ade80" stroke-width="2"/>
                            </svg>
                        </div>
                    </div>

                    <div class="modern-stat-card red">
                        <div class="m-stat-header">
                            <div class="m-icon-box red"><i class="fas fa-shopping-cart"></i></div>
                            <div class="m-trend down"><i class="fas fa-arrow-down"></i> 3%</div>
                        </div>
                        <div class="m-stat-val">{{ totalOrders|default(0) }}</div>
                        <div class="m-stat-label">Total Orders</div>
                        <div class="sparkline-container">
                            <svg viewBox="0 0 100 30" preserveAspectRatio="none">
                                <defs>
                                    <linearGradient id="grad-red" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#ff6584" stop-opacity="0.4"/><stop offset="100%" stop-color="#ff6584" stop-opacity="0"/></linearGradient>
                                </defs>
                                <path d="M0,30 L0,5 L20,15 L40,8 L60,25 L80,18 L100,28 L100,30 Z" fill="url(#grad-red)"/>
                                <polyline points="0,5 20,15 40,8 60,25 80,18 100,28" fill="none" stroke="#ff6584" stroke-width="2"/>
                            </svg>
                        </div>
                    </div>

                    <div class="modern-stat-card yellow">
                        <div class="m-stat-header">
                            <div class="m-icon-box yellow"><i class="fas fa-chart-line"></i></div>
                            <div class="m-trend up"><i class="fas fa-arrow-up"></i> 21%</div>
                        </div>
                        <div class="m-stat-val">₱{{ recentSales|default(0)|number_format(0, '.', ',') }}</div>
                        <div class="m-stat-label">Recent Sales</div>
                        <div class="sparkline-container">
                            <svg viewBox="0 0 100 30" preserveAspectRatio="none">
                                <defs>
                                    <linearGradient id="grad-yellow" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#fbbf24" stop-opacity="0.4"/><stop offset="100%" stop-color="#fbbf24" stop-opacity="0"/></linearGradient>
                                </defs>
                                <path d="M0,30 L0,22 L25,18 L50,20 L75,10 L100,5 L100,30 Z" fill="url(#grad-yellow)"/>
                                <polyline points="0,22 25,18 50,20 75,10 100,5" fill="none" stroke="#fbbf24" stroke-width="2"/>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>

            <div class="animate-up delay-3">
                <div class="section-label"><i class="fas fa-chart-area"></i> Revenue Chart (Drop-in)</div>
                <div class="chart-card">
                    <div class="chart-header">
                        <div class="chart-title">Revenue Overview</div>
                        <div class="chart-filters">
                            <button class="chart-filter-btn">7D</button>
                            <button class="chart-filter-btn active">30D</button>
                            <button class="chart-filter-btn">90D</button>
                        </div>
                    </div>
                    <div class="chart-wrapper">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="animate-up delay-4">
                <div class="section-label"><i class="fas fa-trophy"></i> Top Products & Status</div>
                
                <div class="top-products-grid" style="margin-bottom: 2rem;">
                    <div class="product-rank-card">
                        <div class="p-rank">#1</div>
                        <div class="p-details">
                            <div class="p-name">Shimano Deore XT</div>
                            <div class="p-orders">142 orders</div>
                        </div>
                        <div class="p-price">₱28,400</div>
                    </div>
                    <div class="product-rank-card">
                        <div class="p-rank" style="color: #94a3b8;">#2</div>
                        <div class="p-details">
                            <div class="p-name">Fox 36 Fork 29"</div>
                            <div class="p-orders">98 orders</div>
                        </div>
                        <div class="p-price">₱21,700</div>
                    </div>
                    <div class="product-rank-card">
                        <div class="p-rank" style="color: #b45309;">#3</div>
                        <div class="p-details">
                            <div class="p-name">SRAM Eagle GX</div>
                            <div class="p-orders">87 orders</div>
                        </div>
                        <div class="p-price">₱19,200</div>
                    </div>
                    <div class="product-rank-card">
                        <div class="p-rank" style="color: #475569;">#4</div>
                        <div class="p-details">
                            <div class="p-name">Maxxis Minion DHF</div>
                            <div class="p-orders">73 orders</div>
                        </div>
                        <div class="p-price">₱12,800</div>
                    </div>
                </div>

                <div class="section-label"><i class="fas fa-circle"></i> Glowing Status Dots</div>
                <div class="status-dots-container">
                    <div class="status-pill">
                        <span class="glow-dot warning"></span> Pending — 24
                    </div>
                    <div class="status-pill">
                        <span class="glow-dot success"></span> Completed — 118
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('revenueChart').getContext('2d');
            let gradient = ctx.createLinearGradient(0, 0, 0, 250);
            gradient.addColorStop(0, 'rgba(108, 99, 255, 0.4)');
            gradient.addColorStop(1, 'rgba(108, 99, 255, 0.0)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Revenue',
                        data: [12000, 19500, 15000, 21800, 17200, 28500, 23800],
                        borderColor: '#6C63FF',
                        backgroundColor: gradient,
                        borderWidth: 3,
                        pointBackgroundColor: '#6C63FF',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 5,
                        pointHoverRadius: 7,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(11, 17, 32, 0.9)',
                            displayColors: false,
                        }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { color: '#64748b' } },
                        y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#64748b' } }
                    }
                }
            });
        });
    </script>
{% endblock %}