{# templates/dashboard/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Dashboard | GearGrid{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --primary: #6C63FF;
            --primary-hover: #5b54d6;
            --secondary: #ff6584;
            --success: #4ade80;
            --bg-base: #0B1120;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --glass-bg: rgba(255, 255, 255, 0.02);
            --glass-bg-hover: rgba(255, 255, 255, 0.04);
            --glass-border: rgba(255, 255, 255, 0.06);
            --glass-border-hover: rgba(255, 255, 255, 0.12);
        }

        body {
            background-color: var(--bg-base);
            color: var(--text-main);
        }

        .dashboard {
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            flex: 1;
            margin-left: 16rem;
            padding: 2rem 3rem;
            background: var(--bg-base);
        }

        .content-area {
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Stat Cards */
        .stat-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 1.5rem;
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            background: var(--glass-bg-hover);
            border-color: var(--glass-border-hover);
            transform: translateY(-5px);
        }

        .icon-box {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
        }

        .icon-box.blue {
            background: rgba(108, 99, 255, 0.15);
            color: var(--primary);
        }

        .icon-box.green {
            background: rgba(74, 222, 128, 0.15);
            color: var(--success);
        }

        .icon-box.red {
            background: rgba(255, 101, 132, 0.15);
            color: var(--secondary);
        }

        .icon-box.purple {
            background: rgba(168, 85, 247, 0.15);
            color: #a855f7;
        }

        .trend {
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .trend.up {
            background: rgba(74, 222, 128, 0.1);
            color: var(--success);
            border: 1px solid rgba(74, 222, 128, 0.2);
        }

        .trend.down {
            background: rgba(255, 101, 132, 0.1);
            color: var(--secondary);
            border: 1px solid rgba(255, 101, 132, 0.2);
        }

        .trend.neutral {
            background: rgba(168, 85, 247, 0.1);
            color: #a855f7;
            border: 1px solid rgba(168, 85, 247, 0.2);
        }

        /* Charts Section */
        .chart-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 1.5rem;
        }

        .chart-wrapper {
            width: 100%;
            height: 300px;
            position: relative;
        }

        /* Invoice Table */
        .table-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 1.5rem;
        }

        .invoice-table {
            width: 100%;
            border-collapse: collapse;
        }

        .invoice-table th {
            text-align: left;
            padding: 1rem;
            color: var(--text-muted);
            font-size: 0.8rem;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--glass-border);
        }

        .invoice-table td {
            padding: 1rem;
            color: #fff;
            font-size: 0.9rem;
            border-bottom: 1px solid var(--glass-border);
        }

        .invoice-table tr:hover td {
            background: var(--glass-bg-hover);
        }

        .status-badge {
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .status-badge.paid {
            background: rgba(74, 222, 128, 0.15);
            color: var(--success);
            border: 1px solid rgba(74, 222, 128, 0.2);
        }

        .status-badge.pending {
            background: rgba(251, 191, 36, 0.15);
            color: #fbbf24;
            border: 1px solid rgba(251, 191, 36, 0.2);
        }

        .status-badge.overdue {
            background: rgba(255, 101, 132, 0.15);
            color: var(--secondary);
            border: 1px solid rgba(255, 101, 132, 0.2);
        }

        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
                padding: 1rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <!-- Top Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 pb-6 border-b border-gray-800">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">Welcome Back, {{ app.user.name|default(app.user.username|default('Admin')) }} 👋</h1>
                <p class="text-gray-400 text-sm">Here's what's happening with your store today.</p>
            </div>
            <div class="mt-4 md:mt-0 flex items-center gap-4">
                <div class="relative">
                    <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <input type="text" placeholder="Search Anything..." class="pl-10 pr-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 w-64">
                </div>
                <div>
                    {% include 'partials/_user_dropdown.html.twig' %}
                </div>
            </div>
        </div>

        <div class="content-area">
            <!-- Stat Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="stat-card">
                    <div class="flex justify-between items-start mb-4">
                        <div class="icon-box blue"><i class="fas fa-users"></i></div>
                        <div class="trend up"><i class="fas fa-arrow-up"></i> +6.5%</div>
                    </div>
                    <div class="text-3xl font-bold text-white mb-1">{{ totalUsers|default(1456) }}</div>
                    <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Customers</div>
                    <div class="text-xs text-gray-500">Since last week</div>
                </div>

                <div class="stat-card">
                    <div class="flex justify-between items-start mb-4">
                        <div class="icon-box green"><i class="fas fa-dollar-sign"></i></div>
                        <div class="trend down"><i class="fas fa-arrow-down"></i> -0.10%</div>
                    </div>
                    <div class="text-3xl font-bold text-white mb-1">${{ recentSales|default(3345) }}</div>
                    <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Revenue</div>
                    <div class="text-xs text-gray-500">Since last week</div>
                </div>

                <div class="stat-card">
                    <div class="flex justify-between items-start mb-4">
                        <div class="icon-box red"><i class="fas fa-chart-line"></i></div>
                        <div class="trend down"><i class="fas fa-arrow-down"></i> -0.2%</div>
                    </div>
                    <div class="text-3xl font-bold text-white mb-1">60%</div>
                    <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Profit</div>
                    <div class="text-xs text-gray-500">Since last week</div>
                </div>

                <div class="stat-card">
                    <div class="flex justify-between items-start mb-4">
                        <div class="icon-box purple"><i class="fas fa-file-invoice"></i></div>
                        <div class="trend neutral"><i class="fas fa-arrow-up"></i> +11.5%</div>
                    </div>
                    <div class="text-3xl font-bold text-white mb-1">{{ totalOrders|default(1135) }}</div>
                    <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Invoices</div>
                    <div class="text-xs text-gray-500">Since last week</div>
                </div>
            </div>

            <!-- Charts Row -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                <!-- Invoice Statistics Donut Chart -->
                <div class="chart-card">
                    <h3 class="text-lg font-semibold text-white mb-6">Invoice Statistics</h3>
                    <div class="chart-wrapper">
                        <canvas id="invoiceDonutChart"></canvas>
                    </div>
                </div>

                <!-- Sales Analytics Line Chart -->
                <div class="chart-card">
                    <h3 class="text-lg font-semibold text-white mb-6">Sales Analytics</h3>
                    <div class="chart-wrapper">
                        <canvas id="salesLineChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Recent Invoices Table -->
            <div class="table-card">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-lg font-semibold text-white">Recent Invoices</h3>
                    <button class="px-4 py-2 rounded-lg bg-gray-800/50 border border-gray-700 text-white hover:bg-gray-700/50 hover:border-gray-600 transition-colors">
                        <i class="fas fa-filter mr-2"></i> Filter
                    </button>
                </div>
                <table class="invoice-table">
                    <thead>
                        <tr>
                            <th>No</th>
                            <th>Id Customers</th>
                            <th>Customers name</th>
                            <th>Items Name</th>
                            <th>Order Date</th>
                            <th>Status</th>
                            <th>Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if recentOrders is defined and recentOrders|length > 0 %}
                            {% for order in recentOrders %}
                                <tr>
                                    <td>#{{ '%06d'|format(order.id) }}</td>
                                    <td>C{{ '%03d'|format(order.id) }}</td>
                                    <td>{{ order.customerName|default('Unknown') }}</td>
                                    <td>
                                        {% if order.products|length > 0 %}
                                            {% for product in order.products %}
                                                {{ loop.index }}x {{ product.name }}{% if not loop.last %}, {% endif %}
                                            {% endfor %}
                                        {% else %}
                                            No items
                                        {% endif %}
                                    </td>
                                    <td>{{ order.createdAt ? order.createdAt|date('d/m/Y H:i') : 'N/A' }}</td>
                                    <td>
                                        {% set statusLower = order.status|lower %}
                                        {% set badgeClass = 'overdue' %}
                                        {% if statusLower == 'processing' %}
                                            {% set badgeClass = 'processing' %}
                                        {% elseif statusLower == 'delivered' or statusLower == 'paid' or statusLower == 'complete' or statusLower == 'completed' %}
                                            {% set badgeClass = 'paid' %}
                                        {% elseif statusLower == 'shipped' %}
                                            {% set badgeClass = 'shipped' %}
                                        {% elseif statusLower == 'cancelled' %}
                                            {% set badgeClass = 'overdue' %}
                                        {% elseif statusLower == 'pending' %}
                                            {% set badgeClass = 'pending' %}
                                        {% endif %}
                                        <span class="status-badge {{ badgeClass }}">
                                            {{ order.status|default('Unknown') }}
                                        </span>
                                    </td>
                                    <td>${{ order.totalPrice|default(0)|number_format(0) }}</td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="7" style="text-align: center; color: var(--text-muted);">No orders found</td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block scripts %}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        {% verbatim %}
        document.addEventListener('DOMContentLoaded', function() {
            // Invoice Statistics Donut Chart
            const donutCtx = document.getElementById('invoiceDonutChart').getContext('2d');
            new Chart(donutCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Total Paid', 'Total Overdue', 'Total Unpaid'],
                    datasets: [{
                        data: [234, 514, 345],
                        backgroundColor: [
                            'rgba(108, 99, 255, 0.8)',
                            'rgba(255, 101, 132, 0.8)',
                            'rgba(148, 163, 184, 0.8)'
                        ],
                        borderColor: [
                            '#6C63FF',
                            '#ff6584',
                            '#94a3b8'
                        ],
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                color: '#f8fafc',
                                padding: 20,
                                font: {
                                    size: 12
                                }
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(11, 17, 32, 0.9)',
                            titleColor: '#f8fafc',
                            bodyColor: '#94a3b8',
                            borderColor: 'rgba(255, 255, 255, 0.1)',
                            borderWidth: 1
                        }
                    }
                },
                plugins: [{
                    id: 'centerText',
                    beforeDraw: function(chart) {
                        var width = chart.width,
                            height = chart.height,
                            ctx = chart.ctx;

                        ctx.restore();
                        var fontSize = (height / 114).toFixed(2);
                        ctx.font = 'bold ' + fontSize + 'em Inter';
                        ctx.textBaseline = 'middle';
                        ctx.fillStyle = '#f8fafc';

                        var text = '1,135',
                            textX = Math.round((width - ctx.measureText(text).width) / 2),
                            textY = height / 2 - 10;

                        ctx.fillText(text, textX, textY);
                        
                        ctx.font = 'normal ' + (fontSize * 0.4).toFixed(2) + 'em Inter';
                        ctx.fillStyle = '#94a3b8';
                        var subtext = 'Invoices',
                            subtextX = Math.round((width - ctx.measureText(subtext).width) / 2),
                            subtextY = height / 2 + 15;
                        
                        ctx.fillText(subtext, subtextX, subtextY);
                        ctx.save();
                    }
                }]
            });

            // Sales Analytics Line Chart
            const lineCtx = document.getElementById('salesLineChart').getContext('2d');
            let gradient = lineCtx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, 'rgba(108, 99, 255, 0.4)');
            gradient.addColorStop(1, 'rgba(108, 99, 255, 0.0)');

            new Chart(lineCtx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                    datasets: [{
                        label: 'Sales',
                        data: [800, 950, 1100, 1134, 1050, 1300, 1450, 1380, 1500, 1650, 1800, 1950],
                        borderColor: '#6C63FF',
                        backgroundColor: gradient,
                        borderWidth: 3,
                        pointBackgroundColor: '#6C63FF',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(11, 17, 32, 0.9)',
                            titleColor: '#f8fafc',
                            bodyColor: '#94a3b8',
                            borderColor: 'rgba(255, 255, 255, 0.1)',
                            borderWidth: 1,
                            displayColors: false,
                            callbacks: {
                                label: function(context) {
                                    return '$' + context.parsed.y;
                                }
                            }
                        }
                    },
                    scales: {
                        x: { 
                            grid: { display: false }, 
                            ticks: { color: '#94a3b8', font: { size: 11 } } 
                        },
                        y: { 
                            grid: { color: 'rgba(255,255,255,0.05)' }, 
                            ticks: { 
                                color: '#94a3b8',
                                callback: function(value) {
                                    return '$' + value;
                                }
                            } 
                        }
                    }
                }
            });
        });
        {% endverbatim %}
    </script>
{% endblock %}