{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content %}
<div class="dashboard-container">
    <!-- Header Section -->
    <div class="dashboard-header">
        <div class="header-content">
            <div class="welcome-section">
                <h1 class="welcome-title">
                    <span class="greeting">Welcome back,</span>
                    <span class="username">{{ app.user.name ?? 'Admin' }}</span>
                </h1>
                <p class="welcome-subtitle">Here's what's happening with your store today</p>
            </div>
            <div class="header-actions">
                <button class="action-btn primary" onclick="refreshDashboard()">
                    <i class="fas fa-sync-alt"></i>
                    <span>Refresh</span>
                </button>
                <div class="date-display">
                    <i class="fas fa-calendar-alt"></i>
                    <span>{{ "now"|date("F j, Y") }}</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <!-- Products Card -->
        <div class="stat-card products-card">
            <div class="stat-icon-wrapper">
                <div class="stat-icon products-icon">
                    <i class="fas fa-box"></i>
                </div>
            </div>
            <div class="stat-content">
                <div class="stat-header">
                    <h3 class="stat-title">Total Products</h3>
                    <div class="stat-trend positive">
                        <i class="fas fa-arrow-up"></i>
                        <span>12%</span>
                    </div>
                </div>
                <div class="stat-value">
                    <span class="value">{{ total_products ?? 0 }}</span>
                    <span class="label">Products</span>
                </div>
                <div class="stat-progress">
                    <div class="progress-bar">
                        <div class="progress-fill products-progress" style="width: 75%"></div>
                    </div>
                    <span class="progress-text">75% of goal</span>
                </div>
            </div>
        </div>

        <!-- Categories Card -->
        <div class="stat-card categories-card">
            <div class="stat-icon-wrapper">
                <div class="stat-icon categories-icon">
                    <i class="fas fa-tags"></i>
                </div>
            </div>
            <div class="stat-content">
                <div class="stat-header">
                    <h3 class="stat-title">Categories</h3>
                    <div class="stat-trend positive">
                        <i class="fas fa-arrow-up"></i>
                        <span>8%</span>
                    </div>
                </div>
                <div class="stat-value">
                    <span class="value">{{ total_categories ?? 0 }}</span>
                    <span class="label">Categories</span>
                </div>
                <div class="stat-progress">
                    <div class="progress-bar">
                        <div class="progress-fill categories-progress" style="width: 60%"></div>
                    </div>
                    <span class="progress-text">60% organized</span>
                </div>
            </div>
        </div>

        <!-- Orders Card -->
        <div class="stat-card orders-card">
            <div class="stat-icon-wrapper">
                <div class="stat-icon orders-icon">
                    <i class="fas fa-shopping-cart"></i>
                </div>
            </div>
            <div class="stat-content">
                <div class="stat-header">
                    <h3 class="stat-title">Total Orders</h3>
                    <div class="stat-trend positive">
                        <i class="fas fa-arrow-up"></i>
                        <span>24%</span>
                    </div>
                </div>
                <div class="stat-value">
                    <span class="value">{{ total_orders ?? 0 }}</span>
                    <span class="label">Orders</span>
                </div>
                <div class="stat-progress">
                    <div class="progress-bar">
                        <div class="progress-fill orders-progress" style="width: 85%"></div>
                    </div>
                    <span class="progress-text">85% target</span>
                </div>
            </div>
        </div>

        <!-- Users Card -->
        <div class="stat-card users-card">
            <div class="stat-icon-wrapper">
                <div class="stat-icon users-icon">
                    <i class="fas fa-users"></i>
                </div>
            </div>
            <div class="stat-content">
                <div class="stat-header">
                    <h3 class="stat-title">Total Users</h3>
                    <div class="stat-trend neutral">
                        <i class="fas fa-minus"></i>
                        <span>0%</span>
                    </div>
                </div>
                <div class="stat-value">
                    <span class="value">{{ total_users ?? 0 }}</span>
                    <span class="label">Users</span>
                </div>
                <div class="stat-progress">
                    <div class="progress-bar">
                        <div class="progress-fill users-progress" style="width: 50%"></div>
                    </div>
                    <span class="progress-text">Steady growth</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="main-content-grid">
        <!-- Recent Products -->
        <div class="content-card recent-products">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="fas fa-box"></i>
                    Recent Products
                </h2>
                <div class="card-actions">
                    <a href="{{ path('app_product_index') }}" class="view-all-btn">
                        View All
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="card-content">
                {% if recent_products|length > 0 %}
                    <div class="product-list">
                        {% for product in recent_products|slice(0, 5) %}
                            <div class="product-item">
                                <div class="product-image">
                                    {% if product.image %}
                                        <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}">
                                    {% else %}
                                        <div class="placeholder-image">
                                            <i class="fas fa-box"></i>
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="product-info">
                                    <h4 class="product-name">{{ product.name }}</h4>
                                    <div class="product-meta">
                                        <span class="product-price">${{ product.price|number_format(2) }}</span>
                                        <span class="product-quantity">{{ product.quantity }} in stock</span>
                                    </div>
                                    <div class="product-footer">
                                        <span class="product-author">
                                            <i class="fas fa-user"></i>
                                            {{ product.createdBy.name ?? 'Unknown' }}
                                        </span>
                                        <span class="product-date">
                                            <i class="fas fa-clock"></i>
                                            {{ product.createdAt|date('M j') }}
                                        </span>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="empty-state">
                        <i class="fas fa-box-open"></i>
                        <h3>No products yet</h3>
                        <p>Start by adding your first product to the inventory</p>
                        <a href="{{ path('app_product_new') }}" class="add-btn">
                            <i class="fas fa-plus"></i>
                            Add Product
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="content-card quick-actions">
            <div class="card-header">
                <h2 class="card-title">
                    <i class="fas fa-bolt"></i>
                    Quick Actions
                </h2>
            </div>
            <div class="card-content">
                <div class="action-grid">
                    <a href="{{ path('app_product_new') }}" class="action-card">
                        <div class="action-icon">
                            <i class="fas fa-plus-circle"></i>
                        </div>
                        <h3>Add Product</h3>
                        <p>Create new product</p>
                    </a>
                    
                    <a href="{{ path('app_category_new') }}" class="action-card">
                        <div class="action-icon">
                            <i class="fas fa-folder-plus"></i>
                        </div>
                        <h3>Add Category</h3>
                        <p>Organize products</p>
                    </a>
                    
                    <a href="{{ path('app_order_index') }}" class="action-card">
                        <div class="action-icon">
                            <i class="fas fa-receipt"></i>
                        </div>
                        <h3>View Orders</h3>
                        <p>Manage orders</p>
                    </a>
                    
                    <a href="{{ path('app_log_index') }}" class="action-card">
                        <div class="action-icon">
                            <i class="fas fa-history"></i>
                        </div>
                        <h3>View Logs</h3>
                        <p>System activity</p>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Activity Timeline -->
    <div class="content-card activity-timeline">
        <div class="card-header">
            <h2 class="card-title">
                <i class="fas fa-chart-line"></i>
                Recent Activity
            </h2>
            <div class="card-actions">
                <a href="{{ path('app_log_index') }}" class="view-all-btn">
                    View All
                    <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
        <div class="card-content">
            {% if recent_products|length > 0 %}
                <div class="timeline">
                    {% for product in recent_products|slice(0, 3) %}
                        <div class="timeline-item">
                            <div class="timeline-icon">
                                <i class="fas fa-box"></i>
                            </div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <h4>New Product Added</h4>
                                    <span class="timeline-time">{{ product.createdAt|date('H:i') }}</span>
                                </div>
                                <p class="timeline-description">
                                    <strong>{{ product.createdBy.name ?? 'Unknown' }}</strong> added 
                                    <strong>{{ product.name }}</strong> to inventory
                                </p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="empty-state">
                    <i class="fas fa-clock"></i>
                    <h3>No recent activity</h3>
                    <p>Start adding products to see activity here</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<!-- Custom Styles -->
<style>
/* ===== DASHBOARD CONTAINER ===== */
.dashboard-container {
    min-height: 100vh;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 2rem;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

/* ===== HEADER SECTION ===== */
.dashboard-header {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    padding: 2rem;
    margin-bottom: 2rem;
    animation: slideDown 0.6s ease-out;
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
}

.welcome-section h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem 0;
}

.greeting {
    color: rgba(255, 255, 255, 0.8);
    font-weight: 400;
}

.username {
    color: #fff;
    display: block;
    font-size: 2.2rem;
}

.welcome-subtitle {
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    font-size: 1rem;
}

.header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.action-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 12px;
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    cursor: pointer;
}

.action-btn:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
}

.date-display {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 500;
}

/* ===== STATS GRID ===== */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.stat-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    animation: fadeInUp 0.6s ease-out;
    transition: all 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #667eea, #764ba2);
    border-radius: 20px 20px 0 0;
}

.stat-icon-wrapper {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
}

.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: #fff;
    backdrop-filter: blur(10px);
}

.products-icon { background: linear-gradient(135deg, #667eea, #764ba2); }
.categories-icon { background: linear-gradient(135deg, #f093fb, #f5576c); }
.orders-icon { background: linear-gradient(135deg, #4facfe, #00f2fe); }
.users-icon { background: linear-gradient(135deg, #43e97b, #38f9d7); }

.stat-content {
    padding-right: 5rem;
}

.stat-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
}

.stat-title {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    opacity: 0.8;
}

.stat-trend {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
}

.stat-trend.positive {
    background: rgba(67, 233, 123, 0.2);
    color: #43e97b;
}

.stat-trend.neutral {
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.7);
}

.stat-value {
    margin-bottom: 1rem;
}

.stat-value .value {
    display: block;
    font-size: 2.5rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
}

.stat-value .label {
    display: block;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 0.25rem;
}

.stat-progress {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.progress-bar {
    flex: 1;
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 1s ease-out;
}

.products-progress { background: linear-gradient(90deg, #667eea, #764ba2); }
.categories-progress { background: linear-gradient(90deg, #f093fb, #f5576c); }
.orders-progress { background: linear-gradient(90deg, #4facfe, #00f2fe); }
.users-progress { background: linear-gradient(90deg, #43e97b, #38f9d7); }

.progress-text {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 600;
}

/* ===== MAIN CONTENT GRID ===== */
.main-content-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

/* ===== CONTENT CARDS ===== */
.content-card {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    overflow: hidden;
    animation: fadeInUp 0.8s ease-out;
}

.card-header {
    padding: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.card-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #fff;
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0;
}

.card-title i {
    color: #667eea;
}

.card-actions {
    display: flex;
    gap: 0.5rem;
}

.view-all-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #667eea;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
}

.view-all-btn:hover {
    color: #764ba2;
    transform: translateX(3px);
}

.card-content {
    padding: 1.5rem;
}

/* ===== RECENT PRODUCTS ===== */
.product-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.product-item {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    transition: all 0.3s ease;
}

.product-item:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateX(5px);
}

.product-image {
    width: 60px;
    height: 60px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
}

.product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.placeholder-image {
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    border-radius: 8px;
}

.product-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.product-name {
    color: #fff;
    font-weight: 600;
    margin: 0;
}

.product-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
}

.product-price {
    color: #43e97b;
    font-weight: 700;
}

.product-quantity {
    color: rgba(255, 255, 255, 0.7);
}

.product-footer {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
}

.product-author, .product-date {
    display: flex;
    align-items: center;
    gap: 0.25rem;
}

/* ===== QUICK ACTIONS ===== */
.action-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}

.action-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    text-decoration: none;
    color: #fff;
    transition: all 0.3s ease;
}

.action-card:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
}

.action-icon {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.2rem;
    margin-bottom: 1rem;
}

.action-card h3 {
    color: #fff;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
}

.action-card p {
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    font-size: 0.9rem;
}

/* ===== ACTIVITY TIMELINE ===== */
.timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.timeline-item {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    transition: all 0.3s ease;
}

.timeline-item:hover {
    background: rgba(255, 255, 255, 0.1);
}

.timeline-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    flex-shrink: 0;
}

.timeline-content {
    flex: 1;
}

.timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
}

.timeline-header h4 {
    color: #fff;
    font-weight: 600;
    margin: 0;
}

.timeline-time {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.8rem;
}

.timeline-description {
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    line-height: 1.5;
}

.timeline-description strong {
    color: #667eea;
}

/* ===== EMPTY STATES ===== */
.empty-state {
    text-align: center;
    padding: 3rem;
    color: rgba(255, 255, 255, 0.7);
}

.empty-state i {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
}

.empty-state h3 {
    color: #fff;
    margin: 0 0 0.5rem 0;
}

.empty-state p {
    margin: 0 0 1.5rem 0;
}

.add-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: #fff;
    text-decoration: none;
    border-radius: 12px;
    font-weight: 600;
    transition: all 0.3s ease;
}

.add-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
}

/* ===== ANIMATIONS ===== */
@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ===== RESPONSIVE DESIGN ===== */
@media (max-width: 1024px) {
    .main-content-grid {
        grid-template-columns: 1fr;
    }
    
    .stats-grid {
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }
}

@media (max-width: 768px) {
    .dashboard-container {
        padding: 1rem;
    }
    
    .header-content {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
    }
    
    .stats-grid {
        grid-template-columns: 1fr;
    }
    
    .action-grid {
        grid-template-columns: 1fr;
    }
    
    .stat-content {
        padding-right: 0;
        padding-top: 4rem;
    }
    
    .stat-icon-wrapper {
        position: static;
        margin-bottom: 1rem;
    }
}
</style>

<!-- JavaScript -->
<script>
function refreshDashboard() {
    // Add loading animation
    const btn = event.target.closest('.action-btn');
    const icon = btn.querySelector('i');
    icon.style.animation = 'spin 1s linear infinite';
    
    // Simulate refresh
    setTimeout(() => {
        icon.style.animation = '';
        window.location.reload();
    }, 1000);
}

// Add CSS animation
const style = document.createElement('style');
style.textContent = `
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
`;
document.head.appendChild(style);

// Animate progress bars on load
document.addEventListener('DOMContentLoaded', () => {
    const progressFills = document.querySelectorAll('.progress-fill');
    progressFills.forEach(fill => {
        const width = fill.style.width;
        fill.style.width = '0';
        setTimeout(() => {
            fill.style.width = width;
        }, 500);
    });
});
</script>
{% endblock %}
