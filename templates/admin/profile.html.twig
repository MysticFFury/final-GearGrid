{% extends 'base.html.twig' %}

{% block title %}Edit My Profile | GearGrid Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .dashboard {
            display: flex;
            min-height: 100vh;
        }

        .form-container {
            max-width: 700px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .form-card {
            background: linear-gradient(135deg, #131a2c 0%, #0f1624 100%);
            border-radius: 16px;
            padding: 35px 40px;
            box-shadow: 0 18px 40px rgba(0,0,0,0.45);
            border: 1px solid rgba(255,255,255,0.08);
        }

        .form-title {
            font-size: 1.8rem;
            color: #fff;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .form-subtitle {
            color: #9aa5b5;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .form-group {
            margin-bottom: 22px;
        }

        .form-group label {
            display: block;
            color: #c9d3ec;
            font-size: 13px;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .form-group input {
            width: 100%;
            padding: 12px 14px;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.05);
            color: #fff;
            font-size: 15px;
            transition: all 0.2s;
        }

        .form-group input:focus {
            outline: none;
            border-color: #17a2b8;
            box-shadow: 0 0 0 3px rgba(23, 162, 184, 0.2);
            background: rgba(255,255,255,0.08);
        }

        .form-group small {
            display: block;
            color: #9aa5b5;
            font-size: 12px;
            margin-top: 6px;
        }

        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 30px;
            padding-top: 24px;
            border-top: 1px solid rgba(255,255,255,0.08);
        }

        .btn {
            padding: 12px 24px;
            border-radius: 10px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #17a2b8, #138496);
            color: #fff;
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(23, 162, 184, 0.35);
        }

        .btn-secondary {
            background: rgba(255,255,255,0.05);
            color: #c9d3ec;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .btn-secondary:hover {
            background: rgba(255,255,255,0.08);
        }

        .alert {
            padding: 12px 16px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .alert-success {
            background: rgba(40, 167, 69, 0.15);
            border: 1px solid rgba(40, 167, 69, 0.3);
            color: #d4f8e8;
        }

        .alert-error {
            background: rgba(220, 53, 69, 0.15);
            border: 1px solid rgba(220, 53, 69, 0.3);
            color: #ffd7de;
        }
    </style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <div class="top-header">
            <h1>Edit My Profile</h1>
            <div class="user-info">
                <div class="profile">
                    <img src="https://ui-avatars.com/api/?name={{ app.user.name|default('Admin')|url_encode }}&background=17a2b8&color=fff" alt="User">
                    <span>{{ app.user.name|default('Admin') }}</span>
                </div>
            </div>
        </div>

        <div class="content-area">
            <div class="form-container">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i> {{ message }}
                    </div>
                {% endfor %}

                {% for message in app.flashes('error') %}
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-circle"></i> {{ message }}
                    </div>
                {% endfor %}

                <div class="form-card">
                    <h2 class="form-title">Change Password & Update Profile</h2>
                    <p class="form-subtitle">Update your account information and change your password</p>

                    {{ form_start(form) }}
                        <div class="form-group">
                            {{ form_label(form.name) }}
                            {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.name) }}
                        </div>

                        <div class="form-group">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.email) }}
                        </div>

                        {# Hide roles field when editing own profile #}
                        {% if form.roles is defined %}
                            <div class="form-group" style="display: none;">
                                {{ form_widget(form.roles) }}
                            </div>
                        {% endif %}

                        <div class="form-group">
                            {{ form_label(form.plainPassword) }}
                            {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Leave blank to keep current password'}}) }}
                            {{ form_errors(form.plainPassword) }}
                            <small><i class="fas fa-info-circle"></i> Leave password blank if you don't want to change it</small>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Update Profile
                            </button>
                            <a href="{{ path('app_profile') }}" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}

