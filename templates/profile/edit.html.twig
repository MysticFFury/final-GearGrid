{% extends 'base.html.twig' %}

{% block title %}Change Password | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --primary: #6C63FF;
        --primary-hover: #5b54d6;
        --secondary: #ff6584;
        --success: #4ade80;
        --bg-base: #0B1120;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --glass-bg: rgba(255, 255, 255, 0.02);
        --glass-bg-hover: rgba(255, 255, 255, 0.04);
        --glass-border: rgba(255, 255, 255, 0.06);
        --glass-border-hover: rgba(255, 255, 255, 0.12);
        --danger: #dc3545;
        --card-bg: rgba(255, 255, 255, 0.02);
    }

    .dashboard main {
        margin-left: 16rem;
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-base);
    }

    @media (max-width: 768px) {
        .dashboard main {
            margin-left: 0;
            padding: 1rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <!-- Top Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 pb-6 border-b border-gray-800">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">Change Password</h1>
                <p class="text-gray-400 text-sm">Update your password to keep your account secure</p>
            </div>
            <div class="mt-4 md:mt-0 flex items-center gap-3 bg-gray-800/50 px-4 py-2 rounded-full border border-gray-700">
                <div class="text-right">
                    <p class="text-white font-semibold text-sm">{{ app.user.name|default(app.user.username|default('Admin')) }}</p>
                    <p class="text-gray-400 text-xs">{% if is_granted('ROLE_ADMIN') %}Administrator{% else %}Staff{% endif %}</p>
                </div>
                <div class="relative">
                    <img src="https://ui-avatars.com/api/?name={{ app.user.name|default(app.user.username|default('Admin'))|url_encode }}&background=6C63FF&color=fff" alt="User" class="w-10 h-10 rounded-lg border-2 border-purple-500">
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-gray-900 rounded-full"></span>
                </div>
                <i class="fas fa-chevron-down text-gray-400 text-xs"></i>
            </div>
        </div>

        {# Flash Messages #}
        {% for message in app.flashes('success') %}
            <div class="mb-6 p-4 rounded-lg flex items-center justify-between gap-3 bg-green-500/20 text-green-400 border border-green-500/30 shadow-lg shadow-green-500/20">
                <span class="flex items-center gap-2">
                    <i class="fas fa-check-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-white cursor-pointer text-xl opacity-80 px-1">&times;</button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="mb-6 p-4 rounded-lg flex items-center justify-between gap-3 bg-red-500/20 text-red-400 border border-red-500/30 shadow-lg shadow-red-500/20">
                <span class="flex items-center gap-2">
                    <i class="fas fa-exclamation-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-white cursor-pointer text-xl opacity-80 px-1">&times;</button>
            </div>
        {% endfor %}

        <div class="max-w-3xl mx-auto">
            <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-8 border-t-4 border-t-purple-500">
                <div class="text-center mb-8">
                    <div class="w-16 h-16 rounded-xl bg-purple-600/20 flex items-center justify-center text-purple-500 text-3xl mx-auto mb-4">
                        <i class="fas fa-key"></i>
                    </div>
                    <h2 class="text-2xl font-bold text-white mb-1">Change Password</h2>
                    <p class="text-gray-400 text-sm">Enter your current password and choose a new secure password</p>
                </div>

                {{ form_start(form, { 'attr': { 'novalidate': 'novalidate', 'class': 'space-y-4' } }) }}
                    <div class="space-y-2">
                        <label class="block text-gray-400 text-xs uppercase tracking-wider font-semibold mb-2" for="{{ form.currentPassword.vars.id }}">Current Password</label>
                        {{ form_widget(form.currentPassword, {
                            'attr': {
                                'class': 'w-full px-4 py-3 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500',
                                'placeholder': 'Enter your current password',
                                'autofocus': true
                            }
                        }) }}
                        {{ form_errors(form.currentPassword) }}
                    </div>

                    <div class="space-y-2">
                        <label class="block text-gray-400 text-xs uppercase tracking-wider font-semibold mb-2" for="{{ form.newPassword.first.vars.id }}">New Password</label>
                        {{ form_widget(form.newPassword.first, {
                            'attr': {
                                'class': 'w-full px-4 py-3 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500',
                                'placeholder': 'Enter a new password'
                            }
                        }) }}
                        {{ form_errors(form.newPassword.first) }}
                        <div class="flex items-center gap-2 text-gray-400 text-xs">
                            <i class="fas fa-info-circle"></i> Password must be at least 6 characters
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="block text-gray-400 text-xs uppercase tracking-wider font-semibold mb-2" for="{{ form.newPassword.second.vars.id }}">Confirm New Password</label>
                        {{ form_widget(form.newPassword.second, {
                            'attr': {
                                'class': 'w-full px-4 py-3 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500',
                                'placeholder': 'Confirm your new password'
                            }
                        }) }}
                        {{ form_errors(form.newPassword.second) }}
                    </div>

                    {{ form_errors(form) }}

                    <div class="flex flex-wrap gap-3 pt-6 border-t border-gray-700">
                        <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-lg shadow-purple-500/20">
                            <i class="fas fa-key"></i> Update Password
                        </button>
                        <a href="{{ path('app_profile') }}" class="bg-gray-700/50 hover:bg-gray-600/50 text-gray-300 hover:text-white border border-gray-600 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Auto-dismiss flash messages after 5 seconds
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
            message.style.transition = 'opacity 0.5s';
            message.style.opacity = '0';
            setTimeout(function() {
                message.remove();
            }, 500);
        });
    }, 5000);
});
</script>
{% endblock %}
