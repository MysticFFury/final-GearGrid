{% extends 'base.html.twig' %}

{% block title %}My Profile | GearGrid{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .profile-page {
            display: flex;
            min-height: 100vh;
            justify-content: center; /* horizontally center page content */
            align-items: center;    /* vertically center page content */
        }

        .content-area {
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 60px 20px;
            min-height: calc(100vh - 200px);
        }

        .profile-shell {
            width: 100%;
            max-width: 1100px; /* Make it a little bit longer */
            display: flex;
            justify-content: center;
            margin: 0 auto;
        }

        .profile-card {
            width: 100%;
            max-width: 850px; /* Slightly longer/wider profile card */
            margin: 0 auto;   /* Center horizontally */
            background: linear-gradient(135deg, #131a2c 0%, #0f1624 100%);
            color: #e5e7eb;
            border-radius: 24px;
            padding: 60px 90px; /* More horizontal padding for width */
            box-shadow: 0 22px 48px rgba(0,0,0,0.55);
            border: 1px solid rgba(255,255,255,0.1);
            display: flex;
            flex-direction: column;
            align-items: center; /* Center all inner content */
        }

        .profile-card header {
            display: flex;
            align-items: center;
            gap: 30px;
            margin-bottom: 40px;
            flex-wrap: wrap;
            justify-content: center; /* Center header content */
        }

        .profile-card header img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            border: 3px solid #17a2b8;
            box-shadow: 0 8px 20px rgba(23, 162, 184, 0.35);
        }

        .profile-meta {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 20px;
            margin-top: 30px;
            width: 100%;
        }

        .meta-item {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 20px 24px;
            border-radius: 16px;
            min-height: 120px;
            transition: all 0.3s ease;
        }

        .meta-item:hover {
            background: rgba(255,255,255,0.04);
            border-color: rgba(255,255,255,0.1);
            transform: translateY(-2px);
        }

        .meta-label {
            color: #9aa5b5;
            font-size: 14px;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            font-weight: 600;
        }

        .meta-value {
            font-size: 20px;
            color: #fff;
            font-weight: 600;
            margin-top: 8px;
            word-break: break-word;
        }

        .role-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(23, 162, 184, 0.18);
            color: #c8f4ff;
            border: 1px solid rgba(23, 162, 184, 0.32);
            padding: 10px 16px;
            border-radius: 20px;
            font-weight: 600;
            margin: 8px 10px 0 0;
            font-size: 15px;
        }

        .profile-card h2 {
            margin: 0;
            color: #fff;
            letter-spacing: 0.3px;
            font-size: 2rem;
            font-weight: 700;
        }

        .profile-card .subtitle {
            color: #9aa5b5;
            font-size: 16px;
            margin-top: 8px;
        }

        .profile-card a {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 16px 32px;
            background: linear-gradient(135deg, #17a2b8, #138496);
            color: #fff;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 600;
            font-size: 16px;
            transition: all 0.3s ease;
            margin-top: 32px;
            box-shadow: 0 4px 15px rgba(23, 162, 184, 0.3);
        }

        .profile-card a:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(23, 162, 184, 0.5);
            filter: brightness(1.1);
        }

        @media (max-width: 1200px) {
            .profile-shell {
                max-width: 96vw;
            }
            .profile-card {
                padding: 35px 10vw;
            }
        }

        @media (max-width: 900px) {
            .profile-card {
                max-width: 100%;
                padding: 22px 6vw;
            }
            .profile-shell {
                max-width: 100vw;
            }
        }

        @media (max-width: 768px) {
            .profile-page {
                flex-direction: column;
                align-items: stretch;
                justify-content: flex-start;
            }
            .main-content {
                margin-left: 0;
            }
            .content-area {
                padding: 20px 0;
            }
            .profile-card {
                padding: 18px 4vw;
            }
            .profile-meta {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="profile-page">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content" style="width: 100%;">
        <div class="top-header profile-top-header" style="display: flex; flex-direction: column; align-items: center;">
            <h1>My Profile</h1>
            <div class="user-info">
                <div class="profile" style="display: flex; align-items: center; gap: 10px;">
                    <img src="https://ui-avatars.com/api/?name={{ user.name|default(user.email)|url_encode }}&background=17a2b8&color=fff" alt="User avatar">
                    <span>{{ user.name|default('User') }}</span>
                </div>
            </div>
        </div>

        <div class="content-area">
            <div class="profile-shell">
                <div class="profile-card">
                
                    <header>
                        <img src="https://ui-avatars.com/api/?name={{ user.name|default(user.email)|url_encode }}&background=17a2b8&color=fff" alt="User avatar">
                        <div>
                            <h2>{{ user.name|default('User') }}</h2>
                            <div class="subtitle">{{ user.email|default('—') }}</div>
                            {% set primaryRole = user.roles|first %}
                            <div class="role-badge">
                                <i class="fas fa-id-badge"></i>
                                {{ primaryRole ? primaryRole|replace({'ROLE_':''})|capitalize : 'User' }}
                            </div>
                        </div>
                    </header>

                    <div class="profile-meta">
                        <div class="meta-item">
                            <div class="meta-label">Name</div>
                            <div class="meta-value">{{ user.name|default('—') }}</div>
                        </div>
                        <div class="meta-item">
                            <div class="meta-label">Email</div>
                            <div class="meta-value">{{ user.email|default('—') }}</div>
                        </div>
                        <div class="meta-item">
                            <div class="meta-label">Roles</div>
                            <div class="meta-value">
                                {% for role in user.roles %}
                                    <span class="role-badge">{{ role|replace({'ROLE_':''})|capitalize }}</span>
                                {% else %}
                                    <span class="role-badge">User</span>
                                {% endfor %}
                            </div>
                        </div>
                        <div class="meta-item">
                            <div class="meta-label">Status</div>
                            <div class="meta-value">
                                {% if user.isActive ?? true %}
                                    <span class="role-badge" style="background: rgba(40,167,69,0.2); border-color: rgba(40,167,69,0.4); color: #d4f8e8;">Active</span>
                                {% else %}
                                    <span class="role-badge" style="background: rgba(220,53,69,0.2); border-color: rgba(220,53,69,0.4); color: #ffd7de;">Inactive</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    
                    <div style="text-align: center; margin-top: 40px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.08); width: 100%;">
                        <a href="{{ path('app_profile_edit') }}">
                            <i class="fas fa-key"></i> Change Password
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}
