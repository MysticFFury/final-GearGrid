{% extends 'base.html.twig' %}

{% block title %}My Profile | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --primary: #6C63FF;
        --primary-hover: #5b54d6;
        --secondary: #ff6584;
        --success: #4ade80;
        --bg-base: #0B1120;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --glass-bg: rgba(255, 255, 255, 0.02);
        --glass-bg-hover: rgba(255, 255, 255, 0.04);
        --glass-border: rgba(255, 255, 255, 0.06);
        --glass-border-hover: rgba(255, 255, 255, 0.12);
        --danger: #dc3545;
        --card-bg: rgba(255, 255, 255, 0.02);
    }

    .dashboard main {
        margin-left: 16rem;
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-base);
    }

    @media (max-width: 768px) {
        .dashboard main {
            margin-left: 0;
            padding: 1rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <!-- Top Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 pb-6 border-b border-gray-800">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">My Profile</h1>
                <p class="text-gray-400 text-sm">Manage your account settings and preferences</p>
            </div>
            <div class="mt-4 md:mt-0">
                {% include 'partials/_user_dropdown.html.twig' %}
            </div>
        </div>

        {# Flash Messages #}
        {% for message in app.flashes('success') %}
            <div class="mb-6 p-4 rounded-lg flex items-center justify-between gap-3 bg-green-500/20 text-green-400 border border-green-500/30 shadow-lg shadow-green-500/20">
                <span class="flex items-center gap-2">
                    <i class="fas fa-check-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-white cursor-pointer text-xl opacity-80 px-1">&times;</button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="mb-6 p-4 rounded-lg flex items-center justify-between gap-3 bg-red-500/20 text-red-400 border border-red-500/30 shadow-lg shadow-red-500/20">
                <span class="flex items-center gap-2">
                    <i class="fas fa-exclamation-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-white cursor-pointer text-xl opacity-80 px-1">&times;</button>
            </div>
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Profile Card -->
            <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-8 border-t-4 border-t-purple-500 text-center">
                <div class="relative w-32 h-32 mx-auto mb-6">
                    <img src="https://ui-avatars.com/api/?name={{ user.name|default(user.email)|url_encode }}&background=6C63FF&color=fff&size=280" 
                         alt="{{ user.name|default('User') }}" class="w-full h-full rounded-full border-4 border-purple-500 object-cover">
                    <span class="absolute bottom-2 right-2 w-6 h-6 bg-green-500 border-4 border-gray-800 rounded-full"></span>
                </div>
                
                <h2 class="text-2xl font-bold text-white mb-1">{{ user.name|default('User') }}</h2>
                <p class="text-gray-400 text-sm mb-6">{{ user.email|default('—') }}</p>
                
                <div class="mb-6">
                    {% for role in user.roles %}
                        <span class="inline-flex items-center gap-2 px-3 py-1 bg-purple-600/20 text-purple-400 border border-purple-600/30 rounded-lg text-sm font-medium">
                            <i class="fas fa-shield-alt"></i>
                            {{ role|replace({'ROLE_':''})|capitalize }}
                        </span>
                    {% else %}
                        <span class="inline-flex items-center gap-2 px-3 py-1 bg-purple-600/20 text-purple-400 border border-purple-600/30 rounded-lg text-sm font-medium">
                            <i class="fas fa-shield-alt"></i>
                            User
                        </span>
                    {% endfor %}
                </div>

                <div class="grid grid-cols-3 gap-2 pt-6 border-t border-gray-700">
                    <div class="text-center">
                        <div class="text-2xl font-bold text-white">100%</div>
                        <div class="text-xs text-gray-400 uppercase tracking-wider mt-1">Profile</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-bold text-white">{{ user.roles|length }}</div>
                        <div class="text-xs text-gray-400 uppercase tracking-wider mt-1">Roles</div>
                    </div>
                    <div class="text-center">
                        <div class="text-2xl font-bold text-white">Active</div>
                        <div class="text-xs text-gray-400 uppercase tracking-wider mt-1">Status</div>
                    </div>
                </div>
            </div>

            <!-- Main Info Card -->
            <div class="lg:col-span-2">
                <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-8 border-t-4 border-t-purple-500">
                    <div class="flex justify-between items-center mb-8">
                        <h2 class="text-xl font-semibold text-white flex items-center gap-3"><i class="fas fa-user-circle text-purple-500"></i> Account Information</h2>
                        <a href="{{ path('app_profile_edit') }}" class="bg-gray-700/50 hover:bg-gray-600/50 text-gray-300 hover:text-white border border-gray-600 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                        <div class="bg-gray-800/50 border border-gray-700 rounded-lg p-5 transition-colors hover:bg-gray-800 hover:border-purple-500">
                            <div class="text-gray-400 text-xs uppercase tracking-wider font-semibold mb-2">Full Name</div>
                            <div class="text-white font-medium">{{ user.name|default('—') }}</div>
                        </div>

                        <div class="bg-gray-800/50 border border-gray-700 rounded-lg p-5 transition-colors hover:bg-gray-800 hover:border-purple-500">
                            <div class="text-gray-400 text-xs uppercase tracking-wider font-semibold mb-2">Email Address</div>
                            <div class="text-white font-medium flex items-center gap-2">
                                <i class="fas fa-envelope text-purple-500"></i> {{ user.email|default('—') }}
                            </div>
                        </div>

                        <div class="bg-gray-800/50 border border-gray-700 rounded-lg p-5 transition-colors hover:bg-gray-800 hover:border-purple-500">
                            <div class="text-gray-400 text-xs uppercase tracking-wider font-semibold mb-2">User Roles</div>
                            <div class="text-white font-medium">
                                {% for role in user.roles %}
                                    <span class="px-2 py-1 bg-purple-600/20 text-purple-400 border border-purple-600/30 rounded text-xs font-medium">{{ role|replace({'ROLE_':''})|capitalize }}</span>
                                {% else %}
                                    <span class="px-2 py-1 bg-purple-600/20 text-purple-400 border border-purple-600/30 rounded text-xs font-medium">User</span>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="bg-gray-800/50 border border-gray-700 rounded-lg p-5 transition-colors hover:bg-gray-800 hover:border-purple-500">
                            <div class="text-gray-400 text-xs uppercase tracking-wider font-semibold mb-2">Account Status</div>
                            <div class="text-white font-medium">
                                {% if user.isActive ?? true %}
                                    <span class="text-green-400 flex items-center gap-2"><i class="fas fa-check-circle"></i> Active</span>
                                {% else %}
                                    <span class="text-red-400 flex items-center gap-2"><i class="fas fa-times-circle"></i> Inactive</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-wrap gap-3">
                        <a href="{{ path('app_profile_edit') }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-lg shadow-purple-500/20">
                            <i class="fas fa-key"></i> Change Password
                        </a>
                        <a href="{{ path('app_dashboard') }}" class="bg-gray-700/50 hover:bg-gray-600/50 text-gray-300 hover:text-white border border-gray-600 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                            <i class="fas fa-arrow-left"></i> Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Security Settings -->
        <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-8 border-t-4 border-t-purple-500 mt-6">
            <h2 class="text-xl font-semibold text-white mb-8 flex items-center gap-3"><i class="fas fa-shield-alt text-purple-500"></i> Security Settings</h2>

            <div class="flex items-center justify-between py-4 border-b border-gray-700">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-lg bg-purple-600/20 flex items-center justify-center text-purple-500">
                        <i class="fas fa-lock"></i>
                    </div>
                    <div>
                        <h4 class="text-white font-semibold text-sm">Password</h4>
                        <p class="text-gray-400 text-xs">Last changed recently</p>
                    </div>
                </div>
                <div class="flex items-center gap-2 px-3 py-1 bg-green-500/20 text-green-400 rounded-full text-xs font-semibold">
                    <i class="fas fa-check"></i> Secure
                </div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-gray-700">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-lg bg-purple-600/20 flex items-center justify-center text-purple-500">
                        <i class="fas fa-user-shield"></i>
                    </div>
                    <div>
                        <h4 class="text-white font-semibold text-sm">Two-Factor Authentication</h4>
                        <p class="text-gray-400 text-xs">Add an extra layer of security</p>
                    </div>
                </div>
                <div class="flex items-center gap-2 px-3 py-1 bg-yellow-500/20 text-yellow-400 rounded-full text-xs font-semibold">
                    <i class="fas fa-exclamation-triangle"></i> Disabled
                </div>
            </div>

            <div class="flex items-center justify-between py-4">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-lg bg-purple-600/20 flex items-center justify-center text-purple-500">
                        <i class="fas fa-history"></i>
                    </div>
                    <div>
                        <h4 class="text-white font-semibold text-sm">Login History</h4>
                        <p class="text-gray-400 text-xs">View recent login activity</p>
                    </div>
                </div>
                <div class="flex items-center gap-2 px-3 py-1 bg-green-500/20 text-green-400 rounded-full text-xs font-semibold">
                    <i class="fas fa-check"></i> Available
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Auto-dismiss flash messages after 5 seconds
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
            message.style.transition = 'opacity 0.5s';
            message.style.opacity = '0';
            setTimeout(function() {
                message.remove();
            }, 500);
        });
    }, 5000);
});
</script>
{% endblock %}
