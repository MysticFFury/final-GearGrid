{% extends 'base.html.twig' %}

{% block title %}My Profile | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    :root {
        --primary: #6C63FF;
        --secondary: #ff6584;
        --danger: #dc3545;
        --bg-dark: #12121e;
        --card-bg: #1e1e2f;
        --text-muted: #88889b;
        --glass-border: rgba(255, 255, 255, 0.08);
    }

    .dashboard main {
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-dark);
        font-family: 'Inter', sans-serif;
    }

    /* --- TOP BAR STYLING --- */
    .top-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--glass-border);
    }

    .header-left h1 {
        font-family: 'Oswald', sans-serif;
        color: #fff;
        font-size: 2rem;
        letter-spacing: 1px;
        margin: 0;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-top: 8px;
    }

    .breadcrumb a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s;
    }

    .breadcrumb a:hover { color: var(--primary); }

    .breadcrumb i { font-size: 0.7rem; opacity: 0.5; }

    .breadcrumb span { color: var(--secondary); font-weight: 600; }

    .header-right .profile {
        display: flex;
        align-items: center;
        gap: 15px;
        background: rgba(255, 255, 255, 0.03);
        padding: 8px 20px;
        border-radius: 50px;
        border: 1px solid var(--glass-border);
        transition: all 0.3s ease;
    }

    .header-right .profile:hover {
        background: rgba(255, 255, 255, 0.08);
        transform: translateY(-2px);
    }

    .text-info {
        display: flex;
        flex-direction: column;
        text-align: right;
    }

    .text-info .name { color: #fff; font-weight: 600; font-size: 0.9rem; }
    .text-info .role { color: var(--text-muted); font-size: 0.75rem; }

    .avatar-wrapper { position: relative; width: 42px; height: 42px; }
    .avatar-wrapper img { width: 100%; height: 100%; border-radius: 50%; border: 2px solid var(--primary); }
    .status-indicator {
        position: absolute; bottom: 2px; right: 2px; width: 10px; height: 10px;
        background: #4ade80; border: 2px solid var(--bg-dark); border-radius: 50%;
    }

    /* --- CARD STYLING --- */
    .card {
        background: var(--card-bg);
        padding: 3rem;
        border-radius: 24px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        max-width: 900px;
        margin: 0 auto;
        border: 1px solid var(--glass-border);
        position: relative;
        overflow: hidden;
    }

    .card::before {
        content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 4px;
        background: linear-gradient(90deg, var(--primary), var(--secondary));
    }

    .card h2 {
        color: #fff; font-family: 'Oswald', sans-serif; font-size: 1.5rem;
        margin-bottom: 2.5rem; text-transform: uppercase; display: flex; align-items: center; gap: 12px;
    }

    .card h2 i { color: var(--primary); }

    /* --- PROFILE HEADER --- */
    .profile-header {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--glass-border);
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 3px solid var(--primary);
        box-shadow: 0 8px 25px rgba(108, 99, 255, 0.3);
    }

    .profile-info h3 {
        color: #fff;
        font-family: 'Oswald', sans-serif;
        font-size: 1.8rem;
        margin: 0 0 0.5rem 0;
    }

    .profile-info .email {
        color: var(--text-muted);
        font-size: 1rem;
        margin-bottom: 1rem;
    }

    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0.5rem 1rem;
        background: rgba(108, 99, 255, 0.2);
        color: var(--primary);
        border: 1px solid rgba(108, 99, 255, 0.3);
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
        margin-right: 0.5rem;
    }

    /* --- PROFILE META GRID --- */
    .profile-meta {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .meta-item {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        padding: 1.5rem;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .meta-item:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(108, 99, 255, 0.3);
        transform: translateY(-2px);
    }

    .meta-label {
        color: var(--text-muted);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }

    .meta-value {
        color: #fff;
        font-size: 1.1rem;
        font-weight: 600;
        word-break: break-word;
    }

    .meta-value .role-badge {
        margin-top: 0.5rem;
    }

    /* --- ACTION BUTTONS --- */
    .actions {
        display: flex; gap: 15px; justify-content: flex-start; align-items: center;
        border-top: 1px solid var(--glass-border); padding-top: 2.5rem;
    }

    .btn {
        display: inline-flex; align-items: center; gap: 10px; padding: 0.8rem 1.5rem;
        border-radius: 12px; font-weight: 600; text-decoration: none; transition: all 0.3s ease;
        cursor: pointer; border: none; font-size: 0.9rem; color: #fff; font-family: 'Inter', sans-serif;
    }

    .btn-primary {
        background: var(--primary);
        box-shadow: 0 4px 20px rgba(108, 99, 255, 0.25);
    }

    .btn:hover { transform: translateY(-3px); filter: brightness(1.2); }

    /* --- RESPONSIVE --- */
    @media screen and (max-width: 768px) {
        .dashboard main { padding: 1.5rem 1rem; }
        .top-header { flex-direction: column; align-items: flex-start; gap: 20px; }
        .header-right { width: 100%; }
        .header-right .profile { justify-content: space-between; }
        .card { padding: 2rem 1.5rem; }
        .profile-header { flex-direction: column; text-align: center; }
        .profile-meta { grid-template-columns: 1fr; }
        .actions { flex-direction: column; align-items: stretch; }
        .btn { justify-content: center; }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <div class="top-header">
            <div class="header-left">
                <h1>My Profile</h1>
                <nav class="breadcrumb">
                    <a href="{{ path('app_dashboard') }}">Dashboard</a> 
                    <i class="fas fa-chevron-right"></i> 
                    <span>Profile</span>
                </nav>
            </div>

            <div class="header-right">
                <div class="user-info">
                    <div class="profile">
                        <div class="text-info">
                            <span class="name">{{ app.user.name|default('User') }}</span>
                            <span class="role">{% if is_granted('ROLE_ADMIN') %}Administrator{% else %}Staff{% endif %}</span>
                        </div>
                        <div class="avatar-wrapper">
                            <img src="https://ui-avatars.com/api/?name={{ app.user.name|default('User')|url_encode }}&background=6C63FF&color=fff" alt="User">
                            <span class="status-indicator"></span>
                        </div>
                        <i class="fas fa-chevron-down" style="color: var(--text-muted); font-size: 0.8rem;"></i>
                    </div>
                </div>
            </div>
        </div>

        {# Flash Messages #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success flash-message" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; background: #28a745; color: #fff; border-radius: 8px; display: flex; align-items: center; justify-content: space-between; gap: 10px; box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3); max-width: 900px; margin-left: auto; margin-right: auto;">
                <span style="display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-check-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" style="background: transparent; border: none; color: #fff; cursor: pointer; font-size: 1.2rem; opacity: 0.8; padding: 0 5px;">&times;</button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-error flash-message" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; background: #dc3545; color: #fff; border-radius: 8px; display: flex; align-items: center; justify-content: space-between; gap: 10px; box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3); max-width: 900px; margin-left: auto; margin-right: auto;">
                <span style="display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-exclamation-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" style="background: transparent; border: none; color: #fff; cursor: pointer; font-size: 1.2rem; opacity: 0.8; padding: 0 5px;">&times;</button>
            </div>
        {% endfor %}

        <div class="card">
            <h2><i class="fas fa-user"></i> Profile Information</h2>

            <div class="profile-header">
                <img src="https://ui-avatars.com/api/?name={{ user.name|default(user.email)|url_encode }}&background=6C63FF&color=fff" alt="User avatar" class="profile-avatar">
                <div class="profile-info">
                    <h3>{{ user.name|default('User') }}</h3>
                    <div class="email">{{ user.email|default('—') }}</div>
                    <div>
                        {% for role in user.roles %}
                            <span class="role-badge">
                                <i class="fas fa-id-badge"></i>
                                {{ role|replace({'ROLE_':''})|capitalize }}
                            </span>
                        {% else %}
                            <span class="role-badge">
                                <i class="fas fa-id-badge"></i>
                                User
                            </span>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="profile-meta">
                <div class="meta-item">
                    <div class="meta-label">Full Name</div>
                    <div class="meta-value">{{ user.name|default('—') }}</div>
                </div>

                <div class="meta-item">
                    <div class="meta-label">Email Address</div>
                    <div class="meta-value">{{ user.email|default('—') }}</div>
                </div>

                <div class="meta-item">
                    <div class="meta-label">User Roles</div>
                    <div class="meta-value">
                        {% for role in user.roles %}
                            <span class="role-badge">{{ role|replace({'ROLE_':''})|capitalize }}</span>
                        {% else %}
                            <span class="role-badge">User</span>
                        {% endfor %}
                    </div>
                </div>

                <div class="meta-item">
                    <div class="meta-label">Account Status</div>
                    <div class="meta-value">
                        {% if user.isActive ?? true %}
                            <span class="role-badge" style="background: rgba(74, 222, 128, 0.2); border-color: rgba(74, 222, 128, 0.4); color: #4ade80;">
                                <i class="fas fa-check-circle"></i> Active
                            </span>
                        {% else %}
                            <span class="role-badge" style="background: rgba(220, 53, 69, 0.2); border-color: rgba(220, 53, 69, 0.4); color: #ff6b6b;">
                                <i class="fas fa-times-circle"></i> Inactive
                            </span>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="actions">
                <a href="{{ path('app_profile_edit') }}" class="btn btn-primary">
                    <i class="fas fa-key"></i> Change Password
                </a>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Auto-dismiss flash messages after 5 seconds
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
            message.style.transition = 'opacity 0.5s';
            message.style.opacity = '0';
            setTimeout(function() {
                message.remove();
            }, 500);
        });
    }, 5000);
});
</script>
{% endblock %}
