{% extends 'base.html.twig' %}

{% block title %}Category Details | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<style>
    :root {
        --glass-border: rgba(255,255,255,0.08);
    }

    .dashboard main {
        margin-left: 16rem;
        padding: 2rem 3rem;
        min-height: 100vh;
        background: #0B1120;
        font-family: 'Inter', sans-serif;
    }

    .panel {
        background: linear-gradient(180deg, rgba(17,24,39,0.72), rgba(11,17,32,0.75));
        border: 1px solid var(--glass-border);
        border-radius: 14px;
    }

    @media (max-width: 768px) {
        .dashboard main {
            margin-left: 0;
            padding: 1rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 pb-4 border-b border-gray-700">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">Category Details</h1>
                <nav class="flex items-center gap-2 text-sm text-gray-400">
                    <a href="{{ path('app_dashboard') }}" class="hover:text-purple-500 transition-colors">Dashboard</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <a href="{{ path('app_category_index') }}" class="hover:text-purple-500 transition-colors">Categories</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <span class="text-purple-500 font-semibold">{{ category.name }}</span>
                </nav>
            </div>

            <div class="mt-4 md:mt-0">
                {% include 'partials/_user_dropdown.html.twig' %}
            </div>
        </div>

        <div class="space-y-4">
            {# Flash Messages #}
            {% for message in app.flashes('success') %}
                <div class="bg-green-500/20 border border-green-500/30 text-green-400 px-4 py-3 rounded-lg flex items-center justify-between gap-3 shadow-lg shadow-green-500/10">
                    <span class="flex items-center gap-2">
                        <i class="fas fa-check-circle"></i> {{ message }}
                    </span>
                    <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-green-400 cursor-pointer text-xl opacity-80 hover:opacity-100">&times;</button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="bg-red-500/20 border border-red-500/30 text-red-400 px-4 py-3 rounded-lg flex items-center justify-between gap-3 shadow-lg shadow-red-500/10">
                    <span class="flex items-center gap-2">
                        <i class="fas fa-exclamation-circle"></i> {{ message }}
                    </span>
                    <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-red-400 cursor-pointer text-xl opacity-80 hover:opacity-100">&times;</button>
                </div>
            {% endfor %}

            <div class="max-w-2xl mx-auto">
                <div class="panel border-l-4 border-l-purple-500 p-6">
                    <h2 class="text-xl font-semibold text-white flex items-center gap-3 mb-6">
                        <i class="fas fa-layer-group text-purple-500"></i> Category Information
                    </h2>

                    <div class="space-y-4">
                        <div class="flex justify-between items-start border-b border-gray-700 pb-4">
                            <span class="text-gray-400 text-sm uppercase tracking-wider">Reference ID</span>
                            <span class="text-pink-500 font-mono bg-pink-500/10 px-3 py-1 rounded-md text-sm">#{{ category.id }}</span>
                        </div>

                        <div class="flex justify-between items-start border-b border-gray-700 pb-4">
                            <span class="text-gray-400 text-sm uppercase tracking-wider">Category Name</span>
                            <span class="text-white font-semibold">{{ category.name }}</span>
                        </div>

                        <div class="flex justify-between items-start">
                            <span class="text-gray-400 text-sm uppercase tracking-wider">Description</span>
                            <span class="text-gray-300 max-w-md text-right">
                                {{ category.description ?: 'No detailed description available for this category.' }}
                            </span>
                        </div>
                    </div>

                    <div class="flex flex-wrap gap-3 pt-6 border-t border-gray-700 mt-6">
                        <a href="{{ path('app_category_index') }}" class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                        
                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
                            <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-lg shadow-purple-500/20">
                                <i class="fas fa-edit"></i> Edit Records
                            </a>

                            {{ include('category/_delete_form.html.twig') }}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
            message.style.transition = 'opacity 0.5s';
            message.style.opacity = '0';
            setTimeout(function() {
                message.remove();
            }, 500);
        });
    }, 5000);
});
</script>
{% endblock %}