{% extends 'base.html.twig' %}

{% block title %}Category Details | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
    :root {
        --primary: #6C63FF;
        --secondary: #ff6584;
        --danger: #dc3545;
        --bg-dark: #12121e;
        --card-bg: #1e1e2f;
        --text-muted: #88889b;
        --glass-border: rgba(255, 255, 255, 0.08);
    }

    .dashboard main {
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-dark);
        font-family: 'Inter', sans-serif;
    }

    /* --- TOP BAR STYLING --- */
    .top-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--glass-border);
    }

    .header-left h1 {
        font-family: 'Oswald', sans-serif;
        color: #fff;
        font-size: 2rem;
        letter-spacing: 1px;
        margin: 0;
    }

    .breadcrumb {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-top: 8px;
    }

    .breadcrumb a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s;
    }

    .breadcrumb a:hover { color: var(--primary); }

    .breadcrumb i { font-size: 0.7rem; opacity: 0.5; }

    .breadcrumb span { color: var(--secondary); font-weight: 600; }

    .header-right .profile {
        display: flex;
        align-items: center;
        gap: 15px;
        background: rgba(255, 255, 255, 0.03);
        padding: 8px 20px;
        border-radius: 50px;
        border: 1px solid var(--glass-border);
        transition: all 0.3s ease;
    }

    .header-right .profile:hover {
        background: rgba(255, 255, 255, 0.08);
        transform: translateY(-2px);
    }

    .text-info {
        display: flex;
        flex-direction: column;
        text-align: right;
    }

    .text-info .name { color: #fff; font-weight: 600; font-size: 0.9rem; }
    .text-info .role { color: var(--text-muted); font-size: 0.75rem; }

    .avatar-wrapper { position: relative; width: 42px; height: 42px; }
    .avatar-wrapper img { width: 100%; height: 100%; border-radius: 50%; border: 2px solid var(--primary); }
    .status-indicator {
        position: absolute; bottom: 2px; right: 2px; width: 10px; height: 10px;
        background: #4ade80; border: 2px solid var(--bg-dark); border-radius: 50%;
    }

    /* --- CARD STYLING --- */
    .card {
        background: var(--card-bg);
        padding: 3rem;
        border-radius: 24px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        max-width: 700px;
        margin: 0 auto;
        border: 1px solid var(--glass-border);
        position: relative;
        overflow: hidden;
    }

    .card::before {
        content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 4px;
        background: linear-gradient(90deg, var(--primary), var(--secondary));
    }

    .card h2 {
        color: #fff; font-family: 'Oswald', sans-serif; font-size: 1.5rem;
        margin-bottom: 2.5rem; text-transform: uppercase; display: flex; align-items: center; gap: 12px;
    }

    .card h2 i { color: var(--primary); }

    /* --- DATA TABLE --- */
    .detail-table { width: 100%; border-collapse: collapse; margin-bottom: 3rem; }
    .detail-table tr { border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
    .detail-table tr:last-child { border: none; }
    .detail-table th {
        text-align: left; padding: 1.5rem 0; color: var(--text-muted);
        font-weight: 500; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1.5px; width: 35%;
    }
    .detail-table td { padding: 1.5rem 0; color: #fff; font-size: 1.1rem; }

    /* --- ACTION BUTTONS --- */
    .actions {
        display: flex; gap: 15px; justify-content: flex-start; align-items: center;
        border-top: 1px solid rgba(255, 255, 255, 0.08); padding-top: 2.5rem;
    }

    .btn {
        display: inline-flex; align-items: center; gap: 10px; padding: 0.8rem 1.5rem;
        border-radius: 12px; font-weight: 600; text-decoration: none; transition: all 0.3s ease;
        cursor: pointer; border: none; font-size: 0.9rem; color: #fff; font-family: 'Inter', sans-serif;
    }

    .btn-back { background: rgba(255, 255, 255, 0.05); color: #ccc; border: 1px solid var(--glass-border); }
    .btn-edit { background: var(--primary); box-shadow: 0 4px 20px rgba(108, 99, 255, 0.25); }
    .btn-delete { background: var(--danger); box-shadow: 0 4px 20px rgba(220, 53, 69, 0.25); }

    .btn:hover { transform: translateY(-3px); filter: brightness(1.2); }
    .btn-back:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }

    /* --- RESPONSIVE --- */
    @media screen and (max-width: 768px) {
        .top-header { flex-direction: column; align-items: flex-start; gap: 20px; }
        .header-right { width: 100%; }
        .header-right .profile { justify-content: space-between; }
        .actions { flex-direction: column; align-items: stretch; }
        .btn { justify-content: center; }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <div class="top-header">
            <div class="header-left">
                <h1>Category Details</h1>
                <nav class="breadcrumb">
                    <a href="{{ path('app_dashboard') }}">Dashboard</a> 
                    <i class="fas fa-chevron-right"></i> 
                    <a href="{{ path('app_category_index') }}">Categories</a> 
                    <i class="fas fa-chevron-right"></i> 
                    <span>{{ category.name }}</span>
                </nav>
            </div>

            <div class="header-right">
                <div class="user-info">
                    <div class="profile">
                        <div class="text-info">
                            <span class="name">John Ralf</span>
                            <span class="role">Administrator</span>
                        </div>
                        <div class="avatar-wrapper">
                            <img src="https://ui-avatars.com/api/?name=John+Ralf&background=6C63FF&color=fff" alt="User">
                            <span class="status-indicator"></span>
                        </div>
                        <i class="fas fa-chevron-down" style="color: var(--text-muted); font-size: 0.8rem;"></i>
                    </div>
                </div>
            </div>
        </div>

        {# Flash Messages #}
        {% for message in app.flashes('success') %}
            <div class="alert alert-success flash-message" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; background: #28a745; color: #fff; border-radius: 8px; display: flex; align-items: center; justify-content: space-between; gap: 10px; box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3); max-width: 700px; margin-left: auto; margin-right: auto;">
                <span style="display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-check-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" style="background: transparent; border: none; color: #fff; cursor: pointer; font-size: 1.2rem; opacity: 0.8; padding: 0 5px;">&times;</button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-error flash-message" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; background: #dc3545; color: #fff; border-radius: 8px; display: flex; align-items: center; justify-content: space-between; gap: 10px; box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3); max-width: 700px; margin-left: auto; margin-right: auto;">
                <span style="display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-exclamation-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" style="background: transparent; border: none; color: #fff; cursor: pointer; font-size: 1.2rem; opacity: 0.8; padding: 0 5px;">&times;</button>
            </div>
        {% endfor %}

        <div class="card">
            <h2><i class="fas fa-layer-group"></i> Category Information</h2>

            <table class="detail-table">
                <tbody>
                    <tr>
                        <th>Reference ID</th>
                        <td><span style="color: var(--secondary); font-family: monospace; background: rgba(255,101,132,0.1); padding: 4px 10px; border-radius: 6px;">#{{ category.id }}</span></td>
                    </tr>
                    <tr>
                        <th>Category Name</th>
                        <td style="font-weight: 600; color: #fff;">{{ category.name }}</td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td style="line-height: 1.8; color: #b1b1c3;">
                            {{ category.description ?: 'No detailed description available for this category.' }}
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="actions">
                <a href="{{ path('app_category_index') }}" class="btn btn-back">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
                
                {% if is_granted('ROLE_ADMIN') or category.createdBy == app.user %}
                    <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-edit">
                        <i class="fas fa-edit"></i> Edit Records
                    </a>

                    {{ include('category/_delete_form.html.twig') }}
                {% endif %}
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Auto-dismiss flash messages after 5 seconds
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
            message.style.transition = 'opacity 0.5s';
            message.style.opacity = '0';
            setTimeout(function() {
                message.remove();
            }, 500);
        });
    }, 5000);
});
</script>
{% endblock %}