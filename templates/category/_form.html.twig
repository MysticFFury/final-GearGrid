{{ form_start(form, { 'attr': { 'class': 'space-y-4' } }) }}

<div class="space-y-2">
    {{ form_label(form.name, null, {'label_attr': {'class': 'text-gray-400 text-sm uppercase tracking-wider font-medium'}}) }}
    {{ form_widget(form.name, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500', 'placeholder': 'Enter category name'}}) }}
    {{ form_errors(form.name) }}
</div>

<div class="space-y-2">
    {{ form_label(form.description, null, {'label_attr': {'class': 'text-gray-400 text-sm uppercase tracking-wider font-medium'}}) }}
    {{ form_widget(form.description, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 min-h-[120px]', 'placeholder': 'Enter description (optional)'}}) }}
    {{ form_errors(form.description) }}
</div>

<div class="flex flex-wrap gap-3 pt-4 border-t border-gray-700">
    <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-lg shadow-purple-500/20">
        <i class="fas fa-save"></i> {{ button_label|default('Save') }}
    </button>
</div>

{{ form_end(form) }}