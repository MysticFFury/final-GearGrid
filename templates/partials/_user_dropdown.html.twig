<div class="relative">
    <button id="userDropdownBtn" class="flex items-center gap-3 bg-gray-800/50 px-4 py-2 rounded-full border border-gray-700 hover:bg-gray-800 transition-all duration-200">
        <div class="text-right">
            <p class="text-white font-semibold text-sm">{{ app.user.name|default(app.user.username|default('Admin')) }}</p>
            <p class="text-gray-400 text-xs">{% if is_granted('ROLE_ADMIN') %}Administrator{% else %}Staff{% endif %}</p>
        </div>
        <div class="relative">
            <img src="https://ui-avatars.com/api/?name={{ app.user.name|default(app.user.username|default('Admin'))|url_encode }}&background=6C63FF&color=fff" alt="User" class="w-10 h-10 rounded-lg border-2 border-purple-500">
            <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-gray-900 rounded-full"></span>
        </div>
        <i class="fas fa-chevron-down text-gray-400 text-xs"></i>
    </button>

    <!-- Dropdown Menu -->
    <div id="userDropdownMenu" class="hidden absolute right-0 mt-2 w-48 bg-gray-800 border border-gray-700 rounded-lg shadow-xl overflow-hidden z-50">
        <a href="{{ path('app_profile') }}" class="flex items-center gap-3 px-4 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <i class="fas fa-user-circle w-5"></i>
            <span>View Profile</span>
        </a>
        <form method="post" action="{{ path('app_logout') }}">
            <button type="submit" class="flex items-center gap-3 w-full px-4 py-3 text-gray-300 hover:bg-red-600/20 hover:text-red-400 transition-colors text-left">
                <i class="fas fa-sign-out-alt w-5"></i>
                <span>Logout</span>
            </button>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const dropdownBtn = document.getElementById('userDropdownBtn');
    const dropdownMenu = document.getElementById('userDropdownMenu');

    dropdownBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        dropdownMenu.classList.toggle('hidden');
    });

    document.addEventListener('click', function() {
        dropdownMenu.classList.add('hidden');
    });

    dropdownMenu.addEventListener('click', function(e) {
        e.stopPropagation();
    });
});
</script>
