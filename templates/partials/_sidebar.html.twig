<aside class="fixed left-0 top-0 h-full w-64 bg-gray-900 border-r border-gray-800 flex flex-col z-50">
    <!-- Logo Section -->
    <div class="p-6 border-b border-gray-800">
        <div class="flex items-center gap-3 group cursor-pointer">
            <div class="relative">
                <div class="absolute inset-0 bg-gradient-to-br from-purple-500/0 to-pink-500/0 rounded-lg transition-all duration-500 group-hover:from-purple-500/20 group-hover:to-pink-500/20"></div>
                <img src="{{ asset('images/logo.png') }}" alt="GearGrid Logo" class="w-10 h-10 rounded-lg transition-all duration-500 group-hover:scale-110 group-hover:rotate-3 group-hover:shadow-lg group-hover:shadow-purple-500/50 group-hover:drop-shadow-[0_0_15px_rgba(108,99,255,0.6)]">
            </div>
            <h2 class="text-2xl font-bold text-white transition-all duration-500 group-hover:scale-105">
                <span class="bg-gradient-to-r from-white via-purple-400 to-pink-400 bg-clip-text text-transparent transition-all duration-500 group-hover:from-purple-300 group-hover:to-pink-500">Gear</span><span class="bg-gradient-to-r from-purple-400 via-pink-400 to-purple-600 bg-clip-text text-transparent transition-all duration-500 group-hover:from-pink-400 group-hover:to-purple-400">Grid</span>
            </h2>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 overflow-y-auto py-4">
        <ul class="space-y-1 px-3">
            <li>
                <a href="{{ path('app_dashboard') }}" 
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 hover:text-white transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'app_dashboard' ? 'bg-purple-600/20 text-purple-400 border-l-4 border-purple-500' : '' }}">
                    <i class="fas fa-chart-line w-5"></i>
                    <span class="font-medium">Dashboard</span>
                </a>
            </li>

            <li>
                <a href="{{ path('app_product_index') }}" 
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 hover:text-white transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'app_product' ? 'bg-purple-600/20 text-purple-400 border-l-4 border-purple-500' : '' }}">
                    <i class="fas fa-box w-5"></i>
                    <span class="font-medium">Products</span>
                </a>
            </li>

            <li>
                <a href="{{ path('app_category_index') }}" 
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 hover:text-white transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'app_category' ? 'bg-purple-600/20 text-purple-400 border-l-4 border-purple-500' : '' }}">
                    <i class="fas fa-tags w-5"></i>
                    <span class="font-medium">Categories</span>
                </a>
            </li>

            <li>
                <a href="{{ path('app_order_index') }}" 
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 hover:text-white transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'app_order' ? 'bg-purple-600/20 text-purple-400 border-l-4 border-purple-500' : '' }}">
                    <i class="fas fa-shopping-cart w-5"></i>
                    <span class="font-medium">Orders</span>
                </a>
            </li>

            <li>
                <a href="{{ path('app_profile') }}" 
                   class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 hover:text-white transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'app_profile' ? 'bg-purple-600/20 text-purple-400 border-l-4 border-purple-500' : '' }}">
                    <i class="fas fa-user-circle w-5"></i>
                    <span class="font-medium">Profile</span>
                </a>
            </li>

            {% if is_granted('ROLE_ADMIN') %}
                <li class="pt-4">
                    <div class="px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Admin</div>
                </li>
                <li>
                    <a href="{{ path('app_log_index') }}" 
                       class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 hover:text-white transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'app_log' ? 'bg-purple-600/20 text-purple-400 border-l-4 border-purple-500' : '' }}">
                        <i class="fas fa-file-alt w-5"></i>
                        <span class="font-medium">Logs</span>
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_user_index') }}" 
                       class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-300 hover:bg-gray-800 hover:text-white transition-all duration-200 {{ app.request.attributes.get('_route') starts with 'app_user' ? 'bg-purple-600/20 text-purple-400 border-l-4 border-purple-500' : '' }}">
                        <i class="fas fa-users w-5"></i>
                        <span class="font-medium">Users</span>
                    </a>
                </li>
            {% endif %}
        </ul>
    </nav>

    <!-- Logout -->
    <div class="p-4 border-t border-gray-800">
        <form method="post" action="{{ path('app_logout') }}">
            <button type="submit" class="flex items-center gap-3 px-4 py-3 w-full rounded-lg text-gray-300 hover:bg-red-600/20 hover:text-red-400 transition-all duration-200">
                <i class="fas fa-sign-out-alt w-5"></i>
                <span class="font-medium">Logout</span>
            </button>
        </form>
    </div>
</aside>
