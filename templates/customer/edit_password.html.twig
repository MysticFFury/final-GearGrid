{% extends 'customer/base_customer.html.twig' %}

{% block title %}Change password | GearGrid{% endblock %}

{% block stylesheets %}
<style>
    .pwd-wrap { max-width: 520px; margin: 0 auto; }
    .pwd-card {
        padding: 2rem;
        border-top: 4px solid var(--primary) !important;
    }
    .form-row { margin-bottom: 1.25rem; }
    .form-row label { display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.45rem; }
    .form-row input[type="password"] {
        width: 100%; padding: 0.75rem 1rem; border-radius: 10px; border: 1px solid var(--glass-border);
        background: rgba(255,255,255,0.04); color: #fff; font-family: inherit; font-size: 0.95rem;
    }
    .form-row input:focus { outline: none; border-color: rgba(108,99,255,0.6); box-shadow: 0 0 0 3px rgba(108,99,255,0.15); }
    .form-errors { color: #f87171; font-size: 0.82rem; margin-top: 0.35rem; }
    .btn-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--glass-border); }
    .btn-primary {
        background: linear-gradient(135deg, var(--primary), var(--primary-hover)); color: #fff; border: none;
        padding: 0.65rem 1.25rem; border-radius: 12px; font-weight: 600; cursor: pointer; font-family: inherit;
        box-shadow: 0 6px 20px rgba(108,99,255,0.3);
    }
    .btn-primary:hover { filter: brightness(1.06); transform: translateY(-1px); }
    .btn-ghost { background: transparent; color: var(--text-muted); border: 1px solid var(--glass-border); padding: 0.65rem 1.25rem; border-radius: 10px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
    .btn-ghost:hover { color: #fff; border-color: var(--glass-border-hover); }
    .flash { margin-bottom: 1rem; padding: 0.85rem 1rem; border-radius: 10px; font-size: 0.9rem; }
    .flash.err { background: rgba(248,113,113,0.12); border: 1px solid rgba(248,113,113,0.35); color: #f87171; }
</style>
{% endblock %}

{% block body %}
<div class="pwd-wrap animate-up">
    {% for message in app.flashes('error') %}
        <div class="flash err"><i class="fas fa-exclamation-circle"></i> {{ message }}</div>
    {% endfor %}

    <header class="customer-page-hero" style="margin-bottom: 1.5rem; padding: 1.25rem 1rem;">
        <span class="customer-kicker"><i class="fas fa-key"></i> Security</span>
        <h1 class="customer-page-title" style="font-size: clamp(1.65rem, 4vw, 2.25rem); margin-bottom: 0.35rem;"><i class="fas fa-lock" aria-hidden="true"></i>Change password</h1>
        <p class="customer-page-lead" style="font-size: 0.95rem;">Use a strong password you do not reuse elsewhere.</p>
    </header>

    <div class="pwd-card customer-glass-deep">
        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
            <div class="form-row">
                <label for="{{ form.currentPassword.vars.id }}">Current password</label>
                {{ form_widget(form.currentPassword, { attr: { class: '', autocomplete: 'current-password' } }) }}
                {{ form_errors(form.currentPassword) }}
            </div>
            <div class="form-row">
                <label for="{{ form.newPassword.first.vars.id }}">New password</label>
                {{ form_widget(form.newPassword.first, { attr: { autocomplete: 'new-password' } }) }}
                {{ form_errors(form.newPassword.first) }}
            </div>
            <div class="form-row">
                <label for="{{ form.newPassword.second.vars.id }}">Confirm new password</label>
                {{ form_widget(form.newPassword.second, { attr: { autocomplete: 'new-password' } }) }}
                {{ form_errors(form.newPassword.second) }}
            </div>
            {{ form_errors(form) }}

            <div class="btn-row">
                <button type="submit" class="btn-primary"><i class="fas fa-key"></i> Update password</button>
                <a href="{{ path('app_profile') }}" class="btn-ghost">Cancel</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
