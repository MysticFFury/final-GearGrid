{% extends 'customer/base_customer.html.twig' %}

{% block title %}My account | GearGrid{% endblock %}

{% block stylesheets %}
<style>
    .account-page-intro { margin-bottom: 1.25rem; }
    .account-grid { display: grid; grid-template-columns: 280px 1fr; gap: 2rem; align-items: start; }
    @media (max-width: 900px) { .account-grid { grid-template-columns: 1fr; } }

    .account-card { padding: 1.5rem; }
    .account-avatar {
        width: 72px; height: 72px; border-radius: 50%; object-fit: cover; border: 3px solid rgba(108,99,255,0.4);
        display: block; margin: 0 auto 1rem;
    }
    .account-name { text-align: center; font-weight: 700; color: #fff; font-size: 1.1rem; }
    .account-email { text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.25rem; word-break: break-all; }

    .account-links { display: flex; flex-direction: column; gap: 0.5rem; }
    .account-links a {
        display: flex; align-items: center; gap: 10px; padding: 0.65rem 1rem; border-radius: 10px; text-decoration: none;
        color: var(--text-muted); font-size: 0.9rem; font-weight: 500; transition: all 0.2s;
        border: 1px solid transparent;
    }
    .account-links a:hover { color: #fff; background: rgba(108,99,255,0.1); border-color: rgba(108,99,255,0.25); }
    .account-links a.primary { background: rgba(108,99,255,0.15); color: #a5b4fc; border-color: rgba(108,99,255,0.35); }
    .account-links a.primary:hover { background: var(--primary); color: #fff; }

    .orders-section h2 { font-family: 'Oswald', sans-serif; font-size: 1.35rem; color: #fff; margin-bottom: 1rem; display: flex; align-items: center; gap: 10px; }
    .order-card { padding: 1.25rem 1.5rem; margin-bottom: 1rem; }
    .order-card-top { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 0.75rem; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--glass-border); }
    .order-id { font-weight: 700; color: #fff; }
    .order-meta { font-size: 0.82rem; color: var(--text-muted); }
    .status-pill {
        display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 999px; font-size: 0.75rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.05em;
    }
    .status-pending { background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); }
    .status-processing { background: rgba(96,165,250,0.15); color: #93c5fd; border: 1px solid rgba(96,165,250,0.3); }
    .status-shipped, .status-delivered, .status-completed { background: rgba(74,222,128,0.12); color: #4ade80; border: 1px solid rgba(74,222,128,0.25); }
    .status-cancelled { background: rgba(248,113,113,0.12); color: #f87171; border: 1px solid rgba(248,113,113,0.25); }

    .order-lines { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .order-lines th { text-align: left; color: var(--text-muted); font-weight: 600; padding: 0.5rem 0; border-bottom: 1px solid var(--glass-border); }
    .order-lines td { padding: 0.65rem 0; color: var(--text-main); border-bottom: 1px solid rgba(255,255,255,0.04); }
    .order-lines tr:last-child td { border-bottom: none; }
    .order-total { text-align: right; font-weight: 700; color: var(--success); margin-top: 0.75rem; font-size: 1rem; }

    .empty-orders { color: var(--text-muted); padding: 2rem; text-align: center; border: 1px dashed var(--glass-border); border-radius: 14px; }
    .flash-msgs .flash { margin-bottom: 1rem; padding: 0.85rem 1.1rem; border-radius: 10px; font-size: 0.9rem; }
    .flash-msgs .flash.success { background: rgba(74,222,128,0.12); border: 1px solid rgba(74,222,128,0.35); color: #4ade80; }
    .flash-msgs .flash.error { background: rgba(248,113,113,0.12); border: 1px solid rgba(248,113,113,0.35); color: #f87171; }
</style>
{% endblock %}

{% block body %}
<header class="customer-page-hero account-page-intro animate-up">
    <span class="customer-kicker"><i class="fas fa-user"></i> Member area</span>
    <h1 class="customer-page-title"><i class="fas fa-user-circle" aria-hidden="true"></i>My account</h1>
    <p class="customer-page-lead">Your profile, order history, and security — separate from the staff dashboard.</p>
</header>

<div class="flash-msgs">
    {% for message in app.flashes('success') %}
        <div class="flash success"><i class="fas fa-check-circle"></i> {{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash error"><i class="fas fa-exclamation-circle"></i> {{ message }}</div>
    {% endfor %}
</div>

<div class="account-grid animate-up delay-1">
    <aside class="account-card customer-glass-deep">
        <img class="account-avatar" src="https://ui-avatars.com/api/?name={{ user.name|default(user.email)|url_encode }}&background=6C63FF&color=fff&size=160" alt="">
        <div class="account-name">{{ user.name|default('Member') }}</div>
        <div class="account-email">{{ user.email }}</div>
        <nav class="account-links" aria-label="Account">
            <a class="primary" href="{{ path('app_customer_products') }}"><i class="fas fa-cart-shopping"></i> Shop</a>
            <a href="{{ path('app_customer_cart') }}"><i class="fas fa-basket-shopping"></i> Cart</a>
            <a href="{{ path('app_profile_edit') }}"><i class="fas fa-key"></i> Change password</a>
            <a href="{{ path('app_logout') }}"><i class="fas fa-right-from-bracket"></i> Log out</a>
        </nav>
    </aside>

    <section class="orders-section">
        <h2><i class="fas fa-receipt"></i> My orders</h2>

        {% if orders is empty %}
            <div class="empty-orders customer-glass-deep">
                <p style="margin-bottom: 0.75rem;">You have not placed any orders yet.</p>
                <a href="{{ path('app_customer_products') }}" class="landing-header-cta" style="display: inline-flex; margin-top: 0.5rem;">
                    <i class="fas fa-store"></i> Browse products
                </a>
            </div>
        {% else %}
            {% for order in orders %}
                <article class="order-card customer-glass-deep">
                    <div class="order-card-top">
                        <div>
                            <span class="order-id">Order #{{ order.id }}</span>
                            <div class="order-meta">{{ order.createdAt ? order.createdAt|date('M j, Y g:i a') : '' }}</div>
                        </div>
                        {% set st = order.status|default('')|lower %}
                        <span class="status-pill status-{{ st == 'pending' ? 'pending' : (st == 'processing' ? 'processing' : (st == 'cancelled' ? 'cancelled' : 'shipped')) }}">{{ order.status }}</span>
                    </div>

                    {% if order.items|length > 0 %}
                        <table class="order-lines">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th style="text-align:center;">Qty</th>
                                    <th style="text-align:right;">Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for line in order.items %}
                                    <tr>
                                        <td>{{ line.product ? line.product.name : '—' }}</td>
                                        <td style="text-align:center;">{{ line.quantity }}</td>
                                        <td style="text-align:right;">₱{{ line.lineTotal|number_format(2, '.', ',') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% elseif order.products|length > 0 %}
                        <table class="order-lines">
                            <thead>
                                <tr><th>Product</th><th style="text-align:right;">(legacy)</th></tr>
                            </thead>
                            <tbody>
                                {% for p in order.products %}
                                    <tr>
                                        <td>{{ p.name }}</td>
                                        <td style="text-align:right;">₱{{ p.price|number_format(2, '.', ',') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}

                    <div class="order-total">Total: ₱{{ order.totalPrice|number_format(2, '.', ',') }}</div>
                </article>
            {% endfor %}
        {% endif %}
    </section>
</div>

{% if app.request.query.get('checkout') == 'success' %}
<script>
try { localStorage.removeItem('geargrid_cart_v1'); } catch (e) {}
if (window.history && window.history.replaceState) {
    const u = new URL(window.location.href);
    u.searchParams.delete('checkout');
    window.history.replaceState({}, '', u.pathname + u.search);
}
</script>
{% endif %}
{% endblock %}
