{% extends 'customer/base_customer.html.twig' %}

{% block title %}Welcome | GearGrid{% endblock %}

{% block stylesheets %}
<style>
    /* --- Loading Screen --- */
    #loading-screen {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #0B1120 0%, #1a1f35 50%, #0B1120 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        transition: opacity 0.8s ease, visibility 0.8s ease;
        overflow: hidden;
    }

    #loading-screen.hidden {
        opacity: 0;
        visibility: hidden;
    }

    /* Animated Background Particles */
    .loading-particles {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        pointer-events: none;
    }

    .particle {
        position: absolute;
        width: 4px;
        height: 4px;
        background: #6C63FF;
        border-radius: 50%;
        opacity: 0.6;
        animation: float-particle 8s infinite ease-in-out;
        box-shadow: 0 0 10px #6C63FF, 0 0 20px #6C63FF;
    }

    .particle:nth-child(1) { left: 10%; top: 20%; animation-delay: 0s; animation-duration: 6s; }
    .particle:nth-child(2) { left: 20%; top: 80%; animation-delay: 1s; animation-duration: 8s; }
    .particle:nth-child(3) { left: 30%; top: 30%; animation-delay: 2s; animation-duration: 7s; }
    .particle:nth-child(4) { left: 40%; top: 70%; animation-delay: 0.5s; animation-duration: 9s; }
    .particle:nth-child(5) { left: 50%; top: 40%; animation-delay: 1.5s; animation-duration: 5s; }
    .particle:nth-child(6) { left: 60%; top: 60%; animation-delay: 2.5s; animation-duration: 8s; }
    .particle:nth-child(7) { left: 70%; top: 25%; animation-delay: 3s; animation-duration: 6s; }
    .particle:nth-child(8) { left: 80%; top: 75%; animation-delay: 0.8s; animation-duration: 7s; }
    .particle:nth-child(9) { left: 90%; top: 45%; animation-delay: 1.2s; animation-duration: 9s; }
    .particle:nth-child(10) { left: 15%; top: 55%; animation-delay: 2.2s; animation-duration: 6s; }

    @keyframes float-particle {
        0%, 100% {
            transform: translateY(0) translateX(0) scale(1);
            opacity: 0.6;
        }
        25% {
            transform: translateY(-30px) translateX(15px) scale(1.2);
            opacity: 0.8;
        }
        50% {
            transform: translateY(-60px) translateX(-10px) scale(1);
            opacity: 0.4;
        }
        75% {
            transform: translateY(-30px) translateX(20px) scale(1.1);
            opacity: 0.7;
        }
    }

    /* Glowing Ring Animation */
    .loading-ring {
        position: relative;
        width: 150px;
        height: 150px;
        margin-bottom: 2rem;
    }

    .loading-ring::before,
    .loading-ring::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        border: 2px solid transparent;
    }

    .loading-ring::before {
        width: 100%;
        height: 100%;
        border-top-color: #6C63FF;
        border-right-color: #6C63FF;
        animation: spin 1.5s linear infinite;
        box-shadow: 0 0 20px rgba(108, 99, 255, 0.5);
    }

    .loading-ring::after {
        width: 70%;
        height: 70%;
        border-bottom-color: #ff6584;
        border-left-color: #ff6584;
        animation: spin-reverse 1s linear infinite;
        box-shadow: 0 0 15px rgba(255, 101, 132, 0.5);
    }

    .loading-logo-center {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .loading-logo-center img {
        width: 50px;
        height: 50px;
        animation: pulse-glow 2s ease-in-out infinite;
        filter: drop-shadow(0 0 15px rgba(108, 99, 255, 0.8));
    }

    .loading-logo-center h2 {
        font-family: 'Oswald', sans-serif;
        font-size: 1.8rem;
        color: #fff;
        letter-spacing: 3px;
        font-weight: 700;
        background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: fadeInUp 1s ease-out;
    }

    /* Progress Bar */
    .loading-progress {
        width: 200px;
        height: 3px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        margin-top: 2rem;
        overflow: hidden;
        position: relative;
    }

    .loading-progress-bar {
        height: 100%;
        background: linear-gradient(90deg, #6C63FF, #ff6584, #6C63FF);
        background-size: 200% 100%;
        border-radius: 10px;
        animation: progress-slide 2s ease-in-out infinite, shimmer 1.5s linear infinite;
        box-shadow: 0 0 10px rgba(108, 99, 255, 0.8);
    }

    .loading-text {
        margin-top: 1.5rem;
        color: var(--text-muted);
        font-size: 0.95rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        animation: fadeIn 2s ease-in-out;
        font-weight: 500;
    }

    .loading-text span {
        color: #6C63FF;
        animation: text-pulse 1.5s ease-in-out infinite;
    }

    @keyframes spin {
        to { transform: translate(-50%, -50%) rotate(360deg); }
    }

    @keyframes spin-reverse {
        to { transform: translate(-50%, -50%) rotate(-360deg); }
    }

    @keyframes pulse-glow {
        0%, 100% { transform: scale(1); filter: drop-shadow(0 0 15px rgba(108, 99, 255, 0.8)); }
        50% { transform: scale(1.1); filter: drop-shadow(0 0 25px rgba(108, 99, 255, 1)); }
    }

    @keyframes progress-slide {
        0% { width: 0%; }
        50% { width: 100%; }
        100% { width: 0%; }
    }

    @keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @keyframes text-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    /* --- Hero Layout --- */
    .hero-section {
        position: relative; /* Needed for the 3D canvas positioning */
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 5rem;
        align-items: center;
        margin-top: 3rem;
        padding-bottom: 4rem;
    }
    
    /* The container for our 3D background */
    #canvas-container {
        position: absolute;
        top: -10%;
        left: -10%;
        width: 120%;
        height: 120%;
        z-index: 0;
        pointer-events: none; /* Prevents 3D from blocking clicks on buttons */
    }

    /* Keep content above the 3D canvas */
    .hero-content, .hero-carousel-wrapper {
        position: relative;
        z-index: 1;
    }

    .hero-badge {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 8px 16px; border-radius: 30px;
        background: linear-gradient(135deg, rgba(108, 99, 255, 0.15), rgba(108, 99, 255, 0.05)); 
        border: 1px solid rgba(108, 99, 255, 0.3);
        color: #a5b4fc; font-weight: 600; font-size: 0.85rem; margin-bottom: 1.5rem;
        text-transform: uppercase; letter-spacing: 1px;
    }
    
    .hero-title {
        font-family: 'Oswald', sans-serif; font-size: 4.5rem; line-height: 1.1; margin-bottom: 1.5rem;
        /* Premium text gradient */
        background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        filter: drop-shadow(0 4px 10px rgba(0,0,0,0.3));
    }
    
    .hero-subtitle {
        color: var(--text-muted); font-size: 1.15rem; line-height: 1.8; margin-bottom: 2.5rem; max-width: 90%;
    }
    
    .feature-list { display: flex; flex-direction: column; gap: 1.2rem; margin-top: 2.5rem;}
    .feature-item { display: flex; align-items: flex-start; gap: 15px; color: var(--text-muted); font-size: 0.95rem; line-height: 1.5;}
    .feature-item i { color: var(--success); font-size: 1.3rem; margin-top: 2px; text-shadow: 0 0 10px rgba(74, 222, 128, 0.4); }

    /* --- Hero Carousel Styles --- */
    .hero-carousel-wrapper {
        perspective: 1000px;
        width: 100%;
        margin: 0 auto;
    }
    
    .hero-glow {
        position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
        width: 100%; height: 100%; background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
        filter: blur(80px); opacity: 0.25; z-index: -1;
    }

    .carousel-container {
        position: relative; border-radius: 24px; overflow: hidden;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4), 0 0 0 1px var(--glass-border-hover);
        transform: rotateY(-5deg) rotateX(5deg); transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s ease;
        aspect-ratio: 4/3; background: var(--glass-bg);
    }

    .hero-carousel-wrapper:hover .carousel-container {
        transform: rotateY(0deg) rotateX(0deg) translateY(-10px);
        box-shadow: 0 40px 80px rgba(108, 99, 255, 0.2), 0 0 0 1px rgba(108, 99, 255, 0.4);
    }

    .carousel-track { position: relative; height: 100%; width: 100%; transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1); }
    .carousel-slide { position: absolute; top: 0; bottom: 0; width: 100%; }
    .carousel-slide img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.9); }

    .slide-caption {
        position: absolute; bottom: 40px; left: 30px; background: rgba(11, 17, 32, 0.85);
        backdrop-filter: blur(12px); padding: 12px 24px; border-radius: 12px; font-weight: 600;
        color: #fff; border: 1px solid var(--glass-border); opacity: 0; transform: translateY(15px);
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
        box-shadow: 0 10px 25px rgba(0,0,0,0.5);
    }
    .carousel-slide.current-slide .slide-caption { opacity: 1; transform: translateY(0); }

    /* Navigation Buttons */
    .carousel-button {
        position: absolute; top: 50%; transform: translateY(-50%); background: rgba(11, 17, 32, 0.7);
        backdrop-filter: blur(8px); color: white; border: 1px solid rgba(255,255,255,0.15);
        width: 48px; height: 48px; border-radius: 50%; cursor: pointer; z-index: 10; display: flex;
        align-items: center; justify-content: center; transition: all 0.3s ease; opacity: 0; font-size: 1.1rem;
    }

    .carousel-container:hover .carousel-button { opacity: 1; }
    .carousel-button:hover { background: var(--primary); transform: translateY(-50%) scale(1.1); border-color: var(--primary); box-shadow: 0 0 20px rgba(108, 99, 255, 0.5); }
    .carousel-btn-prev { left: 20px; }
    .carousel-btn-next { right: 20px; }

    /* Pagination Dots */
    .carousel-nav { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); display: flex; gap: 10px; z-index: 10; background: rgba(0,0,0,0.4); padding: 6px 12px; border-radius: 20px; backdrop-filter: blur(4px); }
    .carousel-dot { border: none; width: 8px; height: 8px; border-radius: 50%; background: rgba(255, 255, 255, 0.4); cursor: pointer; transition: all 0.4s ease; }
    .carousel-dot.current-slide { background: var(--primary); width: 24px; border-radius: 10px; box-shadow: 0 0 10px var(--primary); }

    /* --- STATS STRIP --- */
    .stats-strip {
        display: grid; grid-template-columns: repeat(4, 1fr);
        background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01)); 
        border: 1px solid var(--glass-border);
        border-radius: 24px; padding: 2.5rem 1.5rem; margin-top: 6rem;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.05);
        backdrop-filter: blur(10px);
    }
    .stat { text-align: center; padding: 0.5rem; border-right: 1px solid var(--glass-border); transition: transform 0.3s; cursor: default; }
    .stat:hover { transform: translateY(-5px); }
    .stat:last-child { border-right: none; }
    .stat-num { font-family: 'Oswald', sans-serif; font-size: 2.8rem; color: #fff; font-weight: 700; line-height: 1.2; text-shadow: 0 4px 15px rgba(108, 99, 255, 0.3); }
    .stat-lbl { font-size: 0.9rem; color: var(--primary); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-top: 5px; }

    /* --- SHOP BY CATEGORY --- */
    .category-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-top: 2rem; }
    .category-card {
        position: relative; overflow: hidden;
        background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border);
        border-radius: 20px; text-decoration: none; color: #fff;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        height: 200px; display: flex; flex-direction: column;
    }
    .category-card:hover {
        transform: translateY(-8px); border-color: rgba(108, 99, 255, 0.4);
        box-shadow: 0 20px 40px rgba(108, 99, 255, 0.15), inset 0 1px 0 rgba(255,255,255,0.1);
    }
    .category-pattern {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        opacity: 0.3; transition: opacity 0.3s ease;
    }
    .category-card:hover .category-pattern { opacity: 0.5; }
    
    /* Custom patterns for each category */
    .pattern-cpu {
        background: linear-gradient(135deg, #6C63FF 0%, #4338ca 50%, #3730a3 100%);
        background-size: 400% 400%;
        animation: gradientShift 8s ease infinite;
    }
    .pattern-gpu {
        background: linear-gradient(135deg, #ff6584 0%, #dc2626 50%, #991b1b 100%);
        background-size: 400% 400%;
        animation: gradientShift 8s ease infinite;
    }
    .pattern-ram {
        background: linear-gradient(135deg, #4ade80 0%, #16a34a 50%, #15803d 100%);
        background-size: 400% 400%;
        animation: gradientShift 8s ease infinite;
    }
    .pattern-storage {
        background: linear-gradient(135deg, #00c6ff 0%, #0ea5e9 50%, #0284c7 100%);
        background-size: 400% 400%;
        animation: gradientShift 8s ease infinite;
    }
    .pattern-mobo {
        background: linear-gradient(135deg, #a55eea 0%, #9333ea 50%, #7c3aed 100%);
        background-size: 400% 400%;
        animation: gradientShift 8s ease infinite;
    }
    .pattern-psu {
        background: linear-gradient(135deg, #f7b731 0%, #f59e0b 50%, #d97706 100%);
        background-size: 400% 400%;
        animation: gradientShift 8s ease infinite;
    }
    
    @keyframes gradientShift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    .category-content {
        position: relative; z-index: 1; padding: 2rem; display: flex; flex-direction: column; height: 100%; justify-content: flex-end;
        background: linear-gradient(to top, rgba(11, 17, 32, 0.9), transparent);
    }
    .cat-icon {
        width: 60px; height: 60px; border-radius: 16px; background: rgba(255,255,255,0.1);
        display: flex; align-items: center; justify-content: center; font-size: 1.8rem;
        color: var(--primary); transition: all 0.3s ease; margin-bottom: 1rem;
        border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px);
    }
    .category-card:hover .cat-icon { background: var(--primary); color: #fff; transform: scale(1.1) translateY(-5px); border-color: var(--primary); box-shadow: 0 15px 30px rgba(108, 99, 255, 0.4); }
    .category-card h4 { font-family: 'Oswald', sans-serif; font-size: 1.4rem; margin: 0; font-weight: 600; letter-spacing: 0.5px; text-shadow: 0 2px 10px rgba(0,0,0,0.5); }
    .category-desc { font-size: 0.9rem; color: var(--text-muted); margin-top: 0.5rem; line-height: 1.4; }

    /* --- CORE FEATURES --- */
    @keyframes float-icon {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-8px); }
        100% { transform: translateY(0px); }
    }
    .landing-card .card-icon i { animation: float-icon 3s ease-in-out infinite; }

    /* --- TESTIMONIALS --- */
    .testi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 3rem; }
    .testi-card {
        background: linear-gradient(to bottom, rgba(255,255,255,0.03), transparent);
        border: 1px solid var(--glass-border);
        border-radius: 20px; padding: 2.5rem 2rem; position: relative;
        transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    }
    .testi-card:hover { 
        border-color: rgba(108,99,255,0.5); 
        transform: translateY(-8px); 
        box-shadow: 0 15px 35px rgba(108,99,255,0.15), inset 0 1px 0 rgba(255,255,255,0.1); 
    }
    .quote-deco { font-size: 5rem; line-height: 1; color: var(--primary); opacity: 0.1; font-family: Georgia, serif; position: absolute; top: 1rem; left: 1.5rem; }
    .stars { display: flex; gap: 4px; margin-bottom: 1.5rem; position: relative; z-index: 1;}
    .star { width: 16px; height: 16px; fill: #fbbf24; filter: drop-shadow(0 0 4px rgba(251, 191, 36, 0.4)); }
    .testi-text { font-size: 1.05rem; color: var(--text-main); line-height: 1.8; font-style: italic; margin-bottom: 2rem; position: relative; z-index: 1; }
    .testi-author { display: flex; align-items: center; gap: 15px; border-top: 1px solid var(--glass-border); padding-top: 1.5rem; }
    .avatar { width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; font-weight: 700; flex-shrink: 0; border: 2px solid rgba(255,255,255,0.1); }
    .av-purple { background: linear-gradient(135deg, rgba(108,99,255,0.4), rgba(108,99,255,0.1)); color: #fff; border-color: var(--primary); }
    .av-green  { background: linear-gradient(135deg, rgba(74,222,128,0.3), rgba(74,222,128,0.1)); color: #fff; border-color: var(--success); }
    .av-pink   { background: linear-gradient(135deg, rgba(255,101,132,0.3), rgba(255,101,132,0.1)); color: #fff; border-color: var(--secondary); }
    .aname { font-size: 1.05rem; font-weight: 600; color: #fff; margin-bottom: 2px;}
    .abadge { display: inline-flex; align-items: center; gap: 5px; font-size: 0.75rem; color: #4ade80; background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.25); padding: 4px 10px; border-radius: 10px; }

    /* --- SEAMLESS NEWSLETTER --- */
    .newsletter {
        background: linear-gradient(135deg, rgba(108,99,255,0.1), rgba(255,101,132,0.05)), url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiLz48L3N2Zz4=');
        border: 1px solid var(--glass-border-hover); border-radius: 30px;
        padding: 5rem 3rem; text-align: center; margin-top: 6rem;
        box-shadow: 0 30px 60px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.1);
        position: relative; overflow: hidden;
    }
    
    .newsletter::before {
        content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
        background: radial-gradient(circle, rgba(108,99,255,0.15) 0%, transparent 60%);
        pointer-events: none;
    }

    .nl-title { font-family: 'Oswald', sans-serif; font-size: 2.8rem; margin-bottom: 1rem; color: #fff; text-shadow: 0 2px 10px rgba(0,0,0,0.3); }
    .nl-sub { color: var(--text-muted); font-size: 1.15rem; margin-bottom: 2.5rem; max-width: 550px; margin-left: auto; margin-right: auto; line-height: 1.6;}
    
    /* The Pill Form */
    .nl-form { 
        display: flex; background: rgba(11, 17, 32, 0.6); border: 1px solid rgba(255,255,255,0.15);
        border-radius: 50px; padding: 6px; max-width: 550px; margin: 0 auto; 
        transition: border-color 0.3s, box-shadow 0.3s; backdrop-filter: blur(10px);
    }
    .nl-form:focus-within { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(108,99,255,0.2); }
    .nl-input { flex: 1; background: transparent; border: none; padding: 1rem 1.5rem; color: #fff; font-size: 1.05rem; font-family: inherit; outline: none; }
    .nl-input::placeholder { color: #64748b; }
    .nl-btn { background: var(--primary); color: #fff; border: none; padding: 1rem 2.2rem; border-radius: 40px; font-weight: 700; font-size: 1.05rem; cursor: pointer; white-space: nowrap; transition: transform 0.2s, background 0.2s; }
    .nl-btn:hover { background: var(--primary-hover); transform: scale(1.02); }

    @media (max-width: 992px) {
        .hero-section { grid-template-columns: 1fr; gap: 3rem; }
        .hero-title { font-size: 3.5rem; }
        .carousel-container { transform: none; }
        .stats-strip { grid-template-columns: 1fr 1fr; gap: 2rem 1rem; }
        .stat { border-right: none; border-bottom: 1px solid var(--glass-border); padding-bottom: 1rem; }
        .stat:nth-child(3), .stat:nth-child(4) { border-bottom: none; padding-bottom: 0; }
        .testi-grid { grid-template-columns: 1fr; }
        .nl-form { flex-direction: column; border-radius: 16px; background: transparent; border: none; gap: 10px; }
        .nl-input { background: rgba(11, 17, 32, 0.6); border: 1px solid rgba(255,255,255,0.15); border-radius: 12px; }
        .nl-btn { border-radius: 12px; width: 100%; }
        .nl-form:focus-within { box-shadow: none; border-color: transparent; }
    }
</style>
{% endblock %}

{% block body %}
    <!-- Loading Screen -->
    <div id="loading-screen">
        <!-- Animated Particles -->
        <div class="loading-particles">
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
        </div>

        <!-- Glowing Ring with Logo -->
        <div class="loading-ring">
            <div class="loading-logo-center">
                <img src="{{ asset('images/logo.png') }}" alt="GearGrid Logo">
                <h2>GEARGRID</h2>
