{# templates/customer/products.html.twig #}
{% extends 'customer/base_customer.html.twig' %}

{% block title %}Our Products | GearGrid{% endblock %}

{% block stylesheets %}
<style>
    /* --- Hero --- */
    .landing-section.catalog-page { margin-top: 2.25rem; }
    .catalog-hero {
        text-align: center;
        margin-bottom: 2.5rem;
        padding: 2.25rem 1.5rem 2.75rem;
        border-radius: 24px;
        position: relative;
        overflow: hidden;
        background: linear-gradient(165deg, rgba(108, 99, 255, 0.09) 0%, rgba(15, 22, 38, 0.4) 42%, rgba(255, 101, 132, 0.05) 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    } 
    .catalog-hero::before {
        content: '';
        position: absolute;
        width: 420px;
        height: 420px;
        top: -180px;
        right: -120px;
        background: radial-gradient(circle, rgba(108, 99, 255, 0.22) 0%, transparent 70%);
        pointer-events: none;
    }
    .catalog-hero::after {
        content: '';
        position: absolute;
        width: 320px;
        height: 320px;
        bottom: -140px;
        left: -80px;
        background: radial-gradient(circle, rgba(255, 101, 132, 0.12) 0%, transparent 70%);
        pointer-events: none;
    }
    .catalog-kicker {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #c4b5fd;
        margin-bottom: 1rem;
        padding: 0.4rem 1rem;
        border-radius: 999px;
        background: rgba(108, 99, 255, 0.14);
        border: 1px solid rgba(108, 99, 255, 0.28);
    }
    .catalog-hero .catalog-title {
        position: relative;
        z-index: 1;
        font-family: 'Oswald', sans-serif;
        font-size: clamp(2.1rem, 5vw, 3.35rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.15;
        color: #fff;
        margin: 0 0 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.65rem;
        text-shadow: 0 4px 32px rgba(108, 99, 255, 0.25);
    }
    .catalog-hero .catalog-title i {
        color: var(--primary);
        font-size: 0.85em;
        filter: drop-shadow(0 0 12px rgba(108, 99, 255, 0.5));
    }
    .catalog-hero-sub {
        position: relative;
        z-index: 1;
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.65;
        max-width: 34rem;
        margin: 0 auto;
    }
    .catalog-hero-sub strong { color: #e2e8f0; font-weight: 600; }

    /* --- Catalog layout: sidebar + grid --- */
    .catalog-layout { display: grid; grid-template-columns: minmax(272px, 308px) 1fr; gap: 2rem 2.25rem; align-items: start; margin-bottom: 2rem; }
    .catalog-sidebar {
        position: sticky;
        top: 5.25rem;
        align-self: start;
        max-height: calc(100vh - 5.5rem);
        border-radius: 16px;
        padding: 0.85rem 0.9rem 0.95rem;
        display: flex;
        flex-direction: column;
        gap: 0;
        min-height: 0;
        background: rgba(15, 22, 38, 0.78);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.09);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    }
    .sidebar-body-scroll {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        overscroll-behavior: contain;
        margin-right: -4px;
        padding-right: 4px;
        -webkit-overflow-scrolling: touch;
    }
    .sidebar-body-scroll::-webkit-scrollbar { width: 5px; }
    .sidebar-body-scroll::-webkit-scrollbar-track { background: rgba(255,255,255,0.04); border-radius: 6px; }
    .sidebar-body-scroll::-webkit-scrollbar-thumb { background: rgba(108, 99, 255, 0.35); border-radius: 6px; }
    .sidebar-body-scroll .sidebar-section {
        padding-bottom: 0.65rem;
        margin-bottom: 0.65rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    .sidebar-body-scroll .sidebar-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0.35rem;
    }
    .sidebar-budget {
        flex-shrink: 0;
        margin-top: 0.35rem;
        padding-top: 0.65rem;
        border-top: 1px solid rgba(108, 99, 255, 0.2);
    }
    .sidebar-head {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding-bottom: 0.65rem;
        margin-bottom: 0.65rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        flex-shrink: 0;
    }
    .sidebar-head-icon {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.88rem;
        color: var(--primary);
        background: linear-gradient(145deg, rgba(108, 99, 255, 0.2), rgba(108, 99, 255, 0.06));
        border: 1px solid rgba(108, 99, 255, 0.28);
    }
    .sidebar-head-title { font-family: 'Oswald', sans-serif; font-size: 1rem; color: #fff; font-weight: 600; letter-spacing: 0.02em; line-height: 1.15; }
    .sidebar-head-sub { font-size: 0.68rem; color: var(--text-muted); margin-top: 0.08rem; }
    .sidebar-label { display: block; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.12em; color: #94a3b8; font-weight: 700; margin-bottom: 0.38rem; }
    .sidebar-hint { font-size: 0.68rem; color: var(--text-muted); line-height: 1.4; margin: 0.45rem 0 0; opacity: 0.9; }
    .catalog-main { min-width: 0; }

    /* --- Search & Filters --- */
    .search-filter-bar { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 0; }
    .search-wrap { position: relative; max-width: none; width: 100%; }
    .search-input {
        width: 100%;
        background: rgba(7, 11, 22, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 0.52rem 0.65rem 0.52rem 2.15rem;
        color: var(--text-main);
        font-size: 0.8rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    }
    .search-input::placeholder { color: #64748b; }
    .search-input:focus { border-color: rgba(108, 99, 255, 0.55); box-shadow: 0 0 0 2px rgba(108, 99, 255, 0.18); background: rgba(11, 17, 32, 0.75); }
    .search-icon { position: absolute; left: 0.72rem; top: 50%; transform: translateY(-50%); color: #64748b; font-size: 0.8rem; }
    
    .filter-chips { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .filter-chips--sidebar { flex-direction: column; flex-wrap: nowrap; gap: 0.22rem; }
    .filter-chips--sidebar .filter-chip {
        width: 100%;
        text-align: left;
        padding: 0.32rem 0.55rem 0.32rem 0.6rem;
        border-radius: 8px;
        font-size: 0.72rem;
        line-height: 1.25;
    }

    .budget-max-wrap { margin-bottom: 0.45rem; }
    .price-input {
        width: 100%;
        box-sizing: border-box;
        background: rgba(7, 11, 22, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 0.52rem 0.65rem;
        color: var(--text-main);
        font-size: 0.8rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .price-input:focus { border-color: rgba(108, 99, 255, 0.55); box-shadow: 0 0 0 2px rgba(108, 99, 255, 0.18); }
    .price-input::placeholder { color: #64748b; opacity: 0.85; }
    .btn-filter-search {
        width: 100%;
        margin-top: 0.25rem;
        background: linear-gradient(135deg, var(--primary) 0%, #7c73ff 45%, var(--primary-hover) 100%);
        border: none;
        color: #fff;
        padding: 0.55rem 0.75rem;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.78rem;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        letter-spacing: 0.02em;
        box-shadow: 0 3px 12px rgba(108, 99, 255, 0.32);
        transition: transform 0.2s, box-shadow 0.2s, filter 0.2s;
    }
    .btn-filter-search:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(108, 99, 255, 0.4); filter: brightness(1.05); }
    .btn-filter-search i { margin-right: 0.35rem; opacity: 0.95; }

    .no-results-filtered {
        display: none;
        grid-column: 1 / -1;
        text-align: center;
        padding: 3.25rem 1.75rem;
        color: var(--text-muted);
        border-radius: 20px;
        background: rgba(15, 22, 38, 0.5);
        border: 1px dashed rgba(108, 99, 255, 0.22);
    }
    .no-results-filtered.visible { display: block; }
    .no-results-filtered i { font-size: 2.25rem; margin-bottom: 1.1rem; color: rgba(108, 99, 255, 0.45); display: block; }
    .filter-chip {
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: #cbd5e1;
        background: rgba(255, 255, 255, 0.03);
        transition: all 0.2s ease;
    }
    .filter-chip:hover { color: #fff; border-color: rgba(255, 255, 255, 0.14); background: rgba(255, 255, 255, 0.06); }
    .filter-chip.active {
        background: linear-gradient(135deg, rgba(108, 99, 255, 0.28), rgba(108, 99, 255, 0.12));
        color: #e0e7ff;
        border-color: rgba(108, 99, 255, 0.45);
        box-shadow: 0 0 0 1px rgba(108, 99, 255, 0.12), 0 2px 10px rgba(108, 99, 255, 0.12);
    }

    /* --- Product Grid & Cards --- */
    .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.75rem; margin-top: 0; }
    .product-card {
        background: rgba(15, 22, 38, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 22px;
        overflow: hidden;
        transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.35s ease, border-color 0.25s ease, background 0.25s ease;
        display: flex;
        flex-direction: column;
        position: relative;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.18);
    }
    .product-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 22px 48px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(108, 99, 255, 0.12), 0 0 40px rgba(108, 99, 255, 0.08);
        border-color: rgba(108, 99, 255, 0.25);
        background: rgba(18, 26, 44, 0.75);
    }
    .product-card.hidden { display: none; }

    /* --- Mini-Carousel --- */
    .product-carousel { position: relative; width: 100%; height: 240px; overflow: hidden; background: linear-gradient(180deg, #151d30 0%, #0a0f1a 100%); }
    .product-carousel::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, transparent 45%, rgba(11, 17, 32, 0.75) 100%);
        pointer-events: none;
        z-index: 1;
    }
    .product-track { display: flex; height: 100%; transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1); position: relative; z-index: 0; }
    .product-slide { min-width: 100%; height: 100%; object-fit: cover; }
    .product-btn { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(11,17,32,0.72); backdrop-filter: blur(10px); color: white; border: 1px solid rgba(255,255,255,0.12); width: 38px; height: 38px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; transition: all 0.3s ease; z-index: 3; }
    .product-carousel:hover .product-btn { opacity: 1; }
    .product-btn:hover { background: var(--primary); border-color: var(--primary); transform: translateY(-50%) scale(1.15); }
    .product-prev { left: 12px; } .product-next { right: 12px; }
    .product-dots { position: absolute; bottom: 15px; left: 50%; transform: translateX(-50%); display: flex; gap: 6px; z-index: 3; background: rgba(0,0,0,0.45); padding: 5px 10px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08); }
    .product-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s ease; }
    .product-dot.active { background: var(--primary); width: 16px; border-radius: 4px; }

    /* --- Quick View Overlay --- */
    .quick-view-overlay { position: absolute; inset: 0; background: rgba(8, 12, 24, 0.72); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease; z-index: 4; }
    .product-card:hover .quick-view-overlay { opacity: 1; }
    .quick-view-btn { background: linear-gradient(135deg, var(--primary), var(--primary-hover)); color: #fff; border: none; padding: 11px 24px; border-radius: 12px; font-size: 0.88rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 4px 14px rgba(108, 99, 255, 0.35); }
    .quick-view-btn:hover { transform: scale(1.02); box-shadow: 0 6px 20px rgba(108, 99, 255, 0.45); }

    /* --- Product Info --- */
    .product-info { padding: 1.35rem 1.5rem 1.6rem; display: flex; flex-direction: column; flex-grow: 1; }
    .product-category { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.14em; color: #a5b4fc; font-weight: 700; margin-bottom: 0.45rem; }
    .product-title { font-family: 'Oswald', sans-serif; font-size: 1.35rem; color: #fff; margin-bottom: 0.35rem; line-height: 1.28; letter-spacing: 0.01em; }
    .product-rating { display: flex; align-items: center; gap: 6px; margin-bottom: 0.7rem; }
    .stars { display: flex; gap: 2px; }
    .star { width: 13px; height: 13px; fill: #fbbf24; }
    .star.empty { fill: #374151; }
    .rating-text { font-size: 0.8rem; color: var(--text-muted); }

    /* Stock Badge */
    .stock-badge { display: inline-flex; align-items: center; gap: 6px; padding: 5px 11px; border-radius: 8px; font-size: 0.72rem; font-weight: 600; margin-bottom: 0.75rem; width: fit-content; }
    .stock-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .stock-in { background: rgba(74,222,128,0.1); color: #4ade80; border: 1px solid rgba(74,222,128,0.2); }
    .stock-in .stock-dot { background: #4ade80; }
    .stock-low { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }
    .stock-low .stock-dot { background: #fbbf24; }
    .stock-out { background: rgba(248,113,113,0.1); color: #f87171; border: 1px solid rgba(248,113,113,0.2); }
    .stock-out .stock-dot { background: #f87171; }

    .product-price { font-size: 1.35rem; color: #86efac; font-weight: 700; margin-bottom: 1rem; letter-spacing: -0.02em; }
    .product-price-label { display: block; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #64748b; margin-bottom: 0.2rem; }

    /* Action Buttons */
    .product-actions { margin-top: auto; display: flex; flex-direction: column; gap: 0.75rem; }
    .btn-cart { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 0.88rem 1rem; border-radius: 14px; font-weight: 600; cursor: pointer; transition: all 0.28s ease; display: flex; align-items: center; justify-content: center; gap: 10px; text-decoration: none; font-size: 0.93rem; font-family: 'Inter', sans-serif; }
    .btn-cart:hover { background: linear-gradient(135deg, var(--primary), var(--primary-hover)); border-color: transparent; box-shadow: 0 6px 22px rgba(108,99,255,0.35); transform: translateY(-2px); }
    .btn-cart.disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }

    /* --- QUICK VIEW MODAL --- */
    .modal-backdrop { position: fixed; inset: 0; background: rgba(5,10,20,0.85); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 1rem; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
    .modal-backdrop.open { opacity: 1; pointer-events: all; }
    .modal-box { background: linear-gradient(165deg, #121a2c 0%, #0d1422 100%); border: 1px solid rgba(108, 99, 255, 0.18); border-radius: 24px; max-width: 820px; width: 100%; max-height: 90vh; overflow-y: auto; transform: translateY(20px) scale(0.97); transition: transform 0.35s cubic-bezier(0.16,1,0.3,1); display: grid; grid-template-columns: 300px 1fr; box-shadow: 0 28px 56px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.04); }
    .modal-backdrop.open .modal-box { transform: translateY(0) scale(1); }
    
    .modal-img-wrap { position: relative; background: #0b1120; }
    .modal-img { width: 100%; height: 100%; min-height: 350px; object-fit: cover; border-radius: 20px 0 0 20px; }
    .modal-close { position: absolute; top: 1rem; right: 1rem; background: rgba(0,0,0,0.6); border: 1px solid var(--glass-border); color: #fff; width: 36px; height: 36px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; transition: all 0.2s; z-index: 10; }
    .modal-close:hover { background: rgba(248,113,113,0.8); }

    .modal-body { padding: 2.5rem; display: flex; flex-direction: column; }
    .modal-cat { font-size: 0.8rem; text-transform: uppercase; color: var(--primary); font-weight: 700; margin-bottom: 0.5rem; }
    .modal-name { font-family: 'Oswald', sans-serif; font-size: 2.2rem; color: #fff; margin-bottom: 0.5rem; line-height: 1.2; }
    .modal-price { font-size: 1.8rem; color: var(--success); font-weight: 700; margin-bottom: 1rem; }
    .modal-desc { font-size: 1rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 1.5rem; }

    /* Qty Counter inside Modal */
    .qty-row { display: flex; align-items: center; gap: 15px; margin-bottom: 1.5rem; }
    .qty-label { font-size: 0.95rem; color: var(--text-muted); font-weight: 600; }
    .qty-counter { display: flex; align-items: center; border: 1px solid var(--glass-border); border-radius: 10px; overflow: hidden; background: rgba(255,255,255,0.03); }
    .qty-btn { background: transparent; border: none; color: #fff; width: 40px; height: 40px; cursor: pointer; font-size: 1.2rem; transition: background 0.2s; }
    .qty-btn:hover { background: rgba(108,99,255,0.3); }
    .qty-val { padding: 0 15px; font-size: 1rem; font-weight: 700; color: #fff; min-width: 45px; text-align: center; border-left: 1px solid var(--glass-border); border-right: 1px solid var(--glass-border); }

    .modal-actions { margin-top: auto; }

    /* --- Toast Notification --- */
    .toast-container { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%); z-index: 10000; display: flex; flex-direction: column; gap: 0.5rem; align-items: center; pointer-events: none; }
    .toast { display: inline-flex; align-items: center; gap: 12px; background: rgba(15, 24, 40, 0.95); border: 1px solid rgba(74,222,128,0.4); border-radius: 12px; padding: 12px 20px; color: #fff; box-shadow: 0 8px 32px rgba(0,0,0,0.5); transform: translateY(20px); opacity: 0; transition: all 0.4s ease; }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast-icon { width: 24px; height: 24px; border-radius: 50%; background: rgba(74,222,128,0.2); display: flex; align-items: center; justify-content: center; color: #4ade80;}

    /* --- Floating Cart --- */
    .floating-cart { position: fixed; bottom: 2rem; right: 2rem; z-index: 900; display: flex; align-items: center; gap: 11px; background: linear-gradient(135deg, var(--primary), var(--primary-hover)); color: #fff; padding: 15px 24px; border-radius: 999px; font-weight: 700; font-size: 0.92rem; cursor: pointer; box-shadow: 0 8px 28px rgba(108,99,255,0.45), 0 0 0 1px rgba(255,255,255,0.12); transition: all 0.3s ease; text-decoration: none; opacity: 0; pointer-events: none; transform: translateY(10px); }
    .floating-cart.visible { opacity: 1; pointer-events: all; transform: translateY(0); }
    .floating-cart:hover { filter: brightness(1.08); transform: translateY(-4px); box-shadow: 0 14px 36px rgba(108,99,255,0.55); color: #fff; }
    .cart-count { background: rgba(255,255,255,0.25); border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; }

    @media (max-width: 900px) {
        .catalog-layout { grid-template-columns: 1fr; }
        .catalog-sidebar { position: static; top: auto; max-height: none; }
        .sidebar-body-scroll { max-height: min(42vh, 260px); }
        .catalog-hero { padding: 1.75rem 1.25rem 2.25rem; }
        .filter-chips--sidebar { flex-direction: row; flex-wrap: wrap; gap: 0.35rem; }
        .filter-chips--sidebar .filter-chip {
            width: auto;
            flex: 1 1 auto;
            min-width: calc(50% - 0.25rem);
            text-align: center;
            padding: 0.38rem 0.55rem;
            font-size: 0.72rem;
        }
    }

    @media (max-width: 768px) {
        .modal-box { grid-template-columns: 1fr; }
        .modal-img { min-height: 250px; border-radius: 20px 20px 0 0; }
    }
</style>
{% endblock %}

{% block body %}

{# ─── Toast Container ─── #}
<div class="toast-container" id="toastContainer"></div>

{# ─── Quick View Modal ─── #}
<div class="modal-backdrop" id="quickViewModal">
    <div class="modal-box">
        <div class="modal-img-wrap">
            <img src="" alt="" class="modal-img" id="modalImg">
            <button class="modal-close" id="modalClose"><i class="fas fa-xmark"></i></button>
        </div>
        <div class="modal-body">
            <div class="modal-cat" id="modalCat"></div>
            <h2 class="modal-name" id="modalName"></h2>
            <div class="modal-price" id="modalPrice"></div>
            <p class="modal-desc" id="modalDesc"></p>
            
            <div class="modal-actions">
                <div class="qty-row">
                    <span class="qty-label">Quantity:</span>
                    <div class="qty-counter">
                        <button class="qty-btn" id="modalQtyDown">−</button>
                        <span class="qty-val" id="modalQtyVal">1</span>
                        <button class="qty-btn" id="modalQtyUp">+</button>
                    </div>
                </div>
                
                {# The button inside the modal #}
                <button type="button" class="btn-cart auth-required-btn" id="modalAddCart" style="width:100%;">
                    <i class="fas fa-cart-plus"></i> Add to Cart
                </button>
            </div>
        </div>
    </div>
</div>

{# ─── Floating Cart Button ─── #}
<a href="{% if app.user %}{{ path('app_customer_cart') }}{% else %}{{ path('app_login') }}{% endif %}" class="floating-cart" id="floatingCart">
    <i class="fas fa-cart-shopping"></i> View Cart <span class="cart-count" id="cartCount">0</span>
</a>

<section class="landing-section catalog-page animate-up">

    <header class="catalog-hero">
        <span class="catalog-kicker"><i class="fas fa-store"></i> Customer catalog</span>
        <h1 class="catalog-title">
            <i class="fas fa-microchip" aria-hidden="true"></i>
            GearGrid catalog
        </h1>
        <p class="catalog-hero-sub">
            Search by name, narrow by category, or set a maximum budget in pesos and tap <strong>Search</strong> to see parts that fit what you want to spend.
        </p>
    </header>

    {# ─── Sidebar (search, categories, budget) + product grid ─── #}
    <div class="catalog-layout animate-up delay-1">
        <aside class="catalog-sidebar" aria-label="Filter catalog">
            <div class="sidebar-head">
                <div class="sidebar-head-icon" aria-hidden="true"><i class="fas fa-sliders"></i></div>
                <div>
                    <div class="sidebar-head-title">Filters</div>
                    <div class="sidebar-head-sub">Refine your results</div>
                </div>
            </div>

            <div class="sidebar-body-scroll">
                <div class="sidebar-section">
                    <span class="sidebar-label">Search</span>
                    <div class="search-filter-bar">
                        <div class="search-wrap">
                            <i class="fas fa-magnifying-glass search-icon"></i>
                            <input type="text" class="search-input" id="productSearch" placeholder="Search components…" autocomplete="off">
                        </div>
                    </div>
                </div>

                <div class="sidebar-section">
                    <span class="sidebar-label">Category</span>
                    <div class="filter-chips filter-chips--sidebar" id="filterChips">
                        <button type="button" class="filter-chip active" data-filter="all">All</button>
                        {% set unique_categories = [] %}
                        {% for product in products %}
                            {% if product.category and product.category.name not in unique_categories %}
                                {% set unique_categories = unique_categories|merge([product.category.name]) %}
                            {% endif %}
                        {% endfor %}
                        {% for category_name in unique_categories %}
                            <button type="button" class="filter-chip" data-filter="{{ category_name|lower }}">{{ category_name }}</button>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="sidebar-section sidebar-budget">
                <span class="sidebar-label">Max budget (₱)</span>
                <div class="budget-max-wrap">
                    <input type="number" class="price-input" id="priceMax" placeholder=" " min="0" step="1" inputmode="numeric" aria-label="Maximum price">
                </div>
                <button type="button" class="btn-filter-search" id="budgetSearchBtn">
                    <i class="fas fa-magnifying-glass"></i> Search
                </button>
                <p class="sidebar-hint">Enter a max price, tap Search. Clear the field and Search to show all prices.</p>
            </div>
        </aside>

        <div class="catalog-main">
            <div class="product-grid animate-up delay-2" id="productGrid">

        {% for product in products %}
            {% set cat_name = product.category ? product.category.name : 'Uncategorized' %}

            <div class="product-card"
                data-product-id="{{ product.id }}"
                data-price-num="{{ product.price }}"
                data-name="{{ product.name }}"
                data-category="{{ cat_name|lower }}"
                data-price="₱{{ product.price|number_format(2, '.', ',') }}"
                data-desc="{{ product.description|escape('html_attr') }}"
                data-img="{% if product.image %}{{ asset('uploads/products/' ~ product.image) }}{% else %}https://via.placeholder.com/600x400?text=No+Image{% endif %}">

                <div class="product-carousel">
                    <div class="product-track">
                        {% if product.image %}
                            <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}" class="product-slide">
                        {% else %}
                            <div style="width: 100%; height: 100%; background: #1e1e2f; display: flex; align-items: center; justify-content: center; color: #555;">
                                <i class="fas fa-image fa-3x"></i>
                            </div>
                        {% endif %}
                    </div>
                    
                    <div class="quick-view-overlay">
                        <button class="quick-view-btn quick-view-trigger"><i class="fas fa-eye"></i> Quick View</button>
                    </div>
                </div>

                <div class="product-info">
                    <span class="product-category">{{ cat_name }}</span>
                    <h3 class="product-title">{{ product.name }}</h3>
                    
                    {% if product.quantity > 5 %}
                        <span class="stock-badge stock-in"><span class="stock-dot"></span>In Stock</span>
                    {% elseif product.quantity > 0 %}
                        <span class="stock-badge stock-low"><span class="stock-dot"></span>Only {{ product.quantity }} left</span>
                    {% else %}
                        <span class="stock-badge stock-out"><span class="stock-dot"></span>Out of Stock</span>
                    {% endif %}

                        <div class="product-price">
                            <span class="product-price-label">Price</span>
                            ₱{{ product.price|number_format(2, '.', ',') }}
                        </div>
                    
                    {% if product.quantity > 0 %}
                        <div class="product-actions">
                            <button type="button" class="btn-cart auth-required-btn"
                                data-product-id="{{ product.id }}"
                                data-price-num="{{ product.price }}"
                                data-product="{{ product.name }}"
                                data-price="₱{{ product.price|number_format(2, '.', ',') }}">
                                <i class="fas fa-cart-plus"></i> Add to Cart
                            </button>
                        </div>
                    {% else %}
                        <div class="product-actions" style="margin-top: auto;">
                            <button class="btn-cart disabled" disabled style="opacity: 0.5; cursor: not-allowed;">
                                <i class="fas fa-ban"></i> Out of Stock
                            </button>
                        </div>
                    {% endif %}
                </div>
            </div>

        {% else %}
            <div class="no-results visible" style="grid-column: 1 / -1; display: block;">
                <i class="fas fa-box-open"></i>
                <p style="font-size:1.2rem; font-weight:600; margin-bottom:0.5rem;">No products found</p>
                <p style="font-size:0.95rem;">Check back later for new inventory.</p>
            </div>
        {% endfor %}

            <div id="noResults" class="no-results-filtered" role="status" aria-live="polite">
                <i class="fas fa-filter"></i>
                <p style="font-size:1.1rem; font-weight:600; margin-bottom:0.35rem; color: var(--text-main);">No parts match your filters</p>
                <p style="font-size:0.92rem;">Try widening your budget, choosing All categories, or clearing the search box.</p>
            </div>
            </div>
        </div>
    </div>
</section>

<script>
    const isLoggedIn = {{ app.user ? 'true' : 'false' }};
    const loginUrl = '{{ path('app_login')|e('js') }}';
    const STORAGE_KEY = 'geargrid_cart_v1';

    function loadCart() {
        try {
            const raw = localStorage.getItem(STORAGE_KEY);
            const data = raw ? JSON.parse(raw) : [];
            return Array.isArray(data) ? data : [];
        } catch (e) {
            return [];
        }
    }

    function saveCart(lines) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(lines));
    }

    document.addEventListener('DOMContentLoaded', () => {

        const toastContainer = document.getElementById('toastContainer');
        const floatingCart = document.getElementById('floatingCart');
        const cartCountEl = document.getElementById('cartCount');

        const refreshCartBadge = () => {
            const lines = loadCart();
            let n = 0;
            lines.forEach(l => { n += Number(l.qty) || 0; });
            cartCountEl.textContent = String(n);
            floatingCart.classList.toggle('visible', n > 0);
        };
        refreshCartBadge();

        const showToast = (name, price) => {
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `
                <div class="toast-icon"><i class="fas fa-check"></i></div>
                <div>
                    <div style="font-weight:700;margin-bottom:4px;">Added to cart</div>
                    <div style="font-size:0.88rem;color:#94a3b8;">${name} &nbsp;·&nbsp; ${price}</div>
                </div>`;
            toastContainer.appendChild(toast);
            requestAnimationFrame(() => { requestAnimationFrame(() => { toast.classList.add('show'); }); });
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 400);
            }, 3000);
        };

        const addLineToCart = (productId, name, priceNum, priceLabel, qty) => {
            const lines = loadCart();
            const id = Number(productId);
            const q = Math.max(1, Number(qty) || 1);
            let found = false;
            lines.forEach(line => {
                if (Number(line.productId) === id) {
                    line.qty += q;
                    found = true;
                }
            });
            if (!found) {
                lines.push({ productId: id, name, priceNum: Number(priceNum), qty: q, price: priceLabel });
            }
            saveCart(lines);
            refreshCartBadge();
        };

        let modalSourceCard = null;

        /* ─── Add to Cart ─── */
        document.querySelectorAll('.auth-required-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                if (!isLoggedIn) {
                    window.location.href = loginUrl;
                    return;
                }

                let productId, name, priceNum, priceLabel, qty = 1;

                if (btn.id === 'modalAddCart') {
                    const card = modalSourceCard;
                    if (!card || !card.dataset.productId) return;
                    productId = card.dataset.productId;
                    name = card.dataset.name;
                    priceNum = card.dataset.priceNum;
                    priceLabel = card.dataset.price;
                    const modalQtyNode = document.getElementById('modalQtyVal');
                    if (modalQtyNode) qty = parseInt(modalQtyNode.textContent, 10) || 1;
                } else {
                    productId = btn.dataset.productId;
                    name = btn.dataset.product;
                    priceNum = btn.dataset.priceNum;
                    priceLabel = btn.dataset.price;
                }

                addLineToCart(productId, name, priceNum, priceLabel, qty);
                showToast(name, priceLabel);

                if (btn.id === 'modalAddCart') {
                    closeModal();
                }
            });
        });

        /* ─── Quick View Modal ─── */
        const modal = document.getElementById('quickViewModal');
        const modalImg = document.getElementById('modalImg');
        const modalCat = document.getElementById('modalCat');
        const modalName = document.getElementById('modalName');
        const modalPrice = document.getElementById('modalPrice');
        const modalDesc = document.getElementById('modalDesc');
        const modalClose = document.getElementById('modalClose');

        document.querySelectorAll('.quick-view-trigger').forEach(btn => {
            btn.addEventListener('click', e => {
                e.preventDefault();
                e.stopPropagation();

                const card = btn.closest('.product-card');
                modalSourceCard = card;

                modalImg.src = card.dataset.img;
                modalCat.textContent = card.querySelector('.product-category').textContent;
                modalName.textContent = card.dataset.name;
                modalPrice.textContent = card.dataset.price;
                modalDesc.textContent = card.dataset.desc || 'No description provided.';

                const modalQtyNode = document.getElementById('modalQtyVal');
                if (modalQtyNode) modalQtyNode.textContent = '1';

                modal.classList.add('open');
                document.body.style.overflow = 'hidden';
            });
        });

        const closeModal = () => {
            modal.classList.remove('open');
            document.body.style.overflow = '';
        };

        if (modalClose) modalClose.addEventListener('click', closeModal);
        modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

        const btnDown = document.getElementById('modalQtyDown');
        const btnUp = document.getElementById('modalQtyUp');
        const valNode = document.getElementById('modalQtyVal');

        if (btnDown && btnUp && valNode) {
            btnDown.addEventListener('click', () => {
                const v = parseInt(valNode.textContent, 10);
                if (v > 1) valNode.textContent = String(v - 1);
            });
            btnUp.addEventListener('click', () => {
                valNode.textContent = String(parseInt(valNode.textContent, 10) + 1);
            });
        }

        /* ─── Search & Filter (budget applied when Search is clicked) ─── */
        const productSearch = document.getElementById('productSearch');
        const filterChips = document.querySelectorAll('.filter-chip');
        const productCards = document.querySelectorAll('.product-card');
        const priceMaxInput = document.getElementById('priceMax');
        const budgetSearchBtn = document.getElementById('budgetSearchBtn');
        let activeFilter = 'all';
        /** @type {number|null} */
        let budgetMax = null;

        const parseMaxBudget = () => {
            const raw = priceMaxInput && priceMaxInput.value.trim() !== '' ? parseFloat(priceMaxInput.value) : NaN;
            let maxV = Number.isFinite(raw) ? raw : null;
            if (maxV !== null && maxV < 0) maxV = 0;
            return maxV;
        };

        const applyFilters = () => {
            const query = productSearch ? productSearch.value.toLowerCase().trim() : '';
            let visibleCount = 0;
            productCards.forEach(card => {
                const name = card.dataset.name.toLowerCase();
                const category = card.dataset.category.toLowerCase();
                const matchesFilter = activeFilter === 'all' || category.includes(activeFilter) || activeFilter.includes(category);
                const matchesSearch = name.includes(query) || category.includes(query);
                const price = parseFloat(card.dataset.priceNum);
                const matchesBudget =
                    budgetMax === null || (Number.isFinite(price) && price <= budgetMax);

                if (matchesFilter && matchesSearch && matchesBudget) {
                    card.classList.remove('hidden');
                    visibleCount++;
                } else {
                    card.classList.add('hidden');
                }
            });

            const noResults = document.getElementById('noResults');
            if (noResults) {
                const showNoMatch = productCards.length > 0 && visibleCount === 0;
                noResults.classList.toggle('visible', showNoMatch);
            }
        };

        const applyBudgetFromInputs = () => {
            budgetMax = parseMaxBudget();
            applyFilters();
        };

        if (productSearch) productSearch.addEventListener('input', applyFilters);

        filterChips.forEach(chip => {
            chip.addEventListener('click', () => {
                filterChips.forEach(c => c.classList.remove('active'));
                chip.classList.add('active');
                activeFilter = chip.dataset.filter;
                applyFilters();
            });
        });

        if (budgetSearchBtn) {
            budgetSearchBtn.addEventListener('click', applyBudgetFromInputs);
        }
        if (priceMaxInput) {
            priceMaxInput.addEventListener('keydown', e => {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    applyBudgetFromInputs();
                }
            });
        }
    });
</script>
{% endblock %}