{# templates/customer/contact.html.twig #}
{% extends 'customer/base_customer.html.twig' %}

{% block title %}Contact Us | GearGrid{% endblock %}

{% block stylesheets %}
<style>
    .contact-header { text-align: center; margin-bottom: 4rem; }
    
    .contact-title {
        font-family: 'Oswald', sans-serif; font-size: 4rem; margin-bottom: 1rem;
        background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        filter: drop-shadow(0 4px 10px rgba(0,0,0,0.3)); line-height: 1.1;
    }

    .contact-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 3rem; }
    
    .contact-info {
        background: linear-gradient(to bottom, rgba(255,255,255,0.03), transparent);
        border: 1px solid var(--glass-border); border-radius: 24px; padding: 2.5rem;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }

    .contact-info img { width: 100%; border-radius: 16px; margin-bottom: 2rem; border: 1px solid var(--glass-border-hover); box-shadow: 0 10px 20px rgba(0,0,0,0.3); }
    
    .contact-item { display: flex; align-items: center; gap: 20px; margin-bottom: 1.5rem; color: var(--text-main); transition: transform 0.3s ease; }
    .contact-item:hover { transform: translateX(5px); }
    
    .contact-icon-box {
        width: 45px; height: 45px; border-radius: 12px; background: rgba(108, 99, 255, 0.15);
        color: #a5b4fc; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
        border: 1px solid rgba(108, 99, 255, 0.3); box-shadow: 0 5px 15px rgba(108, 99, 255, 0.2);
    }

    .contact-item span { font-size: 1.05rem; font-weight: 500; }

    .form-card {
        background: var(--glass-bg); border: 1px solid var(--glass-border);
        border-radius: 24px; padding: 2.5rem; box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }

    .flash-stack { display: grid; gap: 12px; margin: 0 auto 1.75rem; max-width: 920px; }
    .flash {
        display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
        padding: 1rem 1.25rem; border-radius: 16px;
        border: 1px solid var(--glass-border); background: rgba(255,255,255,0.03);
        box-shadow: 0 18px 30px rgba(0,0,0,0.18);
    }
    .flash strong { display: inline-flex; align-items: center; gap: 10px; font-size: 0.95rem; }
    .flash.success { border-color: rgba(74, 222, 128, 0.25); }
    .flash.success strong { color: #a7f3d0; }
    .flash.error { border-color: rgba(239, 68, 68, 0.25); }
    .flash.error strong { color: #fecaca; }
    .flash button { background: transparent; border: none; color: var(--text-muted); cursor: pointer; font-size: 1.2rem; padding: 0 4px; }
    .flash button:hover { color: #fff; }

    .contact-form { display: grid; gap: 14px; margin-top: 1rem; }
    .contact-form .row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .field label { display: block; color: var(--text-muted); font-size: 0.9rem; font-weight: 700; margin-bottom: 8px; }
    .field input, .field textarea {
        width: 100%;
        padding: 0.95rem 1.05rem;
        border-radius: 14px;
        border: 1px solid var(--glass-border-hover);
        background: rgba(255, 255, 255, 0.03);
        color: #fff;
        font-size: 1rem;
        outline: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }
    .field textarea { min-height: 160px; resize: vertical; }
    .field input:focus, .field textarea:focus {
        border-color: rgba(108, 99, 255, 0.55);
        background: rgba(255, 255, 255, 0.05);
        box-shadow: 0 0 0 4px rgba(108, 99, 255, 0.16);
    }
    .form-actions { display: flex; gap: 12px; align-items: center; justify-content: flex-end; margin-top: 0.25rem; flex-wrap: wrap; }
    .btn-send {
        display: inline-flex; align-items: center; justify-content: center; gap: 10px;
        padding: 1rem 1.5rem; border-radius: 16px;
        border: 1px solid rgba(108, 99, 255, 0.35);
        background: linear-gradient(135deg, rgba(108, 99, 255, 0.95), rgba(108, 99, 255, 0.75));
        color: #fff; font-weight: 800; cursor: pointer;
        box-shadow: 0 18px 34px rgba(108, 99, 255, 0.22);
        transition: transform 0.2s ease, filter 0.2s ease;
    }
    .btn-send:hover { transform: translateY(-2px); filter: brightness(1.05); }

    .helper { color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; }

    @media (max-width: 992px) {
        .contact-grid { grid-template-columns: 1fr; }
        .contact-title { font-size: 3rem; }
        .contact-form .row { grid-template-columns: 1fr; }
        .form-actions { justify-content: stretch; }
        .btn-send { width: 100%; }
    }
</style>
{% endblock %}

{% block body %}
    <section class="landing-section animate-up">

        <div class="flash-stack">
            {% for message in app.flashes('success') %}
                <div class="flash success" role="status" aria-live="polite">
                    <strong><i class="fas fa-circle-check"></i> {{ message }}</strong>
                    <button type="button" onclick="this.parentElement.remove()" aria-label="Dismiss">&times;</button>
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="flash error" role="alert">
                    <strong><i class="fas fa-triangle-exclamation"></i> {{ message }}</strong>
                    <button type="button" onclick="this.parentElement.remove()" aria-label="Dismiss">&times;</button>
                </div>
            {% endfor %}
        </div>
        
        <div class="contact-header">
            <h2 class="contact-title">Get in Touch</h2>
            <p style="color: var(--text-muted); font-size: 1.15rem; max-width: 600px; margin: 0 auto; line-height: 1.7;">
                Have a question about a product, need help with an order, or want to discuss enterprise solutions? We're here to help.
            </p>
        </div>

        <div class="contact-grid">
            <div class="contact-info animate-up delay-1">
                <img src="https://images.unsplash.com/photo-1593640408182-31c70c8268f5?auto=format&fit=crop&w=600&q=80" alt="Contact Support">
                
                <h3 style="font-family: 'Oswald', sans-serif; font-size: 1.8rem; margin-bottom: 2rem; color: #fff;">Contact Details</h3>
                
                <div class="contact-item">
                    <div class="contact-icon-box"><i class="fas fa-location-dot"></i></div>
                    <span>San Miguel Bacong Neg. Or</span>
                </div>
                <div class="contact-item">
                    <div class="contact-icon-box" style="background: rgba(74, 222, 128, 0.15); color: #4ade80; border-color: rgba(74, 222, 128, 0.3);"><i class="fas fa-phone"></i></div>
                    <span>+1 (555) 123-4567</span>
                </div>
                <div class="contact-item">
                    <div class="contact-icon-box" style="background: rgba(255, 101, 132, 0.15); color: #ff6584; border-color: rgba(255, 101, 132, 0.3);"><i class="fas fa-envelope-open-text"></i></div>
                    <span>geargrid@gmail.com</span>
                </div>
            </div>

            <div class="form-card animate-up delay-2">
                <h3 style="font-family: 'Oswald', sans-serif; font-size: 2rem; margin-bottom: 1.5rem; color: #fff;">Send us a message</h3>

                <p class="helper">
                    This form sends your message through our Brevo email system so we can respond quickly.
                </p>

                <form class="contact-form" method="post" action="{{ path('app_customer_contact') }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('customer_contact') }}">

                    <div class="row">
                        <div class="field">
                            <label for="contact_name">Full name</label>
                            <input id="contact_name" name="name" type="text" autocomplete="name" required value="{{ values.name|default('') }}">
                        </div>
                        <div class="field">
                            <label for="contact_email">Email</label>
                            <input id="contact_email" name="email" type="email" autocomplete="email" required value="{{ values.email|default('') }}">
                        </div>
                    </div>

                    <div class="field">
                        <label for="contact_subject">Subject</label>
                        <input id="contact_subject" name="subject" type="text" required value="{{ values.subject|default('') }}">
                    </div>

                    <div class="field">
                        <label for="contact_message">Message</label>
                        <textarea id="contact_message" name="message" required>{{ values.message|default('') }}</textarea>
                    </div>

                    <div class="form-actions">
                        <button class="btn-send" type="submit">
                            <i class="fas fa-paper-plane"></i>
                            Send message
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>
{% endblock %}