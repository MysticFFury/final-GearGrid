{# templates/customer/contact.html.twig #}
{% extends 'customer/base_customer.html.twig' %}

{% block title %}Contact Us | GearGrid{% endblock %}

{% block stylesheets %}
<style>
    .contact-header { text-align: center; margin-bottom: 4rem; }
    
    .contact-title {
        font-family: 'Oswald', sans-serif; font-size: 4rem; margin-bottom: 1rem;
        background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        filter: drop-shadow(0 4px 10px rgba(0,0,0,0.3)); line-height: 1.1;
    }

    .contact-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 3rem; }
    
    .contact-info {
        background: linear-gradient(to bottom, rgba(255,255,255,0.03), transparent);
        border: 1px solid var(--glass-border); border-radius: 24px; padding: 2.5rem;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }

    .contact-info img { width: 100%; border-radius: 16px; margin-bottom: 2rem; border: 1px solid var(--glass-border-hover); box-shadow: 0 10px 20px rgba(0,0,0,0.3); }
    
    .contact-item { display: flex; align-items: center; gap: 20px; margin-bottom: 1.5rem; color: var(--text-main); transition: transform 0.3s ease; }
    .contact-item:hover { transform: translateX(5px); }
    
    .contact-icon-box {
        width: 45px; height: 45px; border-radius: 12px; background: rgba(108, 99, 255, 0.15);
        color: #a5b4fc; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
        border: 1px solid rgba(108, 99, 255, 0.3); box-shadow: 0 5px 15px rgba(108, 99, 255, 0.2);
    }

    .contact-item span { font-size: 1.05rem; font-weight: 500; }

    .form-card {
        background: var(--glass-bg); border: 1px solid var(--glass-border);
        border-radius: 24px; padding: 2.5rem; box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }

    @media (max-width: 992px) {
        .contact-grid { grid-template-columns: 1fr; }
        .contact-title { font-size: 3rem; }
    }
</style>
{% endblock %}

{% block body %}
    <section class="landing-section animate-up">
        
        <div class="contact-header">
            <h2 class="contact-title">Get in Touch</h2>
            <p style="color: var(--text-muted); font-size: 1.15rem; max-width: 600px; margin: 0 auto; line-height: 1.7;">
                Have a question about a product, need help with an order, or want to discuss enterprise solutions? We're here to help.
            </p>
        </div>

        <div class="contact-grid">
            <div class="contact-info animate-up delay-1">
                <img src="https://images.unsplash.com/photo-1593640408182-31c70c8268f5?auto=format&fit=crop&w=600&q=80" alt="Contact Support">
                
                <h3 style="font-family: 'Oswald', sans-serif; font-size: 1.8rem; margin-bottom: 2rem; color: #fff;">Contact Details</h3>
                
                <div class="contact-item">
                    <div class="contact-icon-box"><i class="fas fa-location-dot"></i></div>
                    <span>San Miguel Bacong Neg. Or</span>
                </div>
                <div class="contact-item">
                    <div class="contact-icon-box" style="background: rgba(74, 222, 128, 0.15); color: #4ade80; border-color: rgba(74, 222, 128, 0.3);"><i class="fas fa-phone"></i></div>
                    <span>+1 (555) 123-4567</span>
                </div>
                <div class="contact-item">
                    <div class="contact-icon-box" style="background: rgba(255, 101, 132, 0.15); color: #ff6584; border-color: rgba(255, 101, 132, 0.3);"><i class="fas fa-envelope-open-text"></i></div>
                    <span>geargrid@gmail.com</span>
                </div>
            </div>

            <div class="form-card animate-up delay-2">
                <h3 style="font-family: 'Oswald', sans-serif; font-size: 2rem; margin-bottom: 1.5rem; color: #fff;">Send us a message</h3>
                
                <div style="width: 100%; overflow: hidden; border-radius: 16px; border: 1px solid var(--glass-border-hover); box-shadow: 0 10px 30px rgba(0,0,0,0.3); background: #0f1624;">
                    <iframe
                        src="https://docs.google.com/forms/d/e/REPLACE_WITH_YOUR_FORM_ID/viewform?embedded=true"
                        width="100%"
                        height="620"
                        frameborder="0"
                        marginheight="0"
                        marginwidth="0"
                        style="border: 0;"
                        allow="fullscreen"
                    >Loading...</iframe>
                </div>
            </div>
        </div>
    </section>
{% endblock %}