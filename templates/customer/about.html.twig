{# templates/customer/about.html.twig #}
{% extends 'customer/base_customer.html.twig' %}

{% block title %}About Us | GearGrid{% endblock %}

{% block stylesheets %}
<style>
    /* --- Hero Banner --- */
    .about-banner-container {
        position: relative; width: 100%; height: 450px;
        border-radius: 30px; overflow: hidden; margin-bottom: 5rem;
        border: 1px solid var(--glass-border-hover);
        box-shadow: 0 30px 60px rgba(0,0,0,0.4);
    }
    
    .about-banner { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.85); }

    .about-banner-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(11, 17, 32, 1) 5%, rgba(11, 17, 32, 0.4) 50%, transparent);
        display: flex; align-items: flex-end; padding: 4rem;
    }

    .about-banner-text h2 {
        font-family: 'Oswald', sans-serif; font-size: 4rem; margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        filter: drop-shadow(0 4px 10px rgba(0,0,0,0.3)); line-height: 1.1;
    }

    .about-banner-text p { font-size: 1.25rem; color: var(--text-muted); max-width: 600px; line-height: 1.7; }

    /* --- Split Story Section --- */
    .story-section { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; margin-bottom: 6rem; }
    
    .story-content h3 { font-family: 'Oswald', sans-serif; font-size: 2.8rem; color: #fff; margin-bottom: 1.5rem; text-shadow: 0 2px 10px rgba(0,0,0,0.3); }
    .story-content p { font-size: 1.1rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 1.5rem; }

    @keyframes float-subtle {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-5px); }
        100% { transform: translateY(0px); }
    }

    .mission-icon-box {
        width: 55px; height: 55px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;
        box-shadow: 0 10px 20px rgba(0,0,0,0.2); animation: float-subtle 4s ease-in-out infinite;
    }

    /* --- Team Section --- */
    .team-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2.5rem; margin-bottom: 4rem;}
    
    .team-card {
        background: linear-gradient(to bottom, rgba(255,255,255,0.03), transparent);
        border: 1px solid var(--glass-border); border-radius: 24px; padding: 3rem 2rem;
        text-align: center; transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    }

    .team-card:hover {
        transform: translateY(-10px); border-color: rgba(108,99,255,0.4);
        box-shadow: 0 20px 40px rgba(108, 99, 255, 0.15), inset 0 1px 0 rgba(255,255,255,0.1);
    }

    .team-avatar-wrapper { position: relative; width: 130px; height: 130px; margin: 0 auto 1.8rem; }
    
    .team-avatar-wrapper::after {
        content: ''; position: absolute; inset: -5px; border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        z-index: -1; opacity: 0; transition: opacity 0.4s ease; filter: blur(10px);
    }

    .team-card:hover .team-avatar-wrapper::after { opacity: 0.7; }

    .team-avatar {
        width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
        border: 4px solid rgba(255,255,255,0.1); transition: border-color 0.4s ease;
        background: var(--bg-base); /* In case image is transparent */
    }

    .team-card:hover .team-avatar { border-color: transparent; }

    .team-role {
        display: inline-block; padding: 4px 12px; background: rgba(108, 99, 255, 0.15);
        color: #a5b4fc; border-radius: 20px; font-weight: 600; font-size: 0.8rem;
        text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1rem;
    }

    .team-name { font-family: 'Oswald', sans-serif; font-size: 1.8rem; margin-bottom: 0.8rem; color: #fff; }
    .team-desc { color: var(--text-muted); font-size: 1rem; line-height: 1.6; }

    @media (max-width: 992px) {
        .story-section { grid-template-columns: 1fr; gap: 3rem; }
        .about-banner-overlay { padding: 2rem; }
        .about-banner-text h2 { font-size: 2.8rem; }
    }
</style>
{% endblock %}

{% block body %}
    <section class="animate-up">
        <div class="about-banner-container">
            <img src="https://images.unsplash.com/photo-1497215728101-856f4ea42174?auto=format&fit=crop&w=1600&q=80" alt="GearGrid Headquarters" class="about-banner">
            <div class="about-banner-overlay">
                <div class="about-banner-text">
                    <h2>Driven by Performance</h2>
                    <p>We are a passionate team of hardware enthusiasts dedicated to powering your next big build.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="story-section animate-up delay-1">
        <div class="story-content">
            <h3>Our Mission</h3>
            <p>
                Founded with a simple goal: to make premium computer hardware accessible, organized, and easy to manage. GearGrid was born out of frustration with cluttered, confusing e-commerce tech sites.
            </p>
            <p>
                Whether you are building your first gaming PC, upgrading a creative workstation, or deploying an enterprise server room, we provide the tools, the gear, and the expert support you need to succeed.
            </p>
        </div>
        
        <div class="landing-card" style="padding: 2.5rem; background: linear-gradient(145deg, rgba(255,255,255,0.03), transparent);">
            <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 1rem;">
                <div class="mission-icon-box" style="background: rgba(108, 99, 255, 0.15); color: #a5b4fc; border: 1px solid rgba(108, 99, 255, 0.3);">
                    <i class="fas fa-shield-check"></i>
                </div>
                <h4 style="font-family: 'Oswald', sans-serif; font-size: 1.5rem; color: #fff;">Guaranteed Quality</h4>
            </div>
            <p style="color: var(--text-muted); line-height: 1.7; font-size: 1.05rem;">Every single component in our catalog is heavily vetted for performance, reliability, and compatibility.</p>
            
            <hr style="border-color: var(--glass-border-hover); margin: 2rem 0;">
            
            <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 1rem;">
                <div class="mission-icon-box" style="background: rgba(74, 222, 128, 0.15); color: #4ade80; border: 1px solid rgba(74, 222, 128, 0.3); animation-delay: -2s;">
                    <i class="fas fa-truck-fast"></i>
                </div>
                <h4 style="font-family: 'Oswald', sans-serif; font-size: 1.5rem; color: #fff;">Lightning Fast</h4>
            </div>
            <p style="color: var(--text-muted); line-height: 1.7; font-size: 1.05rem;">Our streamlined warehouse workflow ensures that your gear is packed and shipped at industry-leading speeds.</p>
        </div>
    </section>

    <section class="landing-section animate-up delay-2">
        <div style="text-align: center; margin-bottom: 4rem;">
            <h2 class="section-title" style="justify-content: center; font-size: 3rem; background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"><i class="fas fa-users" style="color: var(--primary); -webkit-text-fill-color: initial;"></i> Meet the Leadership</h2>
            <p style="color: var(--text-muted); font-size: 1.15rem;">The engineers, designers, and managers keeping GearGrid running.</p>
        </div>

        <div class="team-grid">
            <div class="team-card">
                <div class="team-avatar-wrapper">
                    {# I HAVE CHANGED THIS IMAGE TO USE YOUR NEW FILE AND YOUR NAME #}
                    <img src="{{ asset('images/new_team_member.png') }}" class="team-avatar" alt="John Ralf">
                </div>
                <div class="team-role">Project Manager</div>
                <h3 class="team-name">John Ralf</h3>
                <p class="team-desc">Oversees company operations and ensures every customer gets the premium support they deserve.</p>
            </div>

            <div class="team-card">
                <div class="team-avatar-wrapper">
                    <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=256&q=80" class="team-avatar" alt="Sam Rivera">
                </div>
                <div class="team-role">Frontend Developer</div>
                <h3 class="team-name">Jhoy Andrino</h3>
                <p class="team-desc">The mastermind behind our sleek, responsive user interface and lightning-fast shopping experience.</p>
            </div>

            <div class="team-card">
                <div class="team-avatar-wrapper">
                    <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=256&q=80" class="team-avatar" alt="Jamie Cruz">
                </div>
                <div class="team-role">Backend Developer</div>
                <h3 class="team-name">Albert Base</h3>
                <p class="team-desc">Architects the secure databases and API infrastructure that keeps your orders processing safely.</p>
            </div>

            <div class="team-card">
                <div class="team-avatar-wrapper">
                    <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=256&q=80" class="team-avatar" alt="Taylor Nguyen">
                </div>
                <div class="team-role">UX Designer</div>
                <h3 class="team-name">Juvy Mae</h3>
                <p class="team-desc">Designs every workflow and interaction to ensure GearGrid is as intuitive as it is powerful.</p>
            </div>
        </div>
    </section>
{% endblock %}