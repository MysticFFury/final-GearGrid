{% extends 'base.html.twig' %}

{% block title %}Add New Product | GearGrid Admin{% endblock %}

{% block stylesheets %}
<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- Custom CSS -->
<link rel="stylesheet" href="{{ asset('css/admin_product_new.css') }}">
{% endblock %}

{% block body %}
<div class="dashboard">
    <!-- Sidebar -->
    {% include 'partials/_sidebar.html.twig' %}

    <!-- Main Content -->
    <main class="main-content">
        <!-- Top Header -->
        <div class="top-header">
            <h1>Add New Product</h1>
            <div class="user-info">
                <div class="profile">
                    <img src="https://ui-avatars.com/api/?name=John+Ralf&background=17a2b8&color=fff" alt="User">
                    <span>John Ralf</span>
                </div>
            </div>
        </div>

        <!-- Form Container -->
        <div class="form-container">
            <div class="form-card">
                <h2>Product Details</h2>

                {{ form_start(form, {'attr': {'class': 'product-form'}}) }}
                <div class="form-grid">
                    <div>
                        {{ form_row(form.name, {'label': 'Product Name', 'attr': {'placeholder': 'Enter product name'}}) }}
                        {{ form_errors(form.name) }}
                    </div>
                    <div>
                        {{ form_row(form.category, {'label': 'Category', 'attr': {'placeholder': 'Select category'}}) }}
                        {{ form_errors(form.category) }}
                    </div>
                    <div>
                        {{ form_row(form.price, {'label': 'Price (₱)', 'attr': {'placeholder': '0.00', 'type': 'number', 'step': '0.01'}}) }}
                        {{ form_errors(form.price) }}
                    </div>
                    <div>
                        {{ form_row(form.quantity, {'label': 'Quantity', 'attr': {'placeholder': '0', 'type': 'number'}}) }}
                        {{ form_errors(form.quantity) }}
                    </div>
                    <div class="full-width">
                        {{ form_row(form.description, {'label': 'Description', 'attr': {'placeholder': 'Enter product description'}}) }}
                        {{ form_errors(form.description) }}
                    </div>
                    <div class="full-width">
                        <label>Product Image</label>
                        <label class="file-upload-wrapper">
                            <i class="fas fa-cloud-upload-alt"></i>
                            {{ form_widget(form.imageFile, {
                                'attr': {
                                    'class': 'custom-file-input',
                                    'accept': 'image/*',
                                    'style': 'position:absolute;opacity:0;cursor:pointer;width:100%;height:100%;top:0;left:0;z-index:2;'
                                }
                            }) }}
                            <span style="color: #a8b4c3; font-size: 0.9rem; z-index:1; position:relative;">
                                Click to upload an image (JPG, PNG, max 5MB)
                            </span>
                        </label>
                        {{ form_errors(form.imageFile) }}
                    </div>
                </div>

                <div class="action-buttons">
                    <button type="submit" class="btn btn-save"><i class="fas fa-save"></i> Save Product</button>
                    <a href="{{ path('app_product_index') }}" class="btn btn-back"><i class="fas fa-arrow-left"></i> Cancel</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </main>
</div>
{% endblock %}
