<form method="post"
      action="{{ path('app_product_delete', {'id': product.id}) }}"
      onsubmit="return confirm('Are you sure you want to delete this product?');"
      style="display: inline-block; margin: 0;">

    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">

    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-3 py-1.5 rounded-md text-sm font-medium transition-colors flex items-center gap-1 shadow-md">
        <i class="fas fa-trash"></i> Delete
    </button>
</form>