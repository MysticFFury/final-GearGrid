{% extends 'base.html.twig' %}

{% block title %}Product Details | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<style>
    .dashboard main {
        padding: 2rem 3rem;
        min-height: 100vh;
        background: #0B1120;
        font-family: 'Inter', sans-serif;
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 pb-4 border-b border-gray-700">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">Product Details</h1>
                <nav class="flex items-center gap-2 text-sm text-gray-400">
                    <a href="{{ path('app_dashboard') }}" class="hover:text-purple-500 transition-colors">Dashboard</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <a href="{{ path('app_product_index') }}" class="hover:text-purple-500 transition-colors">Products</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <span class="text-purple-500 font-semibold">{{ product.name }}</span>
                </nav>
            </div>

            <div class="mt-4 md:mt-0 flex items-center gap-3 bg-gray-800/50 px-4 py-2 rounded-full border border-gray-700">
                <div class="text-right">
                    <p class="text-white font-semibold text-sm">{{ app.user.name|default('User') }}</p>
                    <p class="text-gray-400 text-xs">{% if is_granted('ROLE_ADMIN') %}Administrator{% else %}Staff{% endif %}</p>
                </div>
                <div class="relative">
                    <img src="https://ui-avatars.com/api/?name={{ app.user.name|default('User')|url_encode }}&background=6C63FF&color=fff" alt="User" class="w-10 h-10 rounded-full border-2 border-purple-500">
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-gray-900 rounded-full"></span>
                </div>
                <i class="fas fa-chevron-down text-gray-400 text-xs"></i>
            </div>
        </div>

        <div class="space-y-4">
            {# Flash Messages #}
            {% for message in app.flashes('success') %}
                <div class="bg-green-500/20 border border-green-500/30 text-green-400 px-4 py-3 rounded-lg flex items-center justify-between gap-3 shadow-lg shadow-green-500/10">
                    <span class="flex items-center gap-2">
                        <i class="fas fa-check-circle"></i> {{ message }}
                    </span>
                    <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-green-400 cursor-pointer text-xl opacity-80 hover:opacity-100">&times;</button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="bg-red-500/20 border border-red-500/30 text-red-400 px-4 py-3 rounded-lg flex items-center justify-between gap-3 shadow-lg shadow-red-500/10">
                    <span class="flex items-center gap-2">
                        <i class="fas fa-exclamation-circle"></i> {{ message }}
                    </span>
                    <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-red-400 cursor-pointer text-xl opacity-80 hover:opacity-100">&times;</button>
                </div>
            {% endfor %}

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border-l-4 border-purple-500 p-6">
                    <h2 class="text-xl font-semibold text-white flex items-center gap-3 mb-6">
                        <i class="fas fa-box text-purple-500"></i> Product Information
                    </h2>

                    <div class="space-y-4">
                        <div class="flex justify-between items-start border-b border-gray-700 pb-4">
                            <span class="text-gray-400 text-sm uppercase tracking-wider">Reference ID</span>
                            <span class="text-pink-500 font-mono bg-pink-500/10 px-3 py-1 rounded-md text-sm">#{{ product.id }}</span>
                        </div>

                        <div class="flex justify-between items-start border-b border-gray-700 pb-4">
                            <span class="text-gray-400 text-sm uppercase tracking-wider">Product Name</span>
                            <span class="text-white font-semibold">{{ product.name }}</span>
                        </div>

                        <div class="flex justify-between items-start border-b border-gray-700 pb-4">
                            <span class="text-gray-400 text-sm uppercase tracking-wider">Category</span>
                            {% if product.category %}
                                <span class="text-purple-500 bg-purple-500/10 px-3 py-1 rounded-md text-sm">{{ product.category.name }}</span>
                            {% else %}
                                <span class="text-gray-400">No category assigned</span>
                            {% endif %}
                        </div>

                        <div class="flex justify-between items-start border-b border-gray-700 pb-4">
                            <span class="text-gray-400 text-sm uppercase tracking-wider">Price</span>
                            <span class="text-green-400 font-semibold text-lg">₱{{ product.price|number_format(2, '.', ',') }}</span>
                        </div>

                        <div class="flex justify-between items-start border-b border-gray-700 pb-4">
                            <span class="text-gray-400 text-sm uppercase tracking-wider">Quantity</span>
                            <span class="bg-green-500/10 text-green-400 px-3 py-1 rounded-md font-semibold">{{ product.quantity }} units</span>
                        </div>

                        <div class="flex justify-between items-start border-b border-gray-700 pb-4">
                            <span class="text-gray-400 text-sm uppercase tracking-wider">Created Date</span>
                            <span class="text-gray-300">{{ product.createdAt|date('F d, Y \\a\\t g:i A') }}</span>
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border-l-4 border-blue-500 p-6">
                        <h2 class="text-xl font-semibold text-white flex items-center gap-3 mb-6">
                            <i class="fas fa-image text-blue-500"></i> Product Image
                        </h2>
                        <div class="text-center">
                            {% if product.image %}
                                <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}" class="w-full max-w-md mx-auto rounded-lg shadow-lg border border-gray-700">
                            {% else %}
                                <div class="w-full max-w-md mx-auto h-64 flex items-center justify-center bg-gray-700/50 rounded-lg border-2 border-dashed border-gray-600">
                                    <i class="fas fa-image text-5xl text-gray-500 opacity-50"></i>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border-l-4 border-green-500 p-6">
                        <h2 class="text-xl font-semibold text-white flex items-center gap-3 mb-4">
                            <i class="fas fa-align-left text-green-500"></i> Description
                        </h2>
                        <p class="text-gray-300 leading-relaxed">
                            {{ product.description ?: 'No description available for this product.' }}
                        </p>
                    </div>
                </div>
            </div>

            <div class="flex flex-wrap gap-3 pt-4 border-t border-gray-700">
                <a href="{{ path('app_product_index') }}" class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
                
                {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
                    <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-lg shadow-purple-500/20">
                        <i class="fas fa-edit"></i> Edit Product
                    </a>

                    {{ include('product/_delete_form.html.twig') }}
                {% endif %}
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
            message.style.transition = 'opacity 0.5s';
            message.style.opacity = '0';
            setTimeout(function() {
                message.remove();
            }, 500);
        });
    }, 5000);
});
</script>
{% endblock %}
