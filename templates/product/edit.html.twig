{% extends 'base.html.twig' %}

{% block title %}Edit Product | GearGrid Admin{% endblock %}

{% block stylesheets %}
<!-- Font Awesome for Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!-- Google Fonts for Oswald -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- Page CSS -->
<link rel="stylesheet" href="{{ asset('css/admin_product_edit.css') }}">
{% endblock %}

{% block body %}
<div class="dashboard">

    <!-- Sidebar -->
    {% include 'partials/_sidebar.html.twig' %}

    <!-- Main Content -->
    <main class="main-content">

        <!-- Top Header -->
        <div class="top-header">
            <h1>Edit Product</h1>

            <div class="user-info">
                <div class="profile">
                    <img src="https://ui-avatars.com/api/?name=John+Ralf&background=17a2b8&color=fff" alt="User">
                    <span>John Ralf</span>
                </div>
            </div>
        </div>

        <!-- Content Area -->
        <div class="content-area">

            <!-- Card with Form -->
            <div class="form-card">
                {{ include('product/_form.html.twig', {'button_label': 'Update'}) }}
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <a href="{{ path('app_product_index') }}" class="btn btn-back">
                    <i class="fas fa-arrow-left"></i> Back to list
                </a>

                {{ include('product/_delete_form.html.twig') }}
            </div>

        </div>
    </main>

    <!-- Footer -->
    <footer>
        &copy; {{ "now"|date("Y") }} GearGrid Admin Panel. All Rights Reserved.
    </footer>
</div>
{% endblock %}
