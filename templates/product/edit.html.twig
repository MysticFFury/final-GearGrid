{% extends 'base.html.twig' %}

{% block title %}Edit Product | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<style>
    .dashboard main {
        padding: 2rem 3rem;
        min-height: 100vh;
        background: #0B1120;
        font-family: 'Inter', sans-serif;
    }
    
    select option {
        background: #1f2937;
        color: #fff;
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 pb-4 border-b border-gray-700">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">Edit Product</h1>
                <nav class="flex items-center gap-2 text-sm text-gray-400">
                    <a href="{{ path('app_dashboard') }}" class="hover:text-purple-500 transition-colors">Dashboard</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <a href="{{ path('app_product_index') }}" class="hover:text-purple-500 transition-colors">Products</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <a href="{{ path('app_product_show', {'id': product.id}) }}" class="hover:text-purple-500 transition-colors">{{ product.name }}</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <span class="text-purple-500 font-semibold">Edit</span>
                </nav>
            </div>

            <div class="mt-4 md:mt-0 flex items-center gap-3 bg-gray-800/50 px-4 py-2 rounded-full border border-gray-700">
                <div class="text-right">
                    <p class="text-white font-semibold text-sm">{{ app.user.name|default('User') }}</p>
                    <p class="text-gray-400 text-xs">{% if is_granted('ROLE_ADMIN') %}Administrator{% else %}Staff{% endif %}</p>
                </div>
                <div class="relative">
                    <img src="https://ui-avatars.com/api/?name={{ app.user.name|default('User')|url_encode }}&background=6C63FF&color=fff" alt="User" class="w-10 h-10 rounded-full border-2 border-purple-500">
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-gray-900 rounded-full"></span>
                </div>
                <i class="fas fa-chevron-down text-gray-400 text-xs"></i>
            </div>
        </div>

        <div class="space-y-4">
            {# Flash Messages #}
            {% for message in app.flashes('success') %}
                <div class="bg-green-500/20 border border-green-500/30 text-green-400 px-4 py-3 rounded-lg flex items-center justify-between gap-3 shadow-lg shadow-green-500/10">
                    <span class="flex items-center gap-2">
                        <i class="fas fa-check-circle"></i> {{ message }}
                    </span>
                    <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-green-400 cursor-pointer text-xl opacity-80 hover:opacity-100">&times;</button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="bg-red-500/20 border border-red-500/30 text-red-400 px-4 py-3 rounded-lg flex items-center justify-between gap-3 shadow-lg shadow-red-500/10">
                    <span class="flex items-center gap-2">
                        <i class="fas fa-exclamation-circle"></i> {{ message }}
                    </span>
                    <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-red-400 cursor-pointer text-xl opacity-80 hover:opacity-100">&times;</button>
                </div>
            {% endfor %}

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border-l-4 border-purple-500 p-6">
                <h2 class="text-xl font-semibold text-white flex items-center gap-3 mb-6">
                    <i class="fas fa-edit text-purple-500"></i> Edit Product
                </h2>

                {{ form_start(form, { 'attr': { 'class': 'space-y-6' } }) }}
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        {{ form_label(form.name, null, {'label_attr': {'class': 'text-gray-400 text-sm uppercase tracking-wider font-medium'}}) }}
                        {{ form_widget(form.name, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500', 'placeholder': 'Enter product name'}}) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="space-y-2">
                        {{ form_label(form.category, null, {'label_attr': {'class': 'text-gray-400 text-sm uppercase tracking-wider font-medium'}}) }}
                        {{ form_widget(form.category, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500'}}) }}
                        {{ form_errors(form.category) }}
                    </div>

                    <div class="space-y-2">
                        {{ form_label(form.price, null, {'label_attr': {'class': 'text-gray-400 text-sm uppercase tracking-wider font-medium'}}) }}
                        {{ form_widget(form.price, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500', 'placeholder': '0.00', 'step': '0.01'}}) }}
                        {{ form_errors(form.price) }}
                    </div>

                    <div class="space-y-2">
                        {{ form_label(form.quantity, null, {'label_attr': {'class': 'text-gray-400 text-sm uppercase tracking-wider font-medium'}}) }}
                        {{ form_widget(form.quantity, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500', 'placeholder': '0', 'min': '0'}}) }}
                        {{ form_errors(form.quantity) }}
                    </div>

                    <div class="space-y-2 md:col-span-2">
                        {{ form_label(form.description, null, {'label_attr': {'class': 'text-gray-400 text-sm uppercase tracking-wider font-medium'}}) }}
                        {{ form_widget(form.description, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white placeholder-gray-400 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 min-h-[120px]', 'placeholder': 'Enter product description (optional)'}}) }}
                        {{ form_errors(form.description) }}
                    </div>

                    <div class="space-y-2 md:col-span-2">
                        {{ form_label(form.imageFile, null, {'label_attr': {'class': 'text-gray-400 text-sm uppercase tracking-wider font-medium'}}) }}
                        {{ form_widget(form.imageFile, {'attr': {'class': 'w-full px-4 py-2 rounded-lg border border-gray-700 bg-gray-800/50 text-white focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500'}}) }}
                        {{ form_errors(form.imageFile) }}
                        {% if product.image %}
                            <p class="text-gray-400 text-sm">Current image: {{ product.image }}</p>
                        {% endif %}
                    </div>
                </div>

                <div class="flex flex-wrap gap-3 pt-4 border-t border-gray-700">
                    <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-lg shadow-purple-500/20">
                        <i class="fas fa-save"></i> Update Product
                    </button>
                </div>

                {{ form_end(form) }}

                <div class="flex flex-wrap gap-3 pt-4 border-t border-gray-700">
                    <a href="{{ path('app_product_show', {'id': product.id}) }}" class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                        <i class="fas fa-arrow-left"></i> Back to Details
                    </a>

                    {{ include('product/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
            message.style.transition = 'opacity 0.5s';
            message.style.opacity = '0';
            setTimeout(function() {
                message.remove();
            }, 500);
        });
    }, 5000);
});
</script>
{% endblock %}
