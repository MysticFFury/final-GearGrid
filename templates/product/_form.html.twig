{{ form_start(form, {'attr': {'class': 'gg-form'}}) }}

<div class="gg-form-grid">
    <div class="form-group">
        {{ form_label(form.name) }}
        {{ form_widget(form.name, {'attr': {'class': 'gg-input', 'placeholder': 'Enter product name'}}) }}
        {{ form_errors(form.name) }}
    </div>

    <div class="form-group">
        {{ form_label(form.category) }}
        {{ form_widget(form.category, {'attr': {'class': 'gg-input', 'placeholder': 'Select category'}}) }}
        {{ form_errors(form.category) }}
    </div>

    <div class="form-group">
        {{ form_label(form.price) }}
        {{ form_widget(form.price, {'attr': {'class': 'gg-input', 'placeholder': '0.00', 'step': '0.01'}}) }}
        {{ form_errors(form.price) }}
    </div>

    <div class="form-group">
        {{ form_label(form.quantity) }}
        {{ form_widget(form.quantity, {'attr': {'class': 'gg-input', 'placeholder': '0', 'min': '0'}}) }}
        {{ form_errors(form.quantity) }}
    </div>

    <div class="form-group gg-full">
        {{ form_label(form.description) }}
        {{ form_widget(form.description, {'attr': {'class': 'gg-input', 'placeholder': 'Enter product description (optional)'}}) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="form-group gg-full">
        {{ form_label(form.imageFile) }}
        {{ form_widget(form.imageFile, {'attr': {'class': 'gg-input'}}) }}
        {{ form_errors(form.imageFile) }}
    </div>
</div>

{{ form_end(form) }}
