<form method="post" action="{{ path('app_order_delete', {'id': order.id}) }}" 
      style="display:inline; margin: 0;" 
      onsubmit="return confirm('Are you sure you want to delete this order?');">
      
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
    
    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-3 py-1.5 rounded-lg text-sm font-medium transition-colors flex items-center gap-1 shadow-md">
        <i class="fas fa-trash"></i> Delete
    </button>
</form>
