{% extends 'base.html.twig' %}

{% block title %}Order Details | GearGrid Admin{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdn.tailwindcss.com"></script>

<style>
    :root {
        --primary: #6C63FF;
        --primary-hover: #5b54d6;
        --secondary: #ff6584;
        --success: #4ade80;
        --bg-base: #0B1120;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --glass-bg: rgba(255, 255, 255, 0.02);
        --glass-bg-hover: rgba(255, 255, 255, 0.04);
        --glass-border: rgba(255, 255, 255, 0.06);
        --glass-border-hover: rgba(255, 255, 255, 0.12);
        --danger: #dc3545;
        --card-bg: rgba(255, 255, 255, 0.02);
    }

    .dashboard main {
        margin-left: 16rem;
        padding: 2rem 3rem;
        min-height: 100vh;
        background: var(--bg-base);
    }

    .detail-table { width: 100%; border-collapse: collapse; margin-bottom: 3rem; }
    .detail-table tr { border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
    .detail-table tr:last-child { border: none; }
    .detail-table th {
        text-align: left; padding: 1.5rem 0; color: var(--text-muted);
        font-weight: 500; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1.5px; width: 35%;
    }
    .detail-table td { padding: 1.5rem 0; color: #fff; font-size: 1.1rem; }

    .badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .badge-secondary {
        color: var(--secondary);
        font-family: monospace;
        background: rgba(255,101,132,0.1);
    }

    .status-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-pending {
        background: rgba(251, 191, 36, 0.2);
        color: #fbbf24;
    }

    .status-processing {
        background: rgba(59, 130, 246, 0.2);
        color: #3b82f6;
    }

    .status-shipped {
        background: rgba(139, 92, 246, 0.2);
        color: #8b5cf6;
    }

    .status-delivered {
        background: rgba(34, 197, 94, 0.2);
        color: #22c55e;
    }

    .status-completed {
        background: rgba(74, 222, 128, 0.2);
        color: #4ade80;
    }

    .status-cancelled {
        background: rgba(239, 68, 68, 0.2);
        color: #ef4444;
    }

    .product-item {
        display: inline-block;
        padding: 6px 12px;
        margin: 4px 4px 4px 0;
        background: rgba(108, 99, 255, 0.1);
        color: var(--primary);
        border-radius: 6px;
        font-size: 0.9rem;
    }

    @media (max-width: 768px) {
        .dashboard main {
            margin-left: 0;
            padding: 1rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="dashboard">
    {% include 'partials/_sidebar.html.twig' %}

    <main class="main-content">
        <!-- Top Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 pb-6 border-b border-gray-800">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2">Order Details</h1>
                <nav class="flex items-center gap-2 text-sm text-gray-400">
                    <a href="{{ path('app_dashboard') }}" class="hover:text-purple-400 transition-colors">Dashboard</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <a href="{{ path('app_order_index') }}" class="hover:text-purple-400 transition-colors">Orders</a>
                    <i class="fas fa-chevron-right text-xs opacity-50"></i>
                    <span class="text-pink-400 font-semibold">Order #{{ order.id }}</span>
                </nav>
            </div>
            <div class="mt-4 md:mt-0 flex items-center gap-3 bg-gray-800/50 px-4 py-2 rounded-full border border-gray-700">
                <div class="text-right">
                    <p class="text-white font-semibold text-sm">{{ app.user.name|default(app.user.username|default('Admin')) }}</p>
                    <p class="text-gray-400 text-xs">{% if is_granted('ROLE_ADMIN') %}Administrator{% else %}Staff{% endif %}</p>
                </div>
                <div class="relative">
                    <img src="https://ui-avatars.com/api/?name={{ app.user.name|default(app.user.username|default('Admin'))|url_encode }}&background=6C63FF&color=fff" alt="User" class="w-10 h-10 rounded-lg border-2 border-purple-500">
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-gray-900 rounded-full"></span>
                </div>
                <i class="fas fa-chevron-down text-gray-400 text-xs"></i>
            </div>
        </div>

        {# Flash Messages #}
        {% for message in app.flashes('success') %}
            <div class="mb-6 p-4 rounded-lg flex items-center justify-between gap-3 bg-green-500/20 text-green-400 border border-green-500/30 shadow-lg shadow-green-500/20 max-w-3xl mx-auto">
                <span class="flex items-center gap-2">
                    <i class="fas fa-check-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-white cursor-pointer text-xl opacity-80 px-1">&times;</button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="mb-6 p-4 rounded-lg flex items-center justify-between gap-3 bg-red-500/20 text-red-400 border border-red-500/30 shadow-lg shadow-red-500/20 max-w-3xl mx-auto">
                <span class="flex items-center gap-2">
                    <i class="fas fa-exclamation-circle"></i> {{ message }}
                </span>
                <button onclick="this.parentElement.remove()" class="bg-transparent border-none text-white cursor-pointer text-xl opacity-80 px-1">&times;</button>
            </div>
        {% endfor %}

        <div class="max-w-3xl mx-auto">
            <div class="bg-gray-800/30 border border-gray-700 rounded-xl p-8 border-t-4 border-t-purple-500">
                <h2 class="text-xl font-semibold text-white mb-8 flex items-center gap-3"><i class="fas fa-receipt text-purple-500"></i> Order Information</h2>

                <table class="detail-table">
                    <tbody>
                        <tr>
                            <th>Order ID</th>
                            <td><span class="badge badge-secondary">#{{ order.id }}</span></td>
                        </tr>
                        <tr>
                            <th>Customer Name</th>
                            <td class="font-semibold text-white">{{ order.customerName }}</td>
                        </tr>
                        <tr>
                            <th>Total Price</th>
                            <td class="text-green-400 font-semibold text-2xl">₱{{ order.totalPrice|number_format(2, '.', ',') }}</td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td>
                                <span class="status-badge status-{{ order.status|lower }}">
                                    {{ order.status }}
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th>Created Date</th>
                            <td class="text-gray-400">{{ order.createdAt ? order.createdAt|date('F d, Y \a\t g:i A') : 'N/A' }}</td>
                        </tr>
                        <tr>
                            <th>Products</th>
                            <td>
                                {% if order.products|length > 0 %}
                                    <div class="flex flex-wrap gap-2 mt-1">
                                        {% for product in order.products %}
                                            <span class="product-item">{{ product.name }}</span>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <span class="text-gray-400">No products assigned</span>
                                {% endif %}
                            </td>
                        </tr>
                    </tbody>
                </table>

                <div class="flex flex-wrap gap-4 pt-10 border-t border-gray-700">
                    <a href="{{ path('app_order_index') }}" class="bg-gray-700/50 hover:bg-gray-600/50 text-gray-300 hover:text-white border border-gray-600 px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                    
                    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
                        <a href="{{ path('app_order_edit', {'id': order.id}) }}" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center gap-2 shadow-lg shadow-purple-500/20">
                            <i class="fas fa-edit"></i> Edit Order
                        </a>

                        {{ include('order/_delete_form.html.twig') }}
                    {% endif %}
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// Auto-dismiss flash messages after 5 seconds
document.addEventListener('DOMContentLoaded', function() {
    setTimeout(function() {
        const flashMessages = document.querySelectorAll('.flash-message');
        flashMessages.forEach(function(message) {
            message.style.transition = 'opacity 0.5s';
            message.style.opacity = '0';
            setTimeout(function() {
                message.remove();
            }, 500);
        });
    }, 5000);
});
</script>
{% endblock %}
