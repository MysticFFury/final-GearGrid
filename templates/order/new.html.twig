{% extends 'base.html.twig' %}

{% block title %}Add New Order | GearGrid Admin{% endblock %}

{% block stylesheets %}
<!-- Font Awesome for Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!-- Google Fonts for Oswald -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- Optional: Custom CSS -->
<link rel="stylesheet" href="{{ asset('css/admin_product_new.css') }}">
{% endblock %}

{% block body %}
<div class="dashboard">
    <!-- Sidebar -->
    {% include 'partials/_sidebar.html.twig' %}

    <!-- Main Content -->
    <main class="main-content">
        <!-- Top Header -->
        <div class="top-header">
            <h1>Add New Order</h1>
            <div class="user-info">
                <div class="profile">
                    <img src="https://ui-avatars.com/api/?name=John+Ralf&background=17a2b8&color=fff" alt="User">
                    <span>John Ralf</span>
                </div>
            </div>
        </div>

        <!-- Form Container -->
        <div class="form-container">
            <div class="form-card">
                <h2>Order Details</h2>

                {{ form_start(form, {'attr': {'class': 'order-form'}}) }}
                <div class="form-grid">
                    <div>
                        {{ form_row(form.customerName, {'label': 'Customer Name', 'attr': {'placeholder': 'Enter customer name'}}) }}
                        {{ form_errors(form.customerName) }}
                    </div>
                    <div>
                        {{ form_row(form.totalPrice, {'label': 'Total Price (₱)', 'attr': {'placeholder': '0.00', 'type': 'number', 'step': '0.01'}}) }}
                        {{ form_errors(form.totalPrice) }}
                    </div>
                    <div>
                        {{ form_row(form.status, {'label': 'Status', 'attr': {'placeholder': 'Select status'}}) }}
                        {{ form_errors(form.status) }}
                    </div>
                    {# Optional notes field
                    <div class="full-width">
                        {{ form_row(form.notes, {'label': 'Notes', 'attr': {'placeholder': 'Additional notes'}}) }}
                        {{ form_errors(form.notes) }}
                    </div>
                    #}
                </div>

                <div class="action-buttons">
                    <button type="submit" class="btn btn-save"><i class="fas fa-save"></i> Save Order</button>
                    <a href="{{ path('app_order_index') }}" class="btn btn-back"><i class="fas fa-arrow-left"></i> Cancel</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </main>
</div>
{% endblock %}
